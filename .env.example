# =============================================================================
# BlogPlatform — local environment variables for docker-compose
#
# Copy this file to .env and fill in the values before running:
#   cp .env.example .env
#
# .env is listed in .gitignore — never commit it.
# =============================================================================

# SQL Server sa password
# Must meet SQL Server complexity requirements:
#   - At least 8 characters
#   - Upper + lower + digit + symbol
SQL_SA_PASSWORD=BlogPlatform_Dev#2024

# Umbraco backoffice admin account (created on first boot)
UMBRACO_ADMIN_NAME=Blog Admin
UMBRACO_ADMIN_EMAIL=admin@blogplatform.local
UMBRACO_ADMIN_PASSWORD=BlogPlatform_Admin#2024

# API key used by the content seed workflow and cache refresh endpoint
BLOG_CONTENT_SEED_API_KEY=local-dev-seed-key

# ...
UMBRACO_HMAC_SECRET_KEY=0123456789ABCDEF0123456789ABCDEF0123456789ABCDEF0123456789ABCDEF
