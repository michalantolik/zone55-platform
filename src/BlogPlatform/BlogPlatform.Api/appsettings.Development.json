{
  "ConnectionStrings": {
    "umbracoDbDSN": "Server=(localdb)\\MSSQLLocalDB;Database=BlogPlatformUmbracoDb;Integrated Security=true;TrustServerCertificate=true;"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:7252",
      "http://localhost:5016",
      "https://localhost:7180",
      "http://localhost:5179"
    ]
  },

  "ClientLogging": {
    "Enabled": true,
    "MaxMessageLength": 2000
  },

  "UmbracoDeliveryApi": {
    "BaseUrl": "https://localhost:44393/",
    "PostsEndpoint": "api/blog-content/articles",
    "FreshCacheSeconds": 600,
    "StaleCacheSeconds": 3600,
    "TimeoutSeconds": 30,
    "RetryCount": 3,
    "RetryDelayMilliseconds": 1500
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
