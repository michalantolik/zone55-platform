{
  "AllowedHosts": "*",

  "Cors": {
    "AllowedOrigins": []
  },

  "ClientLogging": {
    "Enabled": false,
    "MaxMessageLength": 2000
  },

  "UmbracoDeliveryApi": {
    "BaseUrl": "https://localhost:44393",
    "PostsEndpoint": "api/blog-content/articles",
    "FreshCacheSeconds": 600,
    "StaleCacheSeconds": 3600,
    "TimeoutSeconds": 30,
    "RetryCount": 3,
    "RetryDelayMilliseconds": 1500
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
