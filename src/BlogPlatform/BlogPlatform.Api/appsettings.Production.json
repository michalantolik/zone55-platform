{
  "ConnectionStrings": {
    "umbracoDbDSN": ""
  },

  "Cors": {
    "AllowedOrigins": [
      "https://YOUR_STATIC_WEB_APP_URL"
    ]
  },

  "ClientLogging": {
    "Enabled": false,
    "MaxMessageLength": 2000
  },

  "UmbracoDeliveryApi": {
    "BaseUrl": "https://YOUR_CMS_APP_SERVICE_URL",
    "PostsEndpoint": "api/blog-content/articles",
    "FreshCacheSeconds": 600,
    "StaleCacheSeconds": 3600,
    "TimeoutSeconds": 30,
    "RetryCount": 3,
    "RetryDelayMilliseconds": 1500
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
