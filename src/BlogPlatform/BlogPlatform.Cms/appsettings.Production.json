{
  "$schema": "appsettings-schema.json",

  "KeyVault": {
    "VaultUri": ""
  },

  "ApplicationInsights": {
    "ConnectionString": ""
  },

  "BlogContentSeeder": {
    "Enabled": false,
    "ContentFilePath": "Seeding/blog-content.seed.json"
  },

  "ConnectionStrings": {
    "umbracoDbDSN": "",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.SqlClient"
  },

  "Umbraco": {
    "CMS": {
      "Global": {
        "UseHttps": true,
        "InstallMissingDatabase": true
      },
      "Runtime": {
        "Mode": "Production"
      },
      "WebRouting": {
        "UmbracoApplicationUrl": "https://YOUR_CMS_APP_URL/"
      },
      "ModelsBuilder": {
        "ModelsMode": "Nothing"
      },
      "Unattended": {
        "InstallUnattended": true,
        "UpgradeUnattended": true
      },
      "Imaging": {
        "HMACSecretKey": ""
      }
    }
  },

  "BlogPreview": {
    "AppPreviewUrl": "https://YOUR_STATIC_WEB_APP_URL/preview/article"
  }
}
