@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Blog admin</title>

    <style>
        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: Inter, Arial, sans-serif;
            background: #061325;
            color: #f5f7fb;
        }

        .admin-shell {
            min-height: 100vh;
            background: radial-gradient(circle at top left, rgba(22, 119, 255, 0.22), transparent 34rem), #061325;
        }

        .top-bar {
            height: 64px;
            display: flex;
            align-items: center;
            padding: 0 28px;
            gap: 28px;
            background: #0b1b33;
            border-bottom: 1px solid #24405f;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.25);
        }

        .brand { display: flex; align-items: center; gap: 12px; font-weight: 900; letter-spacing: 0.02em; }

        .brand-mark {
            width: 34px;
            height: 34px;
            border-radius: 999px;
            display: grid;
            place-items: center;
            background: #1677ff;
            color: white;
            font-weight: 900;
        }

        .top-nav { display: flex; height: 100%; align-items: center; gap: 6px; }

        .top-nav button {
            height: 100%;
            display: flex;
            align-items: center;
            border: 0;
            border-bottom: 3px solid transparent;
            padding: 0 18px;
            background: transparent;
            color: #c8d8ef;
            font: inherit;
            font-weight: 800;
            text-decoration: none;
            cursor: pointer;
        }

        .top-nav button:hover,
        .top-nav button.active {
            color: white;
            border-bottom-color: #84bbff;
            background: rgba(255, 255, 255, 0.04);
        }

        .content { padding: 28px; }
        .content.editor-active { padding: 18px; }

        .hero {
            max-width: 1180px;
            margin: 0 auto 24px auto;
            padding: 26px;
            border: 1px solid #24405f;
            border-radius: 22px;
            background: rgba(9, 28, 52, 0.92);
        }

        .hero h1 { margin: 0 0 10px 0; font-size: 34px; }
        .hero p { margin: 0; color: #aac2de; line-height: 1.6; }

        .toolbar {
            max-width: 1180px;
            margin: 0 auto 20px auto;
            display: flex;
            gap: 14px;
            align-items: center;
        }

        .toolbar.hidden { display: none; }

        .search {
            flex: 1;
            border-radius: 12px;
            border: 1px solid #35527a;
            background: #020b18;
            color: white;
            padding: 13px 15px;
            font-size: 15px;
        }

        .status { color: #84bbff; font-weight: 800; white-space: nowrap; }

        .panel { max-width: 1180px; margin: 0 auto; display: none; }
        .panel.active { display: block; }
        .panel.article-editor-panel-active { max-width: none; }

        .editor-frame-shell {
            height: calc(100vh - 100px);
            min-height: 680px;
            border: 1px solid #24405f;
            border-radius: 18px;
            overflow: hidden;
            background: #06152b;
            box-shadow: 0 18px 42px rgba(0, 0, 0, 0.28);
        }

        .editor-frame {
            width: 100%;
            height: 100%;
            border: 0;
            display: block;
            background: #061325;
        }

        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 18px; }

        .card {
            border: 1px solid #24405f;
            border-radius: 18px;
            background: rgba(4, 17, 29, 0.9);
            padding: 20px;
            box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
        }

        .card h2, .card h3 { margin: 0 0 10px 0; }
        .card p { margin: 0; color: #aac2de; line-height: 1.5; }

        .card-header {
            display: flex;
            justify-content: space-between;
            gap: 16px;
            align-items: flex-start;
        }

        .card-main,
        .article-main,
        .document-type-main {
            min-width: 0;
        }

        .card-actions,
        .article-actions,
        .document-type-actions,
        .zone-admin-actions,
        .step-admin-actions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 10px;
            flex-shrink: 0;
        }

        .zone-badge,
        .step-badge {
            display: inline-flex;
            margin-top: 16px;
            padding: 7px 10px;
            border-radius: 999px;
            background: #163b62;
            color: #a7d0ff;
            font-size: 13px;
            font-weight: 800;
        }

        .zones-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(420px, 1fr));
            gap: 18px;
        }

        .zone-card {
            border: 1px solid #24405f;
            border-radius: 20px;
            background: rgba(4, 17, 29, 0.9);
            padding: 20px;
            box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
        }

        .zone-card-header {
            display: grid;
            grid-template-columns: auto 1fr auto;
            gap: 14px;
            align-items: start;
            margin-bottom: 18px;
        }

        .zone-order-mark,
        .step-order-mark {
            width: 38px;
            height: 38px;
            border-radius: 999px;
            display: grid;
            place-items: center;
            border: 1px solid rgba(132, 187, 255, 0.44);
            background: linear-gradient(180deg, rgba(132, 187, 255, 0.20), rgba(22, 119, 255, 0.08));
            color: #d7eaff;
            font-size: 14px;
            font-weight: 900;
        }

        .zone-card h2 {
            margin: 0 0 7px 0;
            font-size: 22px;
        }

        .zone-key,
        .step-key {
            color: #aac2de;
            font-size: 13px;
            line-height: 1.4;
        }

        .zone-count {
            align-self: start;
            white-space: nowrap;
        }

        .zone-steps {
            display: grid;
            gap: 10px;
        }

        .zone-step-row {
            display: grid;
            grid-template-columns: auto 1fr auto auto;
            gap: 12px;
            align-items: center;
            border: 1px solid rgba(36, 64, 95, 0.86);
            border-radius: 14px;
            background: rgba(8, 28, 49, 0.72);
            padding: 12px 14px;
        }
.step-order-mark {
            width: 30px;
            height: 30px;
            font-size: 12px;
        }

        .step-name {
            font-weight: 900;
            margin-bottom: 3px;
        }

        .step-badge {
            margin-top: 0;
            white-space: nowrap;
        }

        .zone-step-group { margin-bottom: 26px; }

        .zone-step-heading {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 0 0 12px 0;
            color: #84bbff;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-size: 14px;
            font-weight: 900;
        }

        .article-list { display: grid; gap: 12px; }

        .article-row {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 18px;
            align-items: center;
            border: 1px solid #24405f;
            border-radius: 16px;
            background: rgba(4, 17, 29, 0.88);
            padding: 16px 18px;
        }

        .article-title { font-weight: 900; margin-bottom: 5px; }
        .article-meta { color: #aac2de; font-size: 14px; }

        .btn {
            border: 0;
            border-radius: 10px;
            padding: 11px 14px;
            background: #1677ff;
            color: white;
            font-weight: 800;
            text-decoration: none;
            cursor: pointer;
        }

        .btn:hover { transform: translateY(-1px); }

        .articles-action-bar {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            margin: 0 0 20px 0;
        }

        .new-article-button {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: 1px solid #4f93e8;
            border-radius: 999px;
            padding: 12px 18px 12px 13px;
            background: linear-gradient(135deg, #1677ff, #0d4fa8);
            color: white;
            font: inherit;
            font-weight: 900;
            cursor: pointer;
            box-shadow: 0 16px 34px rgba(22, 119, 255, 0.28);
        }

        .new-article-button:hover {
            transform: translateY(-1px);
            box-shadow: 0 20px 42px rgba(22, 119, 255, 0.36);
        }

        .new-article-button-mark {
            width: 26px;
            height: 26px;
            border-radius: 999px;
            display: grid;
            place-items: center;
            background: rgba(255, 255, 255, 0.18);
            border: 1px solid rgba(255, 255, 255, 0.28);
            font-size: 20px;
            line-height: 1;
        }

        .document-types-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 16px;
        }

        .document-type-card {
            display: grid;
            grid-template-columns: 54px 1fr auto;
            gap: 16px;
            align-items: start;
            border: 1px solid #24405f;
            border-radius: 18px;
            background: rgba(4, 17, 29, 0.9);
            padding: 18px;
            box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
        }

        .document-type-icon {
            width: 46px;
            height: 46px;
            border-radius: 12px;
            display: grid;
            place-items: center;
            border: 1px solid #35527a;
            background: linear-gradient(180deg, rgba(132, 187, 255, 0.22), rgba(22, 119, 255, 0.10));
            color: #d7eaff;
            font-weight: 900;
            font-size: 17px;
        }

        .document-type-body h2 {
            margin: 3px 0 6px 0;
            font-size: 20px;
        }

        .document-type-body p {
            margin: 0;
            color: #aac2de;
        }

        .document-type-kind {
            color: #84bbff;
            font-size: 12px;
            font-weight: 900;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .document-type-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 14px;
        }

        .document-type-meta span {
            border-radius: 999px;
            padding: 6px 9px;
            background: #163b62;
            color: #a7d0ff;
            font-size: 12px;
            font-weight: 800;
        }

        .btn-secondary { background: #2d4463; }
        .btn-danger { background: #d0384d; }
        .btn-icon { min-width: 42px; padding: 10px 13px; border-radius: 999px; font-size: 18px; line-height: 1; }

        .delete-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            border: 1px solid rgba(255, 116, 139, 0.5);
            border-radius: 999px;
            padding: 9px 12px;
            background: rgba(208, 56, 77, 0.12);
            color: #ffb4c0;
            font: inherit;
            font-size: 13px;
            font-weight: 900;
            cursor: pointer;
            transition: transform 0.15s ease, background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
        }

        .delete-button:hover {
            transform: translateY(-1px);
            border-color: rgba(255, 148, 164, 0.78);
            background: rgba(208, 56, 77, 0.22);
            color: #ffd6dc;
        }

        .delete-button-icon {
            width: 18px;
            height: 18px;
            display: inline-grid;
            place-items: center;
            line-height: 1;
        }

        .article-actions .delete-button {
            width: 42px;
            height: 42px;
            padding: 0;
        }


        .reorder-workspace {
            display: grid;
            gap: 18px;
        }

        .reorder-controls {
            display: grid;
            grid-template-columns: repeat(2, minmax(240px, 1fr)) auto;
            gap: 16px;
            align-items: end;
            border: 1px solid #24405f;
            border-radius: 18px;
            background: rgba(4, 17, 29, 0.88);
            padding: 18px;
            box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
        }

        .reorder-select-group { min-width: 0; }

        .reorder-select {
            width: 100%;
            border-radius: 12px;
            border: 1px solid #35527a;
            background: #020b18;
            color: white;
            padding: 13px 15px;
            font-size: 15px;
            font-weight: 800;
        }

        .reorder-summary {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            border: 1px solid rgba(132, 187, 255, 0.26);
            border-radius: 18px;
            background: linear-gradient(135deg, rgba(22, 119, 255, 0.12), rgba(4, 17, 29, 0.88));
            padding: 16px 18px;
        }

        .reorder-summary strong {
            display: block;
            margin-bottom: 4px;
            font-size: 18px;
        }

        .reorder-summary span {
            color: #aac2de;
            line-height: 1.5;
        }

        .reorder-list {
            display: grid;
            gap: 8px;
        }

        .reorder-row {
            display: grid;
            grid-template-columns: 30px auto 1fr auto;
            gap: 10px;
            align-items: center;
            border: 1px solid #35527a;
            border-radius: 8px;
            background: #020b18;
            padding: 10px;
            transition: border-color 160ms ease, background 160ms ease, box-shadow 160ms ease, opacity 160ms ease, transform 160ms ease;
        }

        .reorder-row[draggable="true"] {
            cursor: grab;
        }

        .reorder-row[draggable="true"]:active {
            cursor: grabbing;
        }

        .reorder-row:hover {
            border-color: #84bbff;
            background: #04152b;
            box-shadow: 0 8px 22px rgba(0, 0, 0, 0.24);
        }

        .reorder-row.dragging {
            opacity: 0.45;
            transform: scale(0.985);
            border-color: #84bbff;
            box-shadow: 0 0 0 2px rgba(132, 187, 255, 0.20);
        }

        .reorder-row.drag-over-before {
            box-shadow: 0 -3px 0 #35d07f, 0 8px 22px rgba(0, 0, 0, 0.24);
        }

        .reorder-row.drag-over-after {
            box-shadow: 0 3px 0 #35d07f, 0 8px 22px rgba(0, 0, 0, 0.24);
        }

        .reorder-row.just-moved {
            animation: reorderMovedPulse 720ms ease-out;
        }

        @@keyframes reorderMovedPulse {
            0% {
                border-color: #35d07f;
                box-shadow: 0 0 0 0 rgba(53, 208, 127, 0.45);
            }

            50% {
                border-color: #35d07f;
                box-shadow: 0 0 0 5px rgba(53, 208, 127, 0.18);
            }

            100% {
                border-color: #35527a;
                box-shadow: none;
            }
        }

        .reorder-drag-handle {
            width: 28px;
            height: 30px;
            display: grid;
            place-items: center;
            border: 1px solid rgba(132, 187, 255, 0.22);
            border-radius: 8px;
            background: rgba(132, 187, 255, 0.08);
            color: #9ecbff;
            cursor: grab;
            font-size: 18px;
            line-height: 1;
            user-select: none;
        }

        .reorder-drag-handle:hover {
            background: rgba(132, 187, 255, 0.18);
            color: #ffffff;
        }

        .reorder-drag-handle:active { cursor: grabbing; }

        .reorder-order-badge {
            min-width: 44px;
            height: 34px;
            border-radius: 999px;
            display: inline-grid;
            place-items: center;
            border: 1px solid rgba(132, 187, 255, 0.44);
            background: linear-gradient(180deg, rgba(132, 187, 255, 0.20), rgba(22, 119, 255, 0.08));
            color: #d7eaff;
            font-size: 13px;
            font-weight: 900;
        }

        .reorder-title { font-weight: 900; margin-bottom: 4px; }
        .reorder-meta { color: #aac2de; font-size: 13px; line-height: 1.45; }

        .reorder-actions {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-end;
            gap: 8px;
        }

        .reorder-action-button {
            min-width: 38px;
            height: 34px;
            border: 1px solid #35527a;
            border-radius: 999px;
            background: #0d253f;
            color: #d7eaff;
            font: inherit;
            font-size: 13px;
            font-weight: 900;
            cursor: pointer;
        }

        .reorder-action-button:hover:not(:disabled) {
            border-color: #84bbff;
            background: #163b62;
            transform: translateY(-1px);
        }

        .reorder-action-button:disabled {
            opacity: 0.38;
            cursor: not-allowed;
        }

        .reorder-manage-button {
            min-width: 40px;
            height: 34px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            border: 1px solid rgba(132, 187, 255, 0.34);
            border-radius: 999px;
            background: linear-gradient(180deg, rgba(132, 187, 255, 0.18), rgba(22, 119, 255, 0.08));
            color: #d7eaff;
            font: inherit;
            font-size: 13px;
            font-weight: 900;
            cursor: pointer;
            transition: transform 0.15s ease, border-color 0.15s ease, background 0.15s ease, color 0.15s ease, box-shadow 0.15s ease;
        }

        .reorder-manage-button:hover:not(:disabled) {
            transform: translateY(-1px);
            border-color: #84bbff;
            background: linear-gradient(180deg, rgba(132, 187, 255, 0.26), rgba(22, 119, 255, 0.16));
            color: #ffffff;
            box-shadow: 0 10px 24px rgba(22, 119, 255, 0.18);
        }

        .reorder-manage-button.edit {
            min-width: 74px;
        }

        .reorder-manage-button.remove {
            border-color: rgba(255, 116, 139, 0.44);
            background: linear-gradient(180deg, rgba(255, 116, 139, 0.16), rgba(208, 56, 77, 0.08));
            color: #ffd6dc;
        }

        .reorder-manage-button.remove:hover:not(:disabled) {
            border-color: rgba(255, 148, 164, 0.82);
            background: linear-gradient(180deg, rgba(255, 116, 139, 0.24), rgba(208, 56, 77, 0.18));
            color: #fff1f4;
            box-shadow: 0 10px 24px rgba(208, 56, 77, 0.20);
        }

        .reorder-manage-icon {
            display: inline-grid;
            place-items: center;
            width: 16px;
            height: 16px;
            line-height: 1;
        }

        @@media (max-width: 900px) {
            .reorder-controls { grid-template-columns: 1fr; }
            .reorder-row { grid-template-columns: auto auto 1fr; }
            .reorder-actions { grid-column: 1 / -1; justify-content: flex-start; }
        }

        .toast {
            position: fixed;
            right: 24px;
            bottom: 24px;
            max-width: 420px;
            display: none;
            border: 1px solid #35527a;
            border-radius: 16px;
            padding: 14px 16px;
            background: #0d1d35;
            color: #f5f7fb;
            box-shadow: 0 22px 60px rgba(0, 0, 0, 0.42);
            z-index: 10000;
            font-weight: 800;
            line-height: 1.45;
        }

        .toast.success { border-color: rgba(31, 157, 85, 0.75); }
        .toast.error { border-color: rgba(208, 56, 77, 0.85); color: #ffd6dc; }

        .empty {
            padding: 22px;
            border: 1px dashed #35527a;
            border-radius: 16px;
            color: #aac2de;
            background: rgba(4, 17, 29, 0.65);
        }

        .hidden { display: none !important; }

        .editor-command-bar {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 12px;
            margin-bottom: 14px;
            padding: 14px 16px;
            border: 1px solid #24405f;
            border-radius: 16px;
            background: rgba(9, 28, 52, 0.94);
            box-shadow: 0 18px 36px rgba(0, 0, 0, 0.22);
        }

        .editor-command-context {
            margin-right: auto;
            color: #aac2de;
            font-size: 14px;
            line-height: 1.45;
        }

        .editor-command-context strong {
            display: block;
            color: #f5f7fb;
            font-size: 15px;
            margin-bottom: 2px;
        }

        .editor-command-bar .btn {
            min-width: 112px;
            padding: 12px 18px;
            border-radius: 12px;
        }

        .editor-action-button {
            min-width: 124px;
            min-height: 44px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 9px;
            border-radius: 999px;
            border: 1px solid rgba(132, 187, 255, 0.28);
            padding: 12px 18px;
            color: #f5f7fb;
            font: inherit;
            font-weight: 900;
            letter-spacing: 0.01em;
            cursor: pointer;
            transition:
                transform 0.16s ease,
                box-shadow 0.16s ease,
                border-color 0.16s ease,
                background 0.16s ease,
                color 0.16s ease;
        }

        .editor-action-button:hover:not(:disabled) {
            transform: translateY(-1px);
        }

        .editor-action-button:focus-visible {
            outline: 3px solid rgba(132, 187, 255, 0.45);
            outline-offset: 3px;
        }

        .editor-action-button-icon {
            width: 22px;
            height: 22px;
            display: inline-grid;
            place-items: center;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.14);
            border: 1px solid rgba(255, 255, 255, 0.18);
            font-size: 14px;
            line-height: 1;
        }

        .editor-action-button-primary {
            border-color: rgba(132, 187, 255, 0.48);
            background:
                radial-gradient(circle at top left, rgba(132, 187, 255, 0.30), transparent 55%),
                linear-gradient(135deg, #1677ff, #1358c8 58%, #0d3f91);
            box-shadow:
                0 16px 34px rgba(22, 119, 255, 0.28),
                inset 0 1px 0 rgba(255, 255, 255, 0.16);
        }

        .editor-action-button-primary:hover:not(:disabled) {
            border-color: rgba(184, 218, 255, 0.78);
            box-shadow:
                0 20px 44px rgba(22, 119, 255, 0.38),
                0 0 0 1px rgba(132, 187, 255, 0.12),
                inset 0 1px 0 rgba(255, 255, 255, 0.22);
        }

        .editor-action-button-close {
            border-color: rgba(255, 116, 139, 0.46);
            background:
                radial-gradient(circle at top left, rgba(255, 116, 139, 0.20), transparent 58%),
                linear-gradient(135deg, rgba(208, 56, 77, 0.24), rgba(84, 22, 38, 0.86));
            color: #ffd6dc;
            box-shadow:
                0 14px 30px rgba(208, 56, 77, 0.16),
                inset 0 1px 0 rgba(255, 255, 255, 0.10);
        }

        .editor-action-button-close:hover:not(:disabled) {
            border-color: rgba(255, 148, 164, 0.82);
            background:
                radial-gradient(circle at top left, rgba(255, 148, 164, 0.26), transparent 58%),
                linear-gradient(135deg, rgba(208, 56, 77, 0.34), rgba(105, 29, 48, 0.92));
            color: #fff1f4;
            box-shadow:
                0 18px 38px rgba(208, 56, 77, 0.24),
                0 0 0 1px rgba(255, 116, 139, 0.12),
                inset 0 1px 0 rgba(255, 255, 255, 0.14);
        }

        .btn-success {
            background: linear-gradient(135deg, #1f9d55, #157347);
        }

        .btn:disabled,
        .btn.disabled,
        .editor-action-button:disabled {
            cursor: not-allowed;
            opacity: 0.48;
            transform: none;
            box-shadow: none;
        }

        .modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.68);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            padding: 24px;
        }

        .modal {
            width: min(520px, 100%);
            border-radius: 20px;
            border: 1px solid #48678f;
            background: #0d1d35;
            padding: 24px;
            box-shadow: 0 24px 80px rgba(0, 0, 0, 0.5);
        }

        .field-label {
            display: block;
            margin: 16px 0 8px 0;
            color: #aac2de;
            font-size: 13px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .modal h2 { margin: 0 0 12px 0; }
        .modal p { margin: 0; color: #c8d8ef; line-height: 1.6; }
        .modal-buttons { display: flex; justify-content: flex-end; gap: 12px; margin-top: 24px; }

        .database-hero {
            border: 1px solid #24405f;
            border-radius: 22px;
            background:
                radial-gradient(circle at top left, rgba(42, 126, 255, 0.22), transparent 34%),
                linear-gradient(135deg, rgba(20, 48, 82, 0.9), rgba(4, 17, 29, 0.96));
            padding: 26px;
            margin-bottom: 22px;
            box-shadow: 0 18px 45px rgba(0, 0, 0, 0.28);
        }

        .database-kicker,
        .database-export-kicker {
            color: #84bbff;
            text-transform: uppercase;
            font-size: 12px;
            font-weight: 900;
            letter-spacing: 0.14em;
            margin-bottom: 8px;
        }

        .database-hero h2 {
            margin: 0 0 10px 0;
            font-size: 32px;
        }

        .database-hero p {
            margin: 0;
            color: #aac2de;
            line-height: 1.6;
        }

        .database-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
            gap: 18px;
            margin-bottom: 22px;
        }

        .database-card,
        .database-export-card {
            border: 1px solid #24405f;
            border-radius: 20px;
            background:
                linear-gradient(135deg, rgba(20, 48, 82, 0.88), rgba(4, 17, 29, 0.96));
            padding: 24px;
            box-shadow: 0 18px 45px rgba(0, 0, 0, 0.28);
        }

        .database-card {
            position: relative;
            overflow: hidden;
        }

        .database-card::after {
            content: "";
            position: absolute;
            inset: auto -40px -50px auto;
            width: 120px;
            height: 120px;
            background: rgba(42, 126, 255, 0.16);
            border-radius: 999px;
        }

        .database-card-icon {
            width: 44px;
            height: 44px;
            border-radius: 16px;
            display: grid;
            place-items: center;
            background: rgba(42, 126, 255, 0.18);
            border: 1px solid rgba(132, 187, 255, 0.34);
            margin-bottom: 18px;
            font-size: 22px;
        }

        .database-number {
            font-size: 46px;
            line-height: 1;
            font-weight: 900;
            color: #84bbff;
            margin-bottom: 10px;
        }

        .database-label {
            color: #c8d8ef;
            font-weight: 800;
        }

        .database-export-card {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 24px;
        }

        .database-export-card h3 {
            margin: 0 0 10px 0;
            font-size: 24px;
        }

        .database-export-card p {
            margin: 0;
            color: #aac2de;
            line-height: 1.6;
        }

        .database-export-button {
            border: 1px solid #5fa8ff;
            border-radius: 999px;
            padding: 14px 20px;
            background: linear-gradient(135deg, #2a7eff, #1761d6);
            color: white;
            font-weight: 900;
            cursor: pointer;
            display: inline-flex;
            gap: 10px;
            align-items: center;
            white-space: nowrap;
            box-shadow: 0 14px 32px rgba(42, 126, 255, 0.32);
        }

        .database-export-button:hover {
            transform: translateY(-1px);
            box-shadow: 0 18px 38px rgba(42, 126, 255, 0.42);
        }

        .database-export-button-icon {
            width: 24px;
            height: 24px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.18);
            display: inline-grid;
            place-items: center;
        }

    </style>
</head>

<body>
    <div class="admin-shell">
        <header class="top-bar">
            <div class="brand">
                <div class="brand-mark">B</div>
                <div>Blog admin</div>
            </div>

            <nav class="top-nav">
                <button id="zonesTab" class="active" type="button" onclick="showPanel('zones')">Zones &amp; Steps</button>
                <button id="articlesTab" type="button" onclick="showPanel('articles')">Articles</button>
                <button id="reorderArticlesTab" type="button" onclick="showPanel('reorderArticles')">Reorder articles</button>
                <button id="documentTypesTab" type="button" onclick="showPanel('documentTypes')">Document Types</button>
                <button id="databaseTab" type="button" onclick="showPanel('database')">Database</button>
            </nav>
        </header>

        <main id="mainContent" class="content">
            <section id="heroSection" class="hero">
                <h1>Blog content workspace</h1>
                <p>
                    Browse Dotnet Zones, Zone Steps and articles in a clean Blog Platform admin view.
                    Use Open editor from the Articles tab when you want to edit an existing article with live preview.
                </p>
            </section>

            <section id="toolbarSection" class="toolbar">
                <input id="searchInput" class="search" type="search" placeholder="Search zones, steps, articles or document types..." />
                <div id="statusText" class="status">Loading CMS content...</div>
            </section>

            <section id="zonesPanel" class="panel active">
                <div class="articles-action-bar">
                    <button class="new-article-button" type="button" onclick="openCreateZoneModal()">
                        <span class="new-article-button-mark">+</span>
                        <span>Create zone</span>
                    </button>
                </div>

                <div id="zonesGrid" class="zones-grid"></div>
            </section>


            <section id="reorderArticlesPanel" class="panel">
                <div class="reorder-workspace">
                    <div class="reorder-controls">
                        <div class="reorder-select-group">
                            <label class="field-label" for="reorderZoneSelect">Zone</label>
                            <select id="reorderZoneSelect" class="reorder-select" onchange="onReorderZoneChanged()"></select>
                        </div>

                        <div class="reorder-select-group">
                            <label class="field-label" for="reorderStepSelect">Step</label>
                            <select id="reorderStepSelect" class="reorder-select" onchange="onReorderStepChanged()"></select>
                        </div>

                        <button id="reloadReorderButton" class="new-article-button" type="button" onclick="loadReorderArticles()">
                            <span class="new-article-button-mark">↻</span>
                            <span>Refresh list</span>
                        </button>
                    </div>

                    <div id="reorderSummary" class="reorder-summary"></div>
                    <div id="reorderArticlesList" class="reorder-list"></div>
                </div>
            </section>

            <section id="documentTypesPanel" class="panel">
                <div id="documentTypesGrid" class="document-types-grid"></div>
            </section>

            <section id="databasePanel" class="panel">
                <div class="database-hero">
                    <div>
                        <div class="database-kicker">SQL database snapshot</div>
                        <h2>Database</h2>
                        <p>
                            Check current content stored in the database and export it into a reusable
                            <strong>blog-content.seed.json</strong> file.
                        </p>
                    </div>
                </div>

                <div class="database-grid">
                    <article class="database-card">
                        <div class="database-card-icon">🗺️</div>
                        <div class="database-number" id="databaseZonesCount">0</div>
                        <div class="database-label">Zones in database</div>
                    </article>

                    <article class="database-card">
                        <div class="database-card-icon">🧭</div>
                        <div class="database-number" id="databaseZoneStepsCount">0</div>
                        <div class="database-label">Zone steps in database</div>
                    </article>

                    <article class="database-card">
                        <div class="database-card-icon">📚</div>
                        <div class="database-number" id="databaseArticlesCount">0</div>
                        <div class="database-label">Articles in database</div>
                    </article>
                </div>

                <div class="database-export-card">
                    <div>
                        <div class="database-export-kicker">Export seed file</div>
                        <h3>Save current database content</h3>
                        <p>
                            Download zones, zone steps and articles from the current SQL database.
                            The file will use the same structure as your seed JSON.
                        </p>
                    </div>

                    <button class="database-export-button" type="button" onclick="exportSeedContent()">
                        <span class="database-export-button-icon">⬇</span>
                        <span>Save blog-content.seed.json</span>
                    </button>
                </div>
            </section>

            <section id="articlesPanel" class="panel">
                <div id="articlesListView">
                    <div id="articlesActionBar" class="articles-action-bar">
                        <button class="new-article-button" type="button" onclick="openNewArticleEditorInArticlesTab()">
                            <span class="new-article-button-mark">+</span>
                            <span>Create new article</span>
                        </button>
                    </div>

                    <div id="articlesGrouped"></div>
                </div>

                <div id="articlesEditorView" class="hidden">
                    <div id="editorCommandBar" class="editor-command-bar">
                        <div id="editorCommandContext" class="editor-command-context">
                            <strong>Article editor</strong>
                            Fill the article fields, preview the result, then publish or update when ready.
                        </div>

                        <button id="editorSaveButton" class="editor-action-button editor-action-button-primary" type="button" onclick="publishOrUpdateInlineArticleEditor()" disabled>
                            <span class="editor-action-button-icon" aria-hidden="true">✓</span>
                            <span>Publish</span>
                        </button>

                        <button class="editor-action-button editor-action-button-close" type="button" onclick="requestCloseInlineArticleEditor()">
                            <span class="editor-action-button-icon" aria-hidden="true">×</span>
                            <span>Close</span>
                        </button>
                    </div>

                    <div class="editor-frame-shell">
                        <iframe id="inlineArticleEditorFrame" class="editor-frame" title="Article Editor in Articles tab"></iframe>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <div id="deleteContentModal" class="modal-backdrop">
        <div class="modal">
            <h2 id="deleteContentModalTitle">Delete item?</h2>
            <p id="deleteContentModalMessage">This action cannot be undone.</p>

            <div class="modal-buttons">
                <button class="btn btn-secondary" type="button" onclick="closeDeleteContentModal()">Cancel</button>
                <button id="confirmDeleteContentButton" class="btn btn-danger" type="button" onclick="confirmDeleteContent()">Delete</button>
            </div>
        </div>
    </div>

    <div id="roadmapModal" class="modal-backdrop">
        <div class="modal">
            <h2 id="roadmapModalTitle">Create item</h2>

            <label class="field-label" for="roadmapNameInput">Name</label>
            <input id="roadmapNameInput" class="search" type="text" />

            <label class="field-label" for="roadmapKeyInput">Key</label>
            <input id="roadmapKeyInput" class="search" type="text" />

            <p id="roadmapKeyHint" style="margin-top:12px;">
                Key is used by articles. Keep it stable after creation.
            </p>

<div class="modal-buttons">
                <button class="btn btn-secondary" type="button" onclick="closeRoadmapModal()">Cancel</button>
                <button id="saveRoadmapButton" class="btn btn-success" type="button" onclick="saveRoadmapItem()">Save</button>
            </div>
        </div>
    </div>

    <div id="toast" class="toast"></div>

    <div id="closeInlineEditorModal" class="modal-backdrop">
        <div class="modal">
            <h2>Close article editor?</h2>
            <p>
                This article has unsaved local changes. Closing the editor will discard those changes and return you to the Articles list.
            </p>

            <div class="modal-buttons">
                <button class="btn btn-secondary" type="button" onclick="closeInlineEditorModal()">Keep editing</button>
                <button class="btn btn-danger" type="button" onclick="closeInlineArticleEditor()">Discard changes</button>
            </div>
        </div>
    </div>

    <script>
        let dotnetRoadmap = [];
        let articles = [];
        let documentTypes = [];
        let databaseSummary = null;
        let activePanel = "zones";
        let reorderArticles = [];
        let selectedReorderZoneKey = null;
        let selectedReorderStepKey = null;
        let draggedReorderArticleKey = null;
        let lastMovedReorderArticleKey = null;
        let reorderSaveInProgress = false;
        let inlineEditorIsDirty = false;
        let inlineEditorArticleKey = null;
        let inlineEditorMode = "existing";
        let inlineEditorIsValid = false;
        let inlineEditorTitle = "Article editor";
        let inlineEditorReturnPanel = "articles";
        let pendingDelete = null;
        let roadmapModalState = null;
        let toastTimeout = null;

        document.addEventListener("DOMContentLoaded", async () => {
            document.getElementById("searchInput").addEventListener("input", renderActivePanel);
            window.addEventListener("message", onEditorMessage);

            await loadContent();
        });

        async function loadContent() {
            const [
                roadmapResponse,
                articlesResponse,
                documentTypesResponse,
                databaseSummaryResponse
            ] = await Promise.all([
                fetch("/api/blog-content/dotnet-roadmap"),
                fetch("/api/blog-content/articles"),
                fetch("/api/blog-content/document-types"),
                fetch("/api/blog-content/database-summary")
            ]);

            dotnetRoadmap = await roadmapResponse.json();
            articles = await articlesResponse.json();
            documentTypes = await documentTypesResponse.json();
            databaseSummary = await databaseSummaryResponse.json();

            initializeReorderSelectors();
            renderActivePanel();

            document.getElementById("statusText").innerText =
                `${dotnetRoadmap.length} zones, ${getTotalStepCount()} steps, ${articles.length} articles, ${documentTypes.length} document types`;
        }

        function showPanel(panel) {
            activePanel = panel;

            document.getElementById("zonesTab").classList.toggle("active", panel === "zones");
            document.getElementById("articlesTab").classList.toggle("active", panel === "articles");
            document.getElementById("reorderArticlesTab").classList.toggle("active", panel === "reorderArticles");
            document.getElementById("documentTypesTab").classList.toggle("active", panel === "documentTypes");
            document.getElementById("databaseTab").classList.toggle("active", panel === "database");

            document.getElementById("zonesPanel").classList.toggle("active", panel === "zones");
            document.getElementById("articlesPanel").classList.toggle("active", panel === "articles");
            document.getElementById("reorderArticlesPanel").classList.toggle("active", panel === "reorderArticles");
            document.getElementById("documentTypesPanel").classList.toggle("active", panel === "documentTypes");
            document.getElementById("databasePanel").classList.toggle("active", panel === "database");

            const articlesEditorIsOpen = panel === "articles" && !document.getElementById("articlesEditorView").classList.contains("hidden");

            document.getElementById("toolbarSection").classList.toggle("hidden", articlesEditorIsOpen);
            document.getElementById("heroSection").style.display = articlesEditorIsOpen ? "none" : "block";
            document.getElementById("mainContent").classList.toggle("editor-active", articlesEditorIsOpen);
            document.getElementById("articlesPanel").classList.toggle("article-editor-panel-active", articlesEditorIsOpen);

            renderActivePanel();
        }

        function renderActivePanel() {
            if (activePanel === "zones") {
                renderZones();
                return;
            }

            if (activePanel === "articles" && document.getElementById("articlesEditorView").classList.contains("hidden")) {
                renderArticles();
                return;
            }

            if (activePanel === "reorderArticles") {
                if (reorderArticles.length === 0) {
                    loadReorderArticles();
                }

                renderReorderArticles();
                return;
            }

            if (activePanel === "documentTypes") {
                renderDocumentTypes();
                return;
            }

            if (activePanel === "database") {
                renderDatabase();
            }
        }

        function renderDatabase() {
            const summary = databaseSummary ?? {
                zones: dotnetRoadmap.length,
                zoneSteps: getTotalStepCount(),
                articles: articles.length
            };

            document.getElementById("databaseZonesCount").innerText = summary.zones;
            document.getElementById("databaseZoneStepsCount").innerText = summary.zoneSteps;
            document.getElementById("databaseArticlesCount").innerText = summary.articles;
        }

        function exportSeedContent() {
            window.location.href = "/api/blog-content/seed-export";
        }

        function renderZones() {
            const search = getSearchText();
            const filteredZones = dotnetRoadmap
                .map(zone => ({
                    ...zone,
                    steps: zone.steps.filter(step =>
                        zone.name.toLowerCase().includes(search) ||
                        zone.key.toLowerCase().includes(search) ||
                        step.name.toLowerCase().includes(search) ||
                        step.key.toLowerCase().includes(search))
                }))
                .filter(zone =>
                    zone.name.toLowerCase().includes(search) ||
                    zone.key.toLowerCase().includes(search) ||
                    zone.steps.length > 0)
                .sort((a, b) => a.order - b.order);

            const grid = document.getElementById("zonesGrid");

            if (filteredZones.length === 0) {
                grid.innerHTML = `<div class="empty">No zones or steps found.</div>`;
                return;
            }

            grid.innerHTML = filteredZones.map(renderZoneCard).join("");
        }

        function renderZoneCard(zone) {
            const zoneCountText = zone.articleCount === 1
                ? "1 article"
                : `${zone.articleCount} articles`;

            return `
                <article class="zone-card">
                    <div class="zone-card-header">
                        <div class="zone-order-mark">${zone.order}</div>

                        <div>
                            <h2>${escapeHtml(zone.name)}</h2>
                            <div class="zone-key">${escapeHtml(zone.key)}</div>
                        </div>

                        <div class="zone-admin-actions">
                            <span class="zone-badge zone-count">${zoneCountText}</span>
                            <button class="btn btn-secondary btn-icon" type="button" title="Add step" onclick="openCreateStepModal('${escapeJs(zone.key)}')">+</button>
                            <button class="btn btn-secondary btn-icon" type="button" title="Edit zone" onclick="openEditZoneModal('${escapeJs(zone.key)}')">✎</button>
                            ${renderDeleteButton("Delete", `requestDelete('zone', '${escapeJs(zone.key)}')`, "Delete zone")}
                        </div>
                    </div>

                    <div class="zone-steps">
                        ${zone.steps.map(step => renderZoneStepRow(zone, step)).join("")}
                    </div>
                </article>
            `;
        }

        function renderZoneStepRow(zone, step) {
            const stepCountText = step.articleCount === 1
                ? "1 article"
                : `${step.articleCount} articles`;

            return `
                <div class="zone-step-row">
                    <div class="step-order-mark">${step.order}</div>

                    <div>
                        <div class="step-name">${escapeHtml(step.name)}</div>
                        <div class="step-key">${escapeHtml(step.key)}</div>
                    </div>

                    <span class="step-badge">${stepCountText}</span>

                    <div class="step-admin-actions">
                        <button class="btn btn-secondary btn-icon" type="button" title="Edit step" onclick="openEditStepModal('${escapeJs(zone.key)}', '${escapeJs(step.key)}')">✎</button>
                        ${renderDeleteButton("Delete", `requestDelete('step', '${escapeJs(zone.key)}|${escapeJs(step.key)}')`, "Delete step")}
                    </div>
                </div>
            `;
        }
function initializeReorderSelectors() {
            const zoneSelect = document.getElementById("reorderZoneSelect");

            if (!zoneSelect) {
                return;
            }

            const orderedZones = [...dotnetRoadmap].sort((a, b) => a.order - b.order || a.name.localeCompare(b.name));

            if (!selectedReorderZoneKey || !orderedZones.some(zone => zone.key === selectedReorderZoneKey)) {
                selectedReorderZoneKey = orderedZones[0]?.key ?? null;
            }

            zoneSelect.innerHTML = orderedZones
                .map(zone => `<option value="${escapeHtml(zone.key)}" ${zone.key === selectedReorderZoneKey ? "selected" : ""}>${escapeHtml(zone.order)}. ${escapeHtml(zone.name)}</option>`)
                .join("");

            initializeReorderStepSelector();
        }

        function initializeReorderStepSelector() {
            const stepSelect = document.getElementById("reorderStepSelect");
            const zone = dotnetRoadmap.find(item => item.key === selectedReorderZoneKey);
            const orderedSteps = [...(zone?.steps ?? [])].sort((a, b) => a.order - b.order || a.name.localeCompare(b.name));

            if (!selectedReorderStepKey || !orderedSteps.some(step => step.key === selectedReorderStepKey)) {
                selectedReorderStepKey = orderedSteps[0]?.key ?? null;
            }

            stepSelect.innerHTML = orderedSteps
                .map(step => `<option value="${escapeHtml(step.key)}" ${step.key === selectedReorderStepKey ? "selected" : ""}>${escapeHtml(step.order)}. ${escapeHtml(step.name)}</option>`)
                .join("");
        }

        async function onReorderZoneChanged() {
            selectedReorderZoneKey = document.getElementById("reorderZoneSelect").value;
            selectedReorderStepKey = null;
            reorderArticles = [];
            initializeReorderStepSelector();
            await loadReorderArticles();
        }

        async function onReorderStepChanged() {
            selectedReorderStepKey = document.getElementById("reorderStepSelect").value;
            reorderArticles = [];
            await loadReorderArticles();
        }

        async function loadReorderArticles() {
            if (!selectedReorderZoneKey || !selectedReorderStepKey) {
                renderReorderArticles();
                return;
            }

            const button = document.getElementById("reloadReorderButton");
            button.disabled = true;

            try {
                const response = await fetch(`/api/blog-content/articles/reorder?zone=${encodeURIComponent(selectedReorderZoneKey)}&step=${encodeURIComponent(selectedReorderStepKey)}`);
                reorderArticles = await response.json();
                renderReorderArticles();
            }
            catch (error) {
                console.error(error);
                showToast("Unable to load articles for reorder.", "error");
            }
            finally {
                button.disabled = false;
            }
        }

        function renderReorderArticles() {
            initializeReorderSelectors();

            const zone = dotnetRoadmap.find(item => item.key === selectedReorderZoneKey);
            const step = zone?.steps.find(item => item.key === selectedReorderStepKey);
            const summary = document.getElementById("reorderSummary");
            const list = document.getElementById("reorderArticlesList");

            if (!zone || !step) {
                summary.innerHTML = `<div><strong>Select zone and step</strong><span>Create at least one zone and step before reordering articles.</span></div>`;
                list.innerHTML = `<div class="empty">No zone and step selected.</div>`;
                return;
            }

            summary.innerHTML = `
                <div>
                    <strong>${escapeHtml(zone.name)} / ${escapeHtml(step.name)}</strong>
                    <span>Drag articles, use arrows, edit content, or remove drafts directly from this list. Order is saved automatically after every move.</span>
                </div>
                <span>${reorderArticles.length} article${reorderArticles.length === 1 ? "" : "s"}</span>
            `;

            if (reorderArticles.length === 0) {
                list.innerHTML = `<div class="empty">No articles in this zone and step yet.</div>`;
                return;
            }

            list.innerHTML = reorderArticles.map((article, index) => renderReorderArticleRow(article, index)).join("");
        }

        function renderReorderArticleRow(article, index) {
            const isFirst = index === 0;
            const isLast = index === reorderArticles.length - 1;
            const displayOrder = index + 1;

            return `
                <article class="reorder-row${article.key === lastMovedReorderArticleKey ? " just-moved" : ""}" draggable="true" data-article-key="${escapeHtml(article.key)}" ondragstart="onReorderDragStart(event, '${escapeJs(article.key)}')" ondragover="onReorderDragOver(event, '${escapeJs(article.key)}')" ondragleave="clearReorderDropCue(event.currentTarget)" ondrop="onReorderDrop(event, '${escapeJs(article.key)}')" ondragend="onReorderDragEnd()">
                    <div class="reorder-drag-handle" title="Drag to reorder" aria-label="Drag to reorder">⋮⋮</div>
                    <div class="reorder-order-badge" title="Current saved order: ${escapeHtml(article.order)}">#${displayOrder}</div>

                    <div class="article-main">
                        <div class="reorder-title">${escapeHtml(article.title)}</div>
                        <div class="reorder-meta">
                            ${escapeHtml(article.slug)} · ${escapeHtml(article.level)} · saved Order: ${escapeHtml(article.order)}
                        </div>
                    </div>

                    <div class="reorder-actions">
                        <button class="reorder-manage-button edit" type="button" title="Edit article" onclick="openArticleEditorFromReorder('${escapeJs(article.key)}')">
                            <span class="reorder-manage-icon" aria-hidden="true">✎</span>
                            <span>Edit</span>
                        </button>
                        <button class="reorder-manage-button remove" type="button" title="Remove article" onclick="requestDelete('article', '${escapeJs(article.key)}')">
                            <span class="reorder-manage-icon" aria-hidden="true">🗑</span>
                            <span>Remove</span>
                        </button>
                        <button class="reorder-action-button" type="button" title="Move to top" onclick="moveReorderArticle('${escapeJs(article.key)}', 'top')" ${isFirst ? "disabled" : ""}>Top</button>
                        <button class="reorder-action-button" type="button" title="Move one level up" onclick="moveReorderArticle('${escapeJs(article.key)}', 'up')" ${isFirst ? "disabled" : ""}>↑</button>
                        <button class="reorder-action-button" type="button" title="Move one level down" onclick="moveReorderArticle('${escapeJs(article.key)}', 'down')" ${isLast ? "disabled" : ""}>↓</button>
                        <button class="reorder-action-button" type="button" title="Move to bottom" onclick="moveReorderArticle('${escapeJs(article.key)}', 'bottom')" ${isLast ? "disabled" : ""}>Bottom</button>
                    </div>
                </article>
            `;
        }

        function onReorderDragStart(event, articleKey) {
            if (event.target.closest(".reorder-actions")) {
                event.preventDefault();
                return;
            }

            draggedReorderArticleKey = articleKey;
            event.dataTransfer.effectAllowed = "move";
            event.dataTransfer.setData("text/plain", articleKey);

            const row = event.currentTarget;

            requestAnimationFrame(() => {
                row.classList.add("dragging");
            });
        }

        function onReorderDragOver(event, targetArticleKey) {
            if (!draggedReorderArticleKey || draggedReorderArticleKey === targetArticleKey) {
                return;
            }

            event.preventDefault();
            event.dataTransfer.dropEffect = "move";

            const row = event.currentTarget;
            const isAfter = shouldReorderDropAfter(event, row);

            clearAllReorderDropCues();
            row.classList.toggle("drag-over-before", !isAfter);
            row.classList.toggle("drag-over-after", isAfter);
        }

        async function onReorderDrop(event, targetArticleKey) {
            event.preventDefault();

            const sourceArticleKey = draggedReorderArticleKey || event.dataTransfer.getData("text/plain");

            if (!sourceArticleKey || sourceArticleKey === targetArticleKey) {
                onReorderDragEnd();
                return;
            }

            const sourceIndex = reorderArticles.findIndex(article => article.key === sourceArticleKey);
            const targetIndex = reorderArticles.findIndex(article => article.key === targetArticleKey);

            if (sourceIndex < 0 || targetIndex < 0) {
                onReorderDragEnd();
                return;
            }

            const row = event.currentTarget;
            const isAfter = shouldReorderDropAfter(event, row);
            let requestedIndex = isAfter ? targetIndex + 1 : targetIndex;

            if (sourceIndex < requestedIndex) {
                requestedIndex -= 1;
            }

            await moveReorderArticleToIndex(sourceIndex, requestedIndex);
            onReorderDragEnd();
        }

        function onReorderDragEnd() {
            draggedReorderArticleKey = null;
            clearAllReorderDropCues();
        }

        async function moveReorderArticleToIndex(fromIndex, toIndex) {
            if (!Number.isInteger(fromIndex) || !Number.isInteger(toIndex)) {
                return;
            }

            if (fromIndex < 0 || fromIndex >= reorderArticles.length) {
                return;
            }

            const safeToIndex = Math.max(0, Math.min(toIndex, reorderArticles.length - 1));

            if (fromIndex === safeToIndex) {
                return;
            }

            const [movedArticle] = reorderArticles.splice(fromIndex, 1);
            reorderArticles.splice(safeToIndex, 0, movedArticle);
            lastMovedReorderArticleKey = movedArticle.key;

            renderReorderArticles();
            await saveReorderArticles();

            window.setTimeout(() => {
                lastMovedReorderArticleKey = null;
                renderReorderArticles();
            }, 760);
        }

        function shouldReorderDropAfter(event, row) {
            const rectangle = row.getBoundingClientRect();
            const verticalMiddle = rectangle.top + rectangle.height / 2;

            return event.clientY > verticalMiddle;
        }

        function clearReorderDropCue(row) {
            if (!row) {
                return;
            }

            row.classList.remove("drag-over-before", "drag-over-after");
        }

        function clearAllReorderDropCues() {
            document
                .querySelectorAll(".reorder-row.dragging, .reorder-row.drag-over-before, .reorder-row.drag-over-after")
                .forEach(row => {
                    row.classList.remove("dragging", "drag-over-before", "drag-over-after");
                });
        }

        async function moveReorderArticle(articleKey, direction) {
            const currentIndex = reorderArticles.findIndex(article => article.key === articleKey);

            if (currentIndex < 0) {
                return;
            }

            let targetIndex = currentIndex;

            if (direction === "top") {
                targetIndex = 0;
            }
            else if (direction === "up") {
                targetIndex = Math.max(0, currentIndex - 1);
            }
            else if (direction === "down") {
                targetIndex = Math.min(reorderArticles.length - 1, currentIndex + 1);
            }
            else if (direction === "bottom") {
                targetIndex = reorderArticles.length - 1;
            }

            if (targetIndex === currentIndex) {
                return;
            }

            await moveReorderArticleToIndex(currentIndex, targetIndex);
        }

        async function saveReorderArticles() {
            if (reorderSaveInProgress || !selectedReorderZoneKey || !selectedReorderStepKey) {
                return;
            }

            reorderSaveInProgress = true;

            try {
                const response = await fetch("/api/blog-content/articles/reorder", {
                    method: "PUT",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        dotnetZone: selectedReorderZoneKey,
                        dotnetZoneStep: selectedReorderStepKey,
                        articleKeys: reorderArticles.map(article => article.key)
                    })
                });

                const result = await readJsonResponse(response);

                if (!response.ok || result.success === false) {
                    showToast(result.message || "Unable to save article order.", "error");
                    await loadReorderArticles();
                    return;
                }

                reorderArticles = result.articles ?? reorderArticles;
                renderReorderArticles();
                showToast(result.message || "Article order updated.", "success");
                await loadContent();
            }
            catch (error) {
                console.error(error);
                showToast("Unable to save article order.", "error");
                await loadReorderArticles();
            }
            finally {
                reorderSaveInProgress = false;
            }
        }

        function renderDocumentTypes() {
            const search = getSearchText();

            const filteredDocumentTypes = documentTypes
                .filter(documentType =>
                    documentType.name.toLowerCase().includes(search) ||
                    documentType.alias.toLowerCase().includes(search) ||
                    documentType.icon.toLowerCase().includes(search))
                .sort((a, b) => Number(a.isElement) - Number(b.isElement) || a.name.localeCompare(b.name));

            const grid = document.getElementById("documentTypesGrid");

            if (filteredDocumentTypes.length === 0) {
                grid.innerHTML = `<div class="empty">No document types found.</div>`;
                return;
            }

            grid.innerHTML = filteredDocumentTypes.map(renderDocumentTypeCard).join("");
        }

        function renderDocumentTypeCard(documentType) {
            const kind = documentType.isElement ? "Element type" : "Document type";
            const countText = documentType.contentCount === 1
                ? "1 content item"
                : `${documentType.contentCount} content items`;

            return `
                <article class="document-type-card">
                    <div class="document-type-icon" title="${escapeHtml(documentType.icon)}">
                        ${getDocumentTypeIcon(documentType)}
                    </div>

                    <div class="document-type-body document-type-main">
                        <div class="document-type-kind">${kind}</div>
                        <h2>${escapeHtml(documentType.name)}</h2>
                        <p>${escapeHtml(documentType.alias)}</p>

                        <div class="document-type-meta">
                            <span>${escapeHtml(documentType.icon)}</span>
                            <span>${countText}</span>
                        </div>
                    </div>

                    <div class="document-type-actions">
                        ${renderDeleteButton("Delete", `requestDelete('documentType', '${escapeJs(documentType.key)}')`, "Delete document type")}
                    </div>
                </article>
            `;
        }

        function getDocumentTypeIcon(documentType) {
            const alias = String(documentType.alias ?? "").toLowerCase();
            const icon = String(documentType.icon ?? "").toLowerCase();

            if (alias.includes("article") || icon.includes("article") || icon.includes("news")) {
                return "▤";
            }

            if (alias.includes("zone") || icon.includes("folder")) {
                return "▰";
            }

            if (alias.includes("heading") || icon.includes("heading")) {
                return "H1";
            }

            if (alias.includes("code") || icon.includes("code")) {
                return "&lt;/&gt;";
            }

            if (alias.includes("plant") || alias.includes("mermaid") || icon.includes("diagram")) {
                return "🔀";
            }

            if (alias.includes("text")) {
                return "📝";
            }

            if (alias.includes("callout")) {
                return "⚠️";
            }

            return documentType.isElement ? "◇" : "□";
        }

        function renderArticles() {
            const search = getSearchText();
            const filteredArticles = articles
                .filter(article =>
                    article.title.toLowerCase().includes(search) ||
                    article.slug.toLowerCase().includes(search) ||
                    getZoneName(article.dotnetZone).toLowerCase().includes(search) ||
                    getStepName(article.dotnetZoneStep).toLowerCase().includes(search))
                .sort((a, b) =>
                    getZoneOrder(a.dotnetZone) - getZoneOrder(b.dotnetZone) ||
                    getStepOrder(a.dotnetZone, a.dotnetZoneStep) - getStepOrder(b.dotnetZone, b.dotnetZoneStep) ||
                    a.title.localeCompare(b.title));

            const grouped = groupByZoneStep(filteredArticles);
            const container = document.getElementById("articlesGrouped");

            if (filteredArticles.length === 0) {
                container.innerHTML = `<div class="empty">No articles found.</div>`;
                return;
            }

            container.innerHTML = Object.keys(grouped)
                .sort((a, b) => a.localeCompare(b))
                .map(groupKey => `
                    <section class="zone-step-group">
                        <div class="zone-step-heading">
                            <span>${escapeHtml(groupKey)}</span>
                            <span>${grouped[groupKey].length}</span>
                        </div>

                        <div class="article-list">
                            ${grouped[groupKey].map(renderArticleRow).join("")}
                        </div>
                    </section>
                `)
                .join("");
        }

        function renderArticleRow(article) {
            return `
