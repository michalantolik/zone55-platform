        async function onEditorMessage(event) {
            const inlineFrame = document.getElementById("inlineArticleEditorFrame");

            if (event.source !== inlineFrame.contentWindow) {
                return;
            }

            const message = event.data;

            if (!message || message.type !== "BLOG_ARTICLE_EDITOR_STATE") {
                return;
            }

            inlineEditorIsDirty = Boolean(message.isDirty);
            inlineEditorIsValid = Boolean(message.isValid);

            if (message.articleKey) {
                inlineEditorArticleKey = message.articleKey;
            }

            if (message.mode) {
                inlineEditorMode = message.mode;
            }

            if (message.title) {
                inlineEditorTitle = message.title;
            }

            updateInlineEditorCommandBar();

            if (message.saved) {
                await loadContent();
            }
        }

        function groupByZoneStep(items) {
            return items.reduce((result, article) => {
                const zoneName = getZoneName(article.dotnetZone);
                const stepName = getStepName(article.dotnetZoneStep);
                const groupName = `${zoneName} / ${stepName}`;

                result[groupName] ??= [];
                result[groupName].push(article);

                return result;
            }, {});
        }

        function getZoneName(zoneKey) {
            return dotnetRoadmap.find(zone => zone.key === zoneKey)?.name || "Unassigned zone";
        }

        function getStepName(stepKey) {
            for (const zone of dotnetRoadmap) {
                const step = zone.steps.find(item => item.key === stepKey);

                if (step) {
                    return step.name;
                }
            }

            return "Unassigned step";
        }

        function getZoneOrder(zoneKey) {
            return dotnetRoadmap.find(zone => zone.key === zoneKey)?.order ?? Number.MAX_SAFE_INTEGER;
        }

        function getStepOrder(zoneKey, stepKey) {
            const zone = dotnetRoadmap.find(item => item.key === zoneKey);

            if (!zone) {
                return Number.MAX_SAFE_INTEGER;
            }

            return zone.steps.find(step => step.key === stepKey)?.order ?? Number.MAX_SAFE_INTEGER;
        }

        function getTotalStepCount() {
            return dotnetRoadmap.reduce((total, zone) => total + zone.steps.length, 0);
        }

        function getSearchText() {
            return document.getElementById("searchInput").value.trim().toLowerCase();
        }

        function escapeHtml(value) {
            return String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll("\"", "&quot;")
                .replaceAll("'", "&#039;");
        }

        function escapeJs(value) {
            return String(value ?? "").replaceAll("\\", "\\\\").replaceAll("'", "\\'");
        }
    </script>
</body>
</html>
