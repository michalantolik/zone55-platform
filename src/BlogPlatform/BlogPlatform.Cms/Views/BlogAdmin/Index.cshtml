        function openRoadmapModal(title, name, key, keyReadonly) {
            const keyInput = document.getElementById("roadmapKeyInput");

            document.getElementById("roadmapModalTitle").innerText = title;
            document.getElementById("roadmapNameInput").value = name;

            keyInput.value = key;
            keyInput.readOnly = keyReadonly;
            keyInput.style.opacity = keyReadonly ? "0.62" : "1";

