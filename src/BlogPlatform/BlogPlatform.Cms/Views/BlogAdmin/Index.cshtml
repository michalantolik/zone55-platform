            roadmapModalState = null;
        }

        async function saveRoadmapItem() {
            if (!roadmapModalState) {
                return;
            }

            const name = document.getElementById("roadmapNameInput").value.trim();
            const key = document.getElementById("roadmapKeyInput").value.trim();

            if (!name) {
                showToast("Name is required.", "error");
                return;
            }

            const button = document.getElementById("saveRoadmapButton");
            button.disabled = true;
            button.innerText = "Saving...";

            try {
                const request = {
                    name,
                    key: key || null,
                    icon: null
                };

                const endpoint = getRoadmapSaveEndpoint();
                const response = await fetch(endpoint.url, {
                    method: endpoint.method,
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(request)
                });

                const result = await readJsonResponse(response);

                if (!response.ok || result.success === false) {
                    showToast(result.message || "Unable to save roadmap item.", "error");
                    return;
                }

                closeRoadmapModal();
                showToast(result.message || "Roadmap item saved.", "success");
                await loadContent();
            }
            catch (error) {
                console.error(error);
                showToast("Unable to save roadmap item.", "error");
            }
            finally {
                button.disabled = false;
                button.innerText = "Save";
            }
        }

        function getRoadmapSaveEndpoint() {
            if (roadmapModalState.mode === "create-zone") {
                return {
                    method: "POST",
                    url: "/api/blog-content/dotnet-roadmap/zones"
                };
            }

            if (roadmapModalState.mode === "edit-zone") {
                return {
                    method: "PUT",
                    url: `/api/blog-content/dotnet-roadmap/zones/${encodeURIComponent(roadmapModalState.zoneKey)}`
                };
            }

            if (roadmapModalState.mode === "create-step") {
                return {
                    method: "POST",
                    url: `/api/blog-content/dotnet-roadmap/zones/${encodeURIComponent(roadmapModalState.zoneKey)}/steps`
                };
            }

            return {
                method: "PUT",
                url: `/api/blog-content/dotnet-roadmap/zones/${encodeURIComponent(roadmapModalState.zoneKey)}/steps/${encodeURIComponent(roadmapModalState.stepKey)}`
            };
        }
