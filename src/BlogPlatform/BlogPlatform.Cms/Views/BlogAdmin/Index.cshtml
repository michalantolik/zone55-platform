@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Blog admin</title>

    <style>
        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: Inter, Arial, sans-serif;
            background: #061325;
            color: #f5f7fb;
        }

        .admin-shell {
            min-height: 100vh;
            background: radial-gradient(circle at top left, rgba(22, 119, 255, 0.22), transparent 34rem), #061325;
        }

        .top-bar {
            height: 64px;
            display: flex;
            align-items: center;
            padding: 0 28px;
            gap: 28px;
            background: #0b1b33;
            border-bottom: 1px solid #24405f;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.25);
        }

        .brand { display: flex; align-items: center; gap: 12px; font-weight: 900; letter-spacing: 0.02em; }

        .brand-mark {
            width: 34px;
            height: 34px;
            border-radius: 999px;
            display: grid;
            place-items: center;
            background: #1677ff;
            color: white;
            font-weight: 900;
        }

        .top-nav { display: flex; height: 100%; align-items: center; gap: 6px; }

        .top-nav button {
            height: 100%;
            display: flex;
            align-items: center;
            border: 0;
            border-bottom: 3px solid transparent;
            padding: 0 18px;
            background: transparent;
            color: #c8d8ef;
            font: inherit;
            font-weight: 800;
            text-decoration: none;
            cursor: pointer;
        }

        .top-nav button:hover,
        .top-nav button.active {
            color: white;
            border-bottom-color: #84bbff;
            background: rgba(255, 255, 255, 0.04);
        }

        .content { padding: 28px; }
        .content.editor-active { padding: 18px; }

        .hero {
            max-width: 1180px;
            margin: 0 auto 24px auto;
            padding: 26px;
            border: 1px solid #24405f;
            border-radius: 22px;
            background: rgba(9, 28, 52, 0.92);
        }

        .hero h1 { margin: 0 0 10px 0; font-size: 34px; }
        .hero p { margin: 0; color: #aac2de; line-height: 1.6; }

        .toolbar {
            max-width: 1180px;
            margin: 0 auto 20px auto;
            display: flex;
            gap: 14px;
            align-items: center;
        }

        .toolbar.hidden { display: none; }

        .search {
            flex: 1;
            border-radius: 12px;
            border: 1px solid #35527a;
            background: #020b18;
            color: white;
            padding: 13px 15px;
            font-size: 15px;
        }

        .status { color: #84bbff; font-weight: 800; white-space: nowrap; }

        .panel { max-width: 1180px; margin: 0 auto; display: none; }
        .panel.active { display: block; }
        .panel.article-editor-panel-active { max-width: none; }

        .editor-frame-shell {
            height: calc(100vh - 100px);
            min-height: 680px;
            border: 1px solid #24405f;
            border-radius: 18px;
            overflow: hidden;
            background: #06152b;
            box-shadow: 0 18px 42px rgba(0, 0, 0, 0.28);
        }

        .editor-frame {
            width: 100%;
            height: 100%;
            border: 0;
            display: block;
            background: #061325;
        }

        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 18px; }

        .card {
            border: 1px solid #24405f;
            border-radius: 18px;
            background: rgba(4, 17, 29, 0.9);
            padding: 20px;
            box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
        }

        .card h2, .card h3 { margin: 0 0 10px 0; }
        .card p { margin: 0; color: #aac2de; line-height: 1.5; }

        .card-header {
            display: flex;
            justify-content: space-between;
            gap: 16px;
            align-items: flex-start;
        }

        .card-main,
        .article-main,
        .document-type-main {
            min-width: 0;
        }

        .card-actions,
        .article-actions,
        .document-type-actions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 10px;
            flex-shrink: 0;
        }

        .category-badge {
            display: inline-flex;
            margin-top: 16px;
            padding: 7px 10px;
            border-radius: 999px;
            background: #163b62;
            color: #a7d0ff;
            font-size: 13px;
            font-weight: 800;
        }

        .category-group { margin-bottom: 26px; }

        .category-heading {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 0 0 12px 0;
            color: #84bbff;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-size: 14px;
            font-weight: 900;
        }

        .article-list { display: grid; gap: 12px; }

        .article-row {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 18px;
            align-items: center;
            border: 1px solid #24405f;
            border-radius: 16px;
            background: rgba(4, 17, 29, 0.88);
            padding: 16px 18px;
        }

        .article-title { font-weight: 900; margin-bottom: 5px; }
        .article-meta { color: #aac2de; font-size: 14px; }

        .btn {
            border: 0;
            border-radius: 10px;
            padding: 11px 14px;
            background: #1677ff;
            color: white;
            font-weight: 800;
            text-decoration: none;
            cursor: pointer;
        }

        .btn:hover { transform: translateY(-1px); }

        .articles-action-bar {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            margin: 0 0 20px 0;
        }

        .new-article-button {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: 1px solid #4f93e8;
            border-radius: 999px;
            padding: 12px 18px 12px 13px;
            background: linear-gradient(135deg, #1677ff, #0d4fa8);
            color: white;
            font: inherit;
            font-weight: 900;
            cursor: pointer;
            box-shadow: 0 16px 34px rgba(22, 119, 255, 0.28);
        }

        .new-article-button:hover {
            transform: translateY(-1px);
            box-shadow: 0 20px 42px rgba(22, 119, 255, 0.36);
        }

        .new-article-button-mark {
            width: 26px;
            height: 26px;
            border-radius: 999px;
            display: grid;
            place-items: center;
            background: rgba(255, 255, 255, 0.18);
            border: 1px solid rgba(255, 255, 255, 0.28);
            font-size: 20px;
            line-height: 1;
        }

        .document-types-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 16px;
        }

        .document-type-card {
            display: grid;
            grid-template-columns: 54px 1fr auto;
            gap: 16px;
            align-items: start;
            border: 1px solid #24405f;
            border-radius: 18px;
            background: rgba(4, 17, 29, 0.9);
            padding: 18px;
            box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
        }

        .document-type-icon {
            width: 46px;
            height: 46px;
            border-radius: 12px;
            display: grid;
            place-items: center;
            border: 1px solid #35527a;
            background: linear-gradient(180deg, rgba(132, 187, 255, 0.22), rgba(22, 119, 255, 0.10));
            color: #d7eaff;
            font-weight: 900;
            font-size: 17px;
        }

        .document-type-body h2 {
            margin: 3px 0 6px 0;
            font-size: 20px;
        }

        .document-type-body p {
            margin: 0;
            color: #aac2de;
        }

        .document-type-kind {
            color: #84bbff;
            font-size: 12px;
            font-weight: 900;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .document-type-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 14px;
        }

        .document-type-meta span {
            border-radius: 999px;
            padding: 6px 9px;
            background: #163b62;
            color: #a7d0ff;
            font-size: 12px;
            font-weight: 800;
        }

        .btn-secondary { background: #2d4463; }
        .btn-danger { background: #d0384d; }
        .btn-icon { min-width: 42px; padding: 10px 13px; border-radius: 999px; font-size: 18px; line-height: 1; }

        .delete-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            border: 1px solid rgba(255, 116, 139, 0.5);
            border-radius: 999px;
            padding: 9px 12px;
            background: rgba(208, 56, 77, 0.12);
            color: #ffb4c0;
            font: inherit;
            font-size: 13px;
            font-weight: 900;
            cursor: pointer;
            transition: transform 0.15s ease, background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
        }

        .delete-button:hover {
            transform: translateY(-1px);
            border-color: rgba(255, 148, 164, 0.78);
            background: rgba(208, 56, 77, 0.22);
            color: #ffd6dc;
        }

        .delete-button-icon {
            width: 18px;
            height: 18px;
            display: inline-grid;
            place-items: center;
            line-height: 1;
        }

        .article-actions .delete-button {
            width: 42px;
            height: 42px;
            padding: 0;
        }

        .toast {
            position: fixed;
            right: 24px;
            bottom: 24px;
            max-width: 420px;
            display: none;
            border: 1px solid #35527a;
            border-radius: 16px;
            padding: 14px 16px;
            background: #0d1d35;
            color: #f5f7fb;
            box-shadow: 0 22px 60px rgba(0, 0, 0, 0.42);
            z-index: 10000;
            font-weight: 800;
            line-height: 1.45;
        }

        .toast.success { border-color: rgba(31, 157, 85, 0.75); }
        .toast.error { border-color: rgba(208, 56, 77, 0.85); color: #ffd6dc; }

        .empty {
            padding: 22px;
            border: 1px dashed #35527a;
            border-radius: 16px;
            color: #aac2de;
            background: rgba(4, 17, 29, 0.65);
        }

        .hidden { display: none !important; }

        .editor-command-bar {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 12px;
            margin-bottom: 14px;
            padding: 14px 16px;
            border: 1px solid #24405f;
            border-radius: 16px;
            background: rgba(9, 28, 52, 0.94);
            box-shadow: 0 18px 36px rgba(0, 0, 0, 0.22);
        }

        .editor-command-context {
            margin-right: auto;
            color: #aac2de;
            font-size: 14px;
            line-height: 1.45;
        }

        .editor-command-context strong {
            display: block;
            color: #f5f7fb;
            font-size: 15px;
            margin-bottom: 2px;
        }

        .editor-command-bar .btn {
            min-width: 112px;
            padding: 12px 18px;
            border-radius: 12px;
        }

        .btn-success {
            background: linear-gradient(135deg, #1f9d55, #157347);
        }

        .btn:disabled,
        .btn.disabled {
            cursor: not-allowed;
            opacity: 0.48;
            transform: none;
            box-shadow: none;
        }

        .modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.68);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            padding: 24px;
        }

        .modal {
            width: min(520px, 100%);
            border-radius: 20px;
            border: 1px solid #48678f;
            background: #0d1d35;
            padding: 24px;
            box-shadow: 0 24px 80px rgba(0, 0, 0, 0.5);
        }

        .modal h2 { margin: 0 0 12px 0; }
        .modal p { margin: 0; color: #c8d8ef; line-height: 1.6; }
        .modal-buttons { display: flex; justify-content: flex-end; gap: 12px; margin-top: 24px; }
    </style>
</head>

<body>
    <div class="admin-shell">
        <header class="top-bar">
            <div class="brand">
                <div class="brand-mark">B</div>
                <div>Blog admin</div>
            </div>

            <nav class="top-nav">
                <button id="categoriesTab" class="active" type="button" onclick="showPanel('categories')">Categories</button>
                <button id="articlesTab" type="button" onclick="showPanel('articles')">Articles</button>
                <button id="documentTypesTab" type="button" onclick="showPanel('documentTypes')">Document Types</button>
            </nav>
        </header>

        <main id="mainContent" class="content">
            <section id="heroSection" class="hero">
                <h1>Blog content workspace</h1>
                <p>
                    Browse Umbraco CMS categories and articles in a clean Blog Platform admin view.
                    Use Open editor from the Articles tab when you want to edit an existing article with live preview.
                </p>
            </section>

            <section id="toolbarSection" class="toolbar">
                <input id="searchInput" class="search" type="search" placeholder="Search categories, articles or document types..." />
                <div id="statusText" class="status">Loading CMS content...</div>
            </section>

            <section id="categoriesPanel" class="panel active">
                <div id="categoriesGrid" class="grid"></div>
            </section>

            <section id="documentTypesPanel" class="panel">
                <div id="documentTypesGrid" class="document-types-grid"></div>
            </section>

            <section id="articlesPanel" class="panel">
                <div id="articlesListView">
                    <div id="articlesActionBar" class="articles-action-bar">
                        <button class="new-article-button" type="button" onclick="openNewArticleEditorInArticlesTab()">
                            <span class="new-article-button-mark">+</span>
                            <span>Create new article</span>
                        </button>
                    </div>

                    <div id="articlesGrouped"></div>
                </div>

                <div id="articlesEditorView" class="hidden">
                    <div id="editorCommandBar" class="editor-command-bar">
                        <div id="editorCommandContext" class="editor-command-context">
                            <strong>Article editor</strong>
                            Fill the article fields, preview the result, then publish or update when ready.
                        </div>

                        <button id="editorSaveButton" class="btn btn-success" type="button" onclick="publishOrUpdateInlineArticleEditor()" disabled>
                            Publish
                        </button>

                        <button class="btn btn-danger" type="button" onclick="requestCloseInlineArticleEditor()">
                            Close
                        </button>
                    </div>

                    <div class="editor-frame-shell">
                        <iframe id="inlineArticleEditorFrame" class="editor-frame" title="Article Editor in Articles tab"></iframe>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <div id="deleteContentModal" class="modal-backdrop">
        <div class="modal">
            <h2 id="deleteContentModalTitle">Delete item?</h2>
            <p id="deleteContentModalMessage">This action cannot be undone.</p>

            <div class="modal-buttons">
                <button class="btn btn-secondary" type="button" onclick="closeDeleteContentModal()">Cancel</button>
                <button id="confirmDeleteContentButton" class="btn btn-danger" type="button" onclick="confirmDeleteContent()">Delete</button>
            </div>
        </div>
    </div>

    <div id="toast" class="toast"></div>

    <div id="closeInlineEditorModal" class="modal-backdrop">
        <div class="modal">
            <h2>Close article editor?</h2>
            <p>
                This article has unsaved local changes. Closing the editor will discard those changes and return you to the Articles list.
            </p>

            <div class="modal-buttons">
                <button class="btn btn-secondary" type="button" onclick="closeInlineEditorModal()">Keep editing</button>
                <button class="btn btn-danger" type="button" onclick="closeInlineArticleEditor()">Discard changes</button>
            </div>
        </div>
    </div>

    <script>
        let categories = [];
        let articles = [];
        let documentTypes = [];
        let activePanel = "categories";
        let inlineEditorIsDirty = false;
        let inlineEditorArticleKey = null;
        let inlineEditorMode = "existing";
        let inlineEditorIsValid = false;
        let inlineEditorTitle = "Article editor";
        let pendingDelete = null;
        let toastTimeout = null;

        document.addEventListener("DOMContentLoaded", async () => {
            document.getElementById("searchInput").addEventListener("input", renderActivePanel);
            window.addEventListener("message", onEditorMessage);

            await loadContent();
        });

        async function loadContent() {
            const [categoriesResponse, articlesResponse, documentTypesResponse] = await Promise.all([
                fetch("/api/blog-content/categories"),
                fetch("/api/blog-content/articles"),
                fetch("/api/blog-content/document-types")
            ]);

            categories = await categoriesResponse.json();
            articles = await articlesResponse.json();
            documentTypes = await documentTypesResponse.json();

            renderActivePanel();

            document.getElementById("statusText").innerText =
                `${categories.length} categories, ${articles.length} articles, ${documentTypes.length} document types`;
        }

        function showPanel(panel) {
            activePanel = panel;

            document.getElementById("categoriesTab").classList.toggle("active", panel === "categories");
            document.getElementById("articlesTab").classList.toggle("active", panel === "articles");
            document.getElementById("documentTypesTab").classList.toggle("active", panel === "documentTypes");

            document.getElementById("categoriesPanel").classList.toggle("active", panel === "categories");
            document.getElementById("articlesPanel").classList.toggle("active", panel === "articles");
            document.getElementById("documentTypesPanel").classList.toggle("active", panel === "documentTypes");

            const articlesEditorIsOpen = panel === "articles" && !document.getElementById("articlesEditorView").classList.contains("hidden");

            document.getElementById("toolbarSection").classList.toggle("hidden", articlesEditorIsOpen);
            document.getElementById("heroSection").style.display = articlesEditorIsOpen ? "none" : "block";
            document.getElementById("mainContent").classList.toggle("editor-active", articlesEditorIsOpen);
            document.getElementById("articlesPanel").classList.toggle("article-editor-panel-active", articlesEditorIsOpen);

            renderActivePanel();
        }

        function renderActivePanel() {
            if (activePanel === "categories") {
                renderCategories();
            }

            if (activePanel === "articles" && document.getElementById("articlesEditorView").classList.contains("hidden")) {
                renderArticles();
            }

            if (activePanel === "documentTypes") {
                renderDocumentTypes();
            }
        }

        function renderCategories() {
            const search = getSearchText();
            const filteredCategories = categories
                .filter(category => category.name.toLowerCase().includes(search) || category.slug.toLowerCase().includes(search))
                .sort((a, b) => a.name.localeCompare(b.name));

            const grid = document.getElementById("categoriesGrid");

            if (filteredCategories.length === 0) {
                grid.innerHTML = `<div class="empty">No categories found.</div>`;
                return;
            }

            grid.innerHTML = filteredCategories.map(category => {
                const count = articles.filter(article => article.categorySlug === category.slug).length;

                return `
                    <article class="card">
                        <div class="card-header">
                            <div class="card-main">
                                <h2>${escapeHtml(category.name)}</h2>
                                <p>${escapeHtml(category.slug)}</p>
                                <span class="category-badge">${count} article${count === 1 ? "" : "s"}</span>
                            </div>

                            <div class="card-actions">
                                ${renderDeleteButton("Delete", `requestDelete('category', '${escapeJs(category.key)}')`, "Delete category")}
                            </div>
                        </div>
                    </article>
                `;
            }).join("");
        }

        function renderDocumentTypes() {
            const search = getSearchText();

            const filteredDocumentTypes = documentTypes
                .filter(documentType =>
                    documentType.name.toLowerCase().includes(search) ||
                    documentType.alias.toLowerCase().includes(search) ||
                    documentType.icon.toLowerCase().includes(search))
                .sort((a, b) => Number(a.isElement) - Number(b.isElement) || a.name.localeCompare(b.name));

            const grid = document.getElementById("documentTypesGrid");

            if (filteredDocumentTypes.length === 0) {
                grid.innerHTML = `<div class="empty">No document types found.</div>`;
                return;
            }

            grid.innerHTML = filteredDocumentTypes.map(renderDocumentTypeCard).join("");
        }

        function renderDocumentTypeCard(documentType) {
            const kind = documentType.isElement ? "Element type" : "Document type";
            const countText = documentType.contentCount === 1
                ? "1 content item"
                : `${documentType.contentCount} content items`;

            return `
                <article class="document-type-card">
                    <div class="document-type-icon" title="${escapeHtml(documentType.icon)}">
                        ${getDocumentTypeIcon(documentType)}
                    </div>

                    <div class="document-type-body document-type-main">
                        <div class="document-type-kind">${kind}</div>
                        <h2>${escapeHtml(documentType.name)}</h2>
                        <p>${escapeHtml(documentType.alias)}</p>

                        <div class="document-type-meta">
                            <span>${escapeHtml(documentType.icon)}</span>
                            <span>${countText}</span>
                        </div>
                    </div>

                    <div class="document-type-actions">
                        ${renderDeleteButton("Delete", `requestDelete('documentType', '${escapeJs(documentType.key)}')`, "Delete document type")}
                    </div>
                </article>
            `;
        }

        function getDocumentTypeIcon(documentType) {
            const alias = String(documentType.alias ?? "").toLowerCase();
            const icon = String(documentType.icon ?? "").toLowerCase();

            if (alias.includes("article") || icon.includes("article") || icon.includes("news")) {
                return "▤";
            }

            if (alias.includes("category") || icon.includes("folder")) {
                return "▰";
            }

            if (alias.includes("heading") || icon.includes("heading")) {
                return "H1";
            }

            if (alias.includes("code") || icon.includes("code")) {
                return "&lt;&gt;";
            }

            if (alias.includes("plant") || alias.includes("mermaid") || icon.includes("diagram")) {
                return "⌘";
            }

            if (alias.includes("text")) {
                return "¶";
            }

            if (alias.includes("callout")) {
                return "△";
            }

            return documentType.isElement ? "◇" : "□";
        }

        function renderArticles() {
            const search = getSearchText();
            const filteredArticles = articles
                .filter(article =>
                    article.title.toLowerCase().includes(search) ||
                    article.slug.toLowerCase().includes(search) ||
                    article.categoryName.toLowerCase().includes(search))
                .sort((a, b) => a.categoryName.localeCompare(b.categoryName) || a.title.localeCompare(b.title));

            const grouped = groupByCategory(filteredArticles);
            const container = document.getElementById("articlesGrouped");

            if (filteredArticles.length === 0) {
                container.innerHTML = `<div class="empty">No articles found.</div>`;
                return;
            }

            container.innerHTML = Object.keys(grouped)
                .sort((a, b) => a.localeCompare(b))
                .map(categoryName => `
                    <section class="category-group">
                        <div class="category-heading">
                            <span>${escapeHtml(categoryName)}</span>
                            <span>${grouped[categoryName].length}</span>
                        </div>

                        <div class="article-list">
                            ${grouped[categoryName].map(renderArticleRow).join("")}
                        </div>
                    </section>
                `)
                .join("");
        }

        function renderArticleRow(article) {
            return `
                <article class="article-row">
                    <div class="article-main">
                        <div class="article-title">${escapeHtml(article.title)}</div>
                        <div class="article-meta">
                            ${escapeHtml(article.slug)} · ${escapeHtml(article.level)} · ${escapeHtml(article.focus)}
                        </div>
                    </div>

                    <div class="article-actions">
                        <button class="btn" type="button" onclick="openArticleEditorInArticlesTab('${escapeJs(article.key)}')">
                            Open editor
                        </button>
                        ${renderDeleteButton("Delete", `requestDelete('article', '${escapeJs(article.key)}')`, "Delete article", false)}
                    </div>
                </article>
            `;
        }

        function renderDeleteButton(label, clickHandler, title, showText = true) {
            return `
                <button class="delete-button" type="button" title="${escapeHtml(title)}" onclick="${clickHandler}">
                    <span class="delete-button-icon" aria-hidden="true">🗑</span>
                    ${showText ? `<span>${escapeHtml(label)}</span>` : `<span class="hidden">${escapeHtml(label)}</span>`}
                </button>
            `;
        }

        function requestDelete(type, key) {
            pendingDelete = resolveDeleteTarget(type, key);

            if (!pendingDelete) {
                showToast("Cannot find selected item.", "error");
                return;
            }

            document.getElementById("deleteContentModalTitle").innerText = pendingDelete.title;
            document.getElementById("deleteContentModalMessage").innerText = pendingDelete.message;
            document.getElementById("confirmDeleteContentButton").disabled = false;
            document.getElementById("confirmDeleteContentButton").innerText = "Delete";
            document.getElementById("deleteContentModal").style.display = "flex";
        }

        function resolveDeleteTarget(type, key) {
            if (type === "category") {
                const category = categories.find(item => item.key === key);

                if (!category) {
                    return null;
                }

                return {
                    type,
                    key,
                    endpoint: `/api/blog-content/categories/${encodeURIComponent(key)}`,
                    title: "Delete category?",
                    message: `Delete category "${category.name}"? This action cannot be undone. Categories with assigned articles are protected and will not be deleted.`
                };
            }

            if (type === "article") {
                const article = articles.find(item => item.key === key);

                if (!article) {
                    return null;
                }

                return {
                    type,
                    key,
                    endpoint: `/api/blog-content/articles/${encodeURIComponent(key)}`,
                    title: "Delete article?",
                    message: `Delete article "${article.title}"? This action cannot be undone.`
                };
            }

            if (type === "documentType") {
                const documentType = documentTypes.find(item => item.key === key);

                if (!documentType) {
                    return null;
                }

                return {
                    type,
                    key,
                    endpoint: `/api/blog-content/document-types/${encodeURIComponent(key)}`,
                    title: "Delete document type?",
                    message: `Delete document type "${documentType.name}"? This action cannot be undone. Types with existing content items are protected and will not be deleted.`
                };
            }

            return null;
        }

        function closeDeleteContentModal() {
            document.getElementById("deleteContentModal").style.display = "none";
            pendingDelete = null;
        }

        async function confirmDeleteContent() {
            if (!pendingDelete) {
                return;
            }

            const button = document.getElementById("confirmDeleteContentButton");
            button.disabled = true;
            button.innerText = "Deleting...";

            try {
                const response = await fetch(pendingDelete.endpoint, {
                    method: "DELETE"
                });

                const result = await readJsonResponse(response);

                if (!response.ok || result.success === false) {
                    showToast(result.message || "Unable to delete selected item.", "error");
                    button.disabled = false;
                    button.innerText = "Delete";
                    return;
                }

                closeDeleteContentModal();
                showToast(result.message || "Item deleted successfully.", "success");
                await loadContent();
            }
            catch (error) {
                console.error(error);
                showToast("Unable to delete selected item.", "error");
                button.disabled = false;
                button.innerText = "Delete";
            }
        }

        async function readJsonResponse(response) {
            try {
                return await response.json();
            }
            catch {
                return {
                    success: response.ok,
                    message: response.ok ? "Done." : "Request failed."
                };
            }
        }

        function showToast(message, kind) {
            const toast = document.getElementById("toast");

            if (toastTimeout) {
                clearTimeout(toastTimeout);
            }

            toast.className = `toast ${kind}`;
            toast.innerText = message;
            toast.style.display = "block";

            toastTimeout = setTimeout(() => {
                toast.style.display = "none";
            }, 4200);
        }

        function openArticleEditorInArticlesTab(articleKey) {
            const article = articles.find(item => item.key === articleKey);

            inlineEditorIsDirty = false;
            inlineEditorArticleKey = articleKey;
            inlineEditorMode = "existing";

            inlineEditorTitle = article ? article.title : "Article editor";
            updateInlineEditorCommandBar();

            document.getElementById("articlesListView").classList.add("hidden");
            document.getElementById("articlesEditorView").classList.remove("hidden");

            const frame = document.getElementById("inlineArticleEditorFrame");
            frame.src = `/blog-admin/article-editor?articleKey=${encodeURIComponent(articleKey)}&embedded=articles&requestId=${Date.now()}`;

            showPanel("articles");
        }

        function openNewArticleEditorInArticlesTab() {
            inlineEditorIsDirty = false;
            inlineEditorArticleKey = null;
            inlineEditorIsValid = false;
            inlineEditorTitle = "Article editor";
            inlineEditorMode = "new";

            inlineEditorTitle = "Create new article";
            updateInlineEditorCommandBar();

            document.getElementById("articlesListView").classList.add("hidden");
            document.getElementById("articlesEditorView").classList.remove("hidden");

            const frame = document.getElementById("inlineArticleEditorFrame");
            frame.src = `/blog-admin/article-editor?embedded=articles&mode=new&requestId=${Date.now()}`;

            showPanel("articles");
        }

        function updateInlineEditorCommandBar() {
            const saveButton = document.getElementById("editorSaveButton");
            const context = document.getElementById("editorCommandContext");
            const isExistingArticle = Boolean(inlineEditorArticleKey);
            const actionText = isExistingArticle ? "Update" : "Publish";

            saveButton.innerText = actionText;
            saveButton.disabled = !inlineEditorIsValid;
            saveButton.title = inlineEditorIsValid
                ? `${actionText} article`
                : "Fill title, slug, summary, category, tags and body before saving.";

            context.innerHTML = `
                <strong>${escapeHtml(inlineEditorTitle || "Article editor")}</strong>
                ${isExistingArticle
                    ? "Editing an article that already exists in the CMS. Update is available when required fields are filled."
                    : "Creating a new CMS article. Publish is available when required fields are filled."}
            `;
        }

        function publishOrUpdateInlineArticleEditor() {
            if (!inlineEditorIsValid) {
                return;
            }

            const frame = document.getElementById("inlineArticleEditorFrame");

            frame.contentWindow?.postMessage({
                type: "BLOG_ARTICLE_EDITOR_SAVE"
            }, "*");
        }

        function requestCloseInlineArticleEditor() {
            if (inlineEditorIsDirty) {
                document.getElementById("closeInlineEditorModal").style.display = "flex";
                return;
            }

            closeInlineArticleEditor();
        }

        function closeInlineEditorModal() {
            document.getElementById("closeInlineEditorModal").style.display = "none";
        }

        function closeInlineArticleEditor() {
            closeInlineEditorModal();

            inlineEditorIsDirty = false;
            inlineEditorArticleKey = null;

            const frame = document.getElementById("inlineArticleEditorFrame");
            frame.removeAttribute("src");

            document.getElementById("articlesEditorView").classList.add("hidden");
            document.getElementById("articlesListView").classList.remove("hidden");

            showPanel("articles");
            renderArticles();
        }

        async function onEditorMessage(event) {
            const inlineFrame = document.getElementById("inlineArticleEditorFrame");

            if (event.source !== inlineFrame.contentWindow) {
                return;
            }

            const message = event.data;

            if (!message || message.type !== "BLOG_ARTICLE_EDITOR_STATE") {
                return;
            }

            inlineEditorIsDirty = Boolean(message.isDirty);
            inlineEditorIsValid = Boolean(message.isValid);

            if (message.articleKey) {
                inlineEditorArticleKey = message.articleKey;
            }

            if (message.mode) {
                inlineEditorMode = message.mode;
            }

            if (message.title) {
                inlineEditorTitle = message.title;
            }

            updateInlineEditorCommandBar();

            if (message.saved) {
                await loadContent();
            }
        }

        function groupByCategory(items) {
            return items.reduce((result, article) => {
                const categoryName = article.categoryName || "Uncategorized";
                result[categoryName] ??= [];
                result[categoryName].push(article);
                return result;
            }, {});
        }

        function getSearchText() {
            return document.getElementById("searchInput").value.trim().toLowerCase();
        }

        function escapeHtml(value) {
            return String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll("\"", "&quot;")
                .replaceAll("'", "&#039;");
        }

        function escapeJs(value) {
            return String(value ?? "").replaceAll("\\", "\\\\").replaceAll("'", "\\'");
        }
    </script>
</body>
</html>
