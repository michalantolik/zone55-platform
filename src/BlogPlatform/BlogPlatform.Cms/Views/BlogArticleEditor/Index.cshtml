@{
    Layout = null;

    var previewUrl =
        (string)(ViewData["PreviewUrl"]
            ?? "https://localhost:7252/preview/article");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Article editor</title>

    <style>
        * {
            box-sizing: border-box;
        }

        :root {
            --article-editor-sidebar-width: 420px;
            --article-editor-sidebar-min-width: 260px;
            --article-editor-preview-min-width: 420px;
            --article-editor-splitter-width: 10px;
        }

        body {
            margin: 0;
            overflow: hidden;
            font-family: Inter, Arial, sans-serif;
            background: #061325;
            color: #f5f7fb;
        }

        body.resizing {
            cursor: col-resize;
            user-select: none;
        }

        body.resizing iframe {
            pointer-events: none;
        }

        .layout {
            display: flex;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
        }

        .sidebar {
            flex: 0 0 var(--article-editor-sidebar-width);
            min-width: var(--article-editor-sidebar-min-width);
            overflow-y: auto;
            padding: 20px;
            background: #06152b;
        }

        .splitter {
            flex: 0 0 var(--article-editor-splitter-width);
            width: var(--article-editor-splitter-width);
            cursor: col-resize;
            background: #11243e;
            border-left: 1px solid #29405f;
            border-right: 1px solid #29405f;
            position: relative;
            touch-action: none;
        }

        .splitter::after {
            content: "";
            position: absolute;
            top: 50%;
            left: 50%;
            width: 3px;
            height: 64px;
            border-radius: 999px;
            background: #5f7fa8;
            transform: translate(-50%, -50%);
            opacity: 0.8;
        }

        .splitter:hover,
        body.resizing .splitter {
            background: #17365d;
        }

        .preview-area {
            flex: 1 1 auto;
            min-width: var(--article-editor-preview-min-width);
            padding: 18px;
            background:
                radial-gradient(circle at top, #103b69, #04111d);
        }

        iframe {
            width: 100%;
            height: calc(100vh - 36px);
            border: 0;
            border-radius: 18px;
            background: white;
        }

        h1 {
            margin-top: 0;
            margin-bottom: 18px;
            font-size: 28px;
        }

        .section-title {
            margin-top: 28px;
            margin-bottom: 10px;
            color: #84bbff;
            font-weight: 800;
            font-size: 14px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        label {
            display: block;
            margin-top: 16px;
            margin-bottom: 8px;
            font-weight: 700;
        }

        input,
        textarea,
        select {
            width: 100%;
            border-radius: 10px;
            border: 1px solid #35527a;
            background: #020b18;
            color: white;
            padding: 12px;
            font-size: 15px;
        }

        textarea {
            min-height: 180px;
            resize: vertical;
        }

        .helper {
            margin-bottom: 18px;
            color: #aac2de;
            font-size: 14px;
            line-height: 1.5;
        }

        .button-row {
            display: flex;
            gap: 12px;
            margin-top: 20px;
        }

        button {
            border: 0;
            border-radius: 10px;
            padding: 12px 18px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.15s ease;
        }

        button:hover {
            transform: translateY(-1px);
        }

        .btn-primary {
            background: #1677ff;
            color: white;
        }

        .btn-secondary {
            background: #2d4463;
            color: white;
        }

        .btn-danger {
            background: #d0384d;
            color: white;
        }

        .status-bar {
            margin-top: 20px;
            padding: 14px;
            border-radius: 12px;
            font-weight: 700;
        }

        .status-clean {
            background: #183822;
            color: #a9ffb9;
        }

        .status-dirty {
            background: #4b3412;
            color: #ffd58d;
        }

        .status-new {
            background: #163b62;
            color: #a7d0ff;
        }

        .modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.6);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

        .modal {
            width: 460px;
            border-radius: 18px;
            border: 1px solid #39577e;
            background: #0d1d35;
            padding: 24px;
        }

        .modal h2 {
            margin-top: 0;
        }

        .modal-buttons {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 24px;
        }
    </style>
</head>

<body>

<div class="layout">

    <div class="sidebar" id="editorSidebar">

        <h1>Article editor</h1>

        <div class="helper">
            Create new articles or edit existing Umbraco CMS articles
            with live preview.
        </div>

        <div class="button-row">
            <button class="btn-primary" type="button" onclick="createNewArticle()">
                Create new article
            </button>
        </div>

        <div class="section-title">Existing articles</div>

        <label>Category</label>

        <select id="categoryFilter">
            <option value="">Loading...</option>
        </select>

        <label>Article</label>

        <select id="articleSelect">
            <option value="">Select article</option>
        </select>

        <div class="button-row">
            <button class="btn-secondary" type="button" onclick="loadSelectedArticle()">
                Load article
            </button>
        </div>

        <div class="section-title">Article fields</div>

        <label>Title</label>
        <input id="title" type="text" />

        <label>Slug</label>
        <input id="slug" type="text" />

        <label>Summary</label>
        <textarea id="summary"></textarea>

        <label>Category</label>
        <select id="articleCategory"></select>

        <label>Tags comma-separated</label>
        <input id="tags" type="text" />

        <label>Body markdown</label>
        <textarea id="bodyMarkdown"></textarea>

        <div id="editorStatus" class="status-bar status-new">
            Creating new article
        </div>

        <div class="button-row">
            <button class="btn-primary" type="button" onclick="confirmSave()">
                Save
            </button>

            <button class="btn-danger" type="button" onclick="confirmCancel()">
                Cancel
            </button>
        </div>

    </div>

    <div
        id="paneSplitter"
        class="splitter"
        role="separator"
        aria-orientation="vertical"
        aria-label="Resize article editor panes">
    </div>

    <div class="preview-area">

        <iframe
            id="previewFrame"
            src="@previewUrl"
            onload="onPreviewFrameLoaded()">
        </iframe>

    </div>

</div>

<div id="saveModal" class="modal-backdrop">
    <div class="modal">
        <h2>Save article</h2>

        <p>Are you sure you want to save the article?</p>

        <div class="modal-buttons">
            <button class="btn-secondary" type="button" onclick="closeSaveModal()">
                No
            </button>

            <button class="btn-primary" type="button" onclick="saveArticle()">
                Yes, save
            </button>
        </div>
    </div>
</div>

<div id="cancelModal" class="modal-backdrop">
    <div class="modal">
        <h2>Cancel changes</h2>

        <p>Are you sure you want to discard local changes?</p>

        <div class="modal-buttons">
            <button class="btn-secondary" type="button" onclick="closeCancelModal()">
                No
            </button>

            <button class="btn-danger" type="button" onclick="cancelChanges()">
                Yes, cancel
            </button>
        </div>
    </div>
</div>

<script>
    const sidebarWidthStorageKey =
        "blogArticleEditor.sidebarWidth";

    const defaultSidebarWidth =
        420;

    const minSidebarWidth =
        260;

    const minPreviewWidth =
        420;

    let currentArticleKey = null;
    let originalState = null;
    let isDirty = false;
    let sendSequence = 0;
    let previewFrameLoaded = false;

    const frame =
        document.getElementById("previewFrame");

    const fieldIds = [
        "title",
        "slug",
        "summary",
        "articleCategory",
        "tags",
        "bodyMarkdown"
    ];

    document.addEventListener("DOMContentLoaded", async () => {

        initializeResizablePanes();

        await loadCategories();

        attachFieldListeners();

        createNewArticle();

        sendPreviewUpdate();
    });

    function initializeResizablePanes() {

        const splitter =
            document.getElementById("paneSplitter");

        const savedWidth =
            Number(localStorage.getItem(sidebarWidthStorageKey));

        if (Number.isFinite(savedWidth) && savedWidth > 0) {
            setSidebarWidth(savedWidth);
        }
        else {
            setSidebarWidth(defaultSidebarWidth);
        }

        splitter.addEventListener("pointerdown", startPaneResize);

        splitter.addEventListener("dblclick", () => {
            setSidebarWidth(defaultSidebarWidth);

            localStorage.setItem(
                sidebarWidthStorageKey,
                defaultSidebarWidth.toString());
        });

        window.addEventListener("resize", () => {
            setSidebarWidth(getCurrentSidebarWidth());
        });
    }

    function startPaneResize(event) {

        event.preventDefault();

        const splitter =
            document.getElementById("paneSplitter");

        splitter.setPointerCapture(event.pointerId);

        document.body.classList.add("resizing");

        const onPointerMove = moveEvent => {
            setSidebarWidth(moveEvent.clientX);
        };

        const onPointerUp = upEvent => {

            splitter.releasePointerCapture(upEvent.pointerId);

            document.body.classList.remove("resizing");

            localStorage.setItem(
                sidebarWidthStorageKey,
                getCurrentSidebarWidth().toString());

            window.removeEventListener("pointermove", onPointerMove);
            window.removeEventListener("pointerup", onPointerUp);
            window.removeEventListener("pointercancel", onPointerUp);
        };

        window.addEventListener("pointermove", onPointerMove);
        window.addEventListener("pointerup", onPointerUp);
        window.addEventListener("pointercancel", onPointerUp);
    }

    function setSidebarWidth(requestedWidth) {

        const maxSidebarWidth =
            Math.max(
                minSidebarWidth,
                window.innerWidth - minPreviewWidth);

        const width =
            Math.min(
                Math.max(requestedWidth, minSidebarWidth),
                maxSidebarWidth);

        document.documentElement.style.setProperty(
            "--article-editor-sidebar-width",
            `${width}px`);
    }

    function getCurrentSidebarWidth() {

        const sidebar =
            document.getElementById("editorSidebar");

        return Math.round(sidebar.getBoundingClientRect().width);
    }

    function onPreviewFrameLoaded() {

        previewFrameLoaded = true;

        console.log("[LIVE_PREVIEW] iframe loaded:", frame.src);

        setTimeout(() => {
            sendPreviewUpdate();
        }, 250);
    }

    async function loadCategories() {

        const response =
            await fetch("/api/blog-content/categories");

        const categories =
            await response.json();

        const categoryFilter =
            document.getElementById("categoryFilter");

        const articleCategory =
            document.getElementById("articleCategory");

        categoryFilter.innerHTML =
            `<option value="">All categories</option>`;

        articleCategory.innerHTML = "";

        for (const category of categories) {

            categoryFilter.innerHTML += `
                <option value="${category.slug}">
                    ${category.name}
                </option>
            `;

            articleCategory.innerHTML += `
                <option value="${category.slug}">
                    ${category.name}
                </option>
            `;
        }

        categoryFilter.addEventListener("change", async () => {
            await loadArticles();
        });

        await loadArticles();
    }

    async function loadArticles() {

        const categorySlug =
            value("categoryFilter");

        const response =
            await fetch(`/api/blog-content/articles?categorySlug=${categorySlug}`);

        const articles =
            await response.json();

        const select =
            document.getElementById("articleSelect");

        select.innerHTML =
            `<option value="">Select article</option>`;

        for (const article of articles) {

            select.innerHTML += `
                <option value="${article.key}">
                    ${article.title} (${article.categoryName})
                </option>
            `;
        }
    }

    async function loadSelectedArticle() {

        const key =
            value("articleSelect");

        if (!key) {
            return;
        }

        const response =
            await fetch(`/api/blog-content/articles/${key}`);

        const article =
            await response.json();

        currentArticleKey =
            article.key;

        setValue("title", article.title);
        setValue("slug", article.slug);
        setValue("summary", article.summary);
        setValue("articleCategory", article.categorySlug);
        setValue("tags", article.tags);
        setValue("bodyMarkdown", article.bodyBlocks);

        originalState =
            getCurrentState();

        setDirty(false);

        updateStatus(
            "Editing existing article",
            "status-clean");

        sendPreviewUpdate();
    }

    function createNewArticle() {

        currentArticleKey = null;

        setValue("title", "Example article title");
        setValue("slug", "example-article");
        setValue("summary", "Short article summary.");
        setValue("tags", ".NET, Architecture, Azure");

        setValue("bodyMarkdown",
`## First heading

This is the first paragraph.

\`\`\`csharp
public sealed class Example
{
    public string Name { get; set; } = string.Empty;
}
\`\`\`
`);

        originalState =
            getCurrentState();

        setDirty(false);

        updateStatus(
            "Creating new article",
            "status-new");

        sendPreviewUpdate();
    }

    function attachFieldListeners() {

        for (const fieldId of fieldIds) {

            const field =
                document.getElementById(fieldId);

            field.addEventListener("input", onEditorChanged);
            field.addEventListener("change", onEditorChanged);
        }
    }

    function onEditorChanged() {

        const changed =
            JSON.stringify(getCurrentState()) !==
            JSON.stringify(originalState);

        setDirty(changed);

        sendPreviewUpdate();
    }

    function getCurrentState() {

        return {
            title: value("title"),
            slug: value("slug"),
            summary: value("summary"),
            categorySlug: value("articleCategory"),
            tags: value("tags"),
            bodyMarkdown: value("bodyMarkdown")
        };
    }

    function sendPreviewUpdate() {

        sendSequence++;

        const article = {

            slug: value("slug"),

            title: value("title"),

            summary: value("summary"),

            category: selectedText("articleCategory"),

            categorySlug: value("articleCategory"),

            level: "Draft",

            focus: "Preview",

            tags:
                value("tags")
                    .split(",")
                    .map(x => x.trim())
                    .filter(Boolean),

            publishedDate: null,

            bodyHtml:
                createPreviewHtml(value("bodyMarkdown"))
        };

        try {

            frame.contentWindow.postMessage({
                type: "BLOG_ARTICLE_PREVIEW",
                sequence: sendSequence,
                article
            }, "*");

            console.log(
                "[LIVE_PREVIEW] message sent:",
                sendSequence,
                article.title);
        }
        catch (error) {

            console.error(
                "[LIVE_PREVIEW] failed to send preview message:",
                error);
        }
    }

    function createPreviewHtml(markdown) {

        return markdown
            .replace(/^## (.*)$/gm, "<h2>$1</h2>")
            .replace(/^# (.*)$/gm, "<h1>$1</h1>")
            .replace(/\*\*(.*?)\*\*/gm, "<strong>$1</strong>")
            .replace(/\n/g, "<br/>");
    }

    function setDirty(value) {

        isDirty = value;

        if (isDirty) {

            updateStatus(
                "Unsaved local changes",
                "status-dirty");
        }
        else {

            if (currentArticleKey) {

                updateStatus(
                    "All changes saved",
                    "status-clean");
            }
            else {

                updateStatus(
                    "Creating new article",
                    "status-new");
            }
        }
    }

    function updateStatus(text, cssClass) {

        const status =
            document.getElementById("editorStatus");

        status.className =
            `status-bar ${cssClass}`;

        status.innerText =
            text;
    }

    function confirmSave() {

        document.getElementById("saveModal").style.display =
            "flex";
    }

    function closeSaveModal() {

        document.getElementById("saveModal").style.display =
            "none";
    }

    function confirmCancel() {

        document.getElementById("cancelModal").style.display =
            "flex";
    }

    function closeCancelModal() {

        document.getElementById("cancelModal").style.display =
            "none";
    }

    async function saveArticle() {

        closeSaveModal();

        const payload = {

            title: value("title"),
            slug: value("slug"),
            summary: value("summary"),
            categorySlug: value("articleCategory"),
            tags: value("tags"),
            bodyBlocks: value("bodyMarkdown"),
            level: "Draft",
            focus: "Preview"
        };

        let response;

        if (currentArticleKey) {

            response = await fetch(
                `/api/blog-content/articles/${currentArticleKey}`,
                {
                    method: "PUT",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(payload)
                });
        }
        else {

            response = await fetch(
                "/api/blog-content/articles",
                {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(payload)
                });
        }

        const result =
            await response.json();

        if (result.success) {

            currentArticleKey =
                result.key;

            originalState =
                getCurrentState();

            setDirty(false);

            await loadArticles();

            alert(result.message);
        }
        else {

            alert(result.message);
        }
    }

    function cancelChanges() {

        closeCancelModal();

        if (!originalState) {
            return;
        }

        setValue("title", originalState.title);
        setValue("slug", originalState.slug);
        setValue("summary", originalState.summary);
        setValue("articleCategory", originalState.categorySlug);
        setValue("tags", originalState.tags);
        setValue("bodyMarkdown", originalState.bodyMarkdown);

        setDirty(false);

        sendPreviewUpdate();
    }

    function value(id) {

        return document.getElementById(id).value;
    }

    function setValue(id, value) {

        document.getElementById(id).value =
            value ?? "";
    }

    function selectedText(id) {

        const select =
            document.getElementById(id);

        return select.options[select.selectedIndex]?.text ?? "";
    }
</script>

</body>
</html>
