@{
    Layout = null;

    var previewUrl =
        (string)(ViewData["PreviewUrl"]
            ?? "https://localhost:7252/preview/article");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Article editor</title>
    <link rel="stylesheet" href="/css/blog-admin-rich-table-editor.css" />

    <style>
            * {
                box-sizing: border-box;
            }

            :root {
                --article-editor-sidebar-width: 520px;
                --article-editor-sidebar-min-width: 360px;
                --article-editor-preview-min-width: 420px;
                --article-editor-splitter-width: 10px;
            }

            body {
                margin: 0;
                overflow: hidden;
                font-family: Inter, Arial, sans-serif;
                background: #061325;
                color: #f5f7fb;
            }

                body.resizing {
                    cursor: col-resize;
                    user-select: none;
                }

                    body.resizing iframe {
                        pointer-events: none;
                    }

            .layout {
                display: flex;
                height: 100vh;
                width: 100vw;
                overflow: hidden;
            }

            .sidebar {
                flex: 0 0 var(--article-editor-sidebar-width);
                min-width: var(--article-editor-sidebar-min-width);
                overflow-y: auto;
                background: #06152b;
                border-right: 1px solid #29405f;
            }

            .sidebar-header {
                padding: 20px 20px 0 20px;
            }

            h1 {
                margin: 0 0 18px 0;
                font-size: 28px;
            }

            .editor-tabs {
                display: flex;
                gap: 0;
                border-bottom: 1px solid #29405f;
                padding: 0 20px;
                background: #071a33;
            }

            .editor-tab {
                border: 0;
                border-bottom: 3px solid transparent;
                background: transparent;
                color: #c8d8ef;
                padding: 15px 18px 12px 18px;
                font: inherit;
                font-weight: 800;
                cursor: pointer;
            }

                .editor-tab:hover,
                .editor-tab.active {
                    color: white;
                    border-bottom-color: #84bbff;
                    background: rgba(255, 255, 255, 0.04);
                }

            .tab-panel {
                display: none;
                padding: 20px;
            }

                .tab-panel.active {
                    display: block;
                }

            .field-label {
                display: block;
                margin-top: 26px;
                margin-bottom: 10px;
                color: #84bbff;
                font-weight: 800;
                font-size: 13px;
                letter-spacing: 1px;
                text-transform: uppercase;
            }

                .field-label:first-of-type {
                    margin-top: 0;
                }

            input,
            textarea,
            select {
                width: 100%;
                border-radius: 10px;
                border: 1px solid #35527a;
                background: #020b18;
                color: white;
                padding: 12px;
                font-size: 15px;
            }

            textarea {
                min-height: 150px;
                resize: vertical;
            }

            input[readonly] {
                color: #b9d5f5;
                background: #071a33;
                border-color: #29405f;
                cursor: not-allowed;
            }

            #bodyMarkdown {
                display: none;
            }

            .block-list {
                display: grid;
                gap: 8px;
            }

            .block-row {
                display: grid;
                grid-template-columns: 30px 34px 1fr auto;
                align-items: center;
                gap: 10px;
                border: 1px solid #35527a;
                border-radius: 8px;
                background: #020b18;
                padding: 10px;
                transition: border-color 160ms ease, background 160ms ease, box-shadow 160ms ease, opacity 160ms ease, transform 160ms ease;
            }

                .block-row[draggable="true"] {
                    cursor: grab;
                }

                    .block-row[draggable="true"]:active {
                        cursor: grabbing;
                    }

                .block-row:hover {
                    border-color: #84bbff;
                    background: #04152b;
                    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.24);
                }

                .block-row.dragging {
                    opacity: 0.45;
                    transform: scale(0.985);
                    border-color: #84bbff;
                    box-shadow: 0 0 0 2px rgba(132, 187, 255, 0.20);
                }

                .block-row.drag-over-before {
                    box-shadow: 0 -3px 0 #35d07f, 0 8px 22px rgba(0, 0, 0, 0.24);
                }

                .block-row.drag-over-after {
                    box-shadow: 0 3px 0 #35d07f, 0 8px 22px rgba(0, 0, 0, 0.24);
                }

                .block-row.just-moved {
                    animation: blockMovedPulse 720ms ease-out;
                }

            @@keyframes blockMovedPulse {
                0% {
                    border-color: #35d07f;
                    box-shadow: 0 0 0 0 rgba(53, 208, 127, 0.45);
                }

                50% {
                    border-color: #35d07f;
                    box-shadow: 0 0 0 5px rgba(53, 208, 127, 0.18);
                }

                100% {
                    border-color: #35527a;
                    box-shadow: none;
                }
            }

            .block-drag-handle {
                width: 28px;
                height: 30px;
                display: grid;
                place-items: center;
                border: 1px solid rgba(132, 187, 255, 0.22);
                border-radius: 8px;
                background: rgba(132, 187, 255, 0.08);
                color: #9ecbff;
                cursor: grab;
                font-size: 18px;
                line-height: 1;
                user-select: none;
            }

                .block-drag-handle:hover {
                    background: rgba(132, 187, 255, 0.18);
                    color: #ffffff;
                }

                .block-drag-handle:active {
                    cursor: grabbing;
                }

            .block-icon {
                width: 28px;
                height: 28px;
                display: grid;
                place-items: center;
                color: #d7eaff;
                font-weight: 900;
                font-size: 14px;
            }

            .block-document-type-icon {
                border-radius: 8px;
                border: 1px solid #35527a;
                background: linear-gradient(180deg, rgba(132, 187, 255, 0.22), rgba(22, 119, 255, 0.10));
            }

            .block-title {
                font-weight: 800;
                color: #f5f7fb;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .block-actions {
                display: inline-flex;
                align-items: center;
                gap: 4px;
            }

            .icon-button {
                width: 30px;
                height: 30px;
                border: 0;
                border-radius: 8px;
                background: rgba(132, 187, 255, 0.12);
                color: #d7eaff;
                cursor: pointer;
                font-weight: 900;
            }

                .icon-button:hover {
                    background: rgba(132, 187, 255, 0.22);
                }

                .icon-button.danger:hover {
                    background: rgba(208, 56, 77, 0.3);
                }

                .icon-button:disabled {
                    opacity: 0.35;
                    cursor: not-allowed;
                }

            .add-content {
                width: 100%;
                margin-top: 10px;
                border: 1px dashed #5f7fa8;
                border-radius: 8px;
                background: rgba(132, 187, 255, 0.06);
                color: #d7eaff;
                padding: 12px;
                font-weight: 800;
                cursor: pointer;
            }

                .add-content:hover {
                    background: rgba(132, 187, 255, 0.14);
                }

            .block-catalog-modal {
                width: min(760px, 100%);
            }

            .block-catalog-intro {
                margin: 0 0 18px 0;
                color: #c8d8ef;
                line-height: 1.5;
            }

            .block-catalog-grid {
                display: grid;
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: 14px;
                margin-top: 14px;
            }

            .block-type-card {
                min-height: 150px;
                display: grid;
                grid-template-rows: 1fr auto;
                border: 1px solid #35527a;
                border-radius: 10px;
                overflow: hidden;
                background: #ffffff;
                color: #111827;
                cursor: pointer;
                text-align: left;
                padding: 0;
                box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
            }

                .block-type-card:hover,
                .block-type-card:focus-visible {
                    border-color: #84bbff;
                    box-shadow: 0 0 0 3px rgba(132, 187, 255, 0.18), 0 8px 24px rgba(0, 0, 0, 0.28);
                    outline: none;
                    transform: translateY(-1px);
                }

            .block-type-icon-area {
                min-height: 108px;
                display: grid;
                place-items: center;
                background: #f3f4f6;
                color: #111827;
                font-size: 30px;
                font-weight: 900;
            }

            .block-type-name {
                padding: 12px 14px;
                color: #0b2350;
                background: #ffffff;
                font-size: 13px;
                font-weight: 800;
            }

            @@media (max-width: 720px) {
                .block-catalog-grid {
                    grid-template-columns: 1fr;
                }
            }


            .diagram-title-field {
                display: none;
                margin-bottom: 14px;
            }

                .diagram-title-field.active {
                    display: block;
                }

                .diagram-title-field .field-label {
                    margin-top: 0;
                }

                .diagram-title-field small {
                    display: block;
                    margin-top: 8px;
                    color: #90a9ca;
                    font-size: 12px;
                    line-height: 1.4;
                }

            .splitter {
                flex: 0 0 var(--article-editor-splitter-width);
                width: var(--article-editor-splitter-width);
                cursor: col-resize;
                background: #11243e;
                border-left: 1px solid #29405f;
                border-right: 1px solid #29405f;
                position: relative;
                touch-action: none;
            }

                .splitter::after {
                    content: "";
                    position: absolute;
                    top: 50%;
                    left: 50%;
                    width: 3px;
                    height: 64px;
                    border-radius: 999px;
                    background: #5f7fa8;
                    transform: translate(-50%, -50%);
                    opacity: 0.8;
                }

                .splitter:hover,
                body.resizing .splitter {
                    background: #17365d;
                }

            .preview-area {
                flex: 1 1 auto;
                min-width: var(--article-editor-preview-min-width);
                padding: 18px;
                background: radial-gradient(circle at top, #103b69, #04111d);
            }

            iframe {
                width: 100%;
                height: calc(100vh - 36px);
                border: 0;
                border-radius: 18px;
                background: white;
            }

            .modal-backdrop {
                position: fixed;
                inset: 0;
                display: none;
                align-items: center;
                justify-content: center;
                padding: 24px;
                background: rgba(0, 0, 0, 0.72);
                z-index: 10000;
            }

            .modal {
                width: min(620px, 100%);
                border: 1px solid #48678f;
                border-radius: 18px;
                background: #0d1d35;
                padding: 22px;
                box-shadow: 0 24px 80px rgba(0, 0, 0, 0.5);
            }

                .modal h2 {
                    margin: 0 0 14px 0;
                }

            .modal-actions {
                display: flex;
                justify-content: flex-end;
                gap: 10px;
                margin-top: 16px;
            }

            .modal-header {
                display: flex;
                align-items: flex-start;
                gap: 14px;
            }

            .modal-icon {
                width: 42px;
                height: 42px;
                display: grid;
                place-items: center;
                border-radius: 14px;
                font-size: 20px;
                font-weight: 900;
                flex: 0 0 auto;
            }

                .modal-icon.danger {
                    background: rgba(244, 63, 94, 0.18);
                    color: #fecdd3;
                    border: 1px solid rgba(244, 63, 94, 0.42);
                }

                .modal-icon.success {
                    background: rgba(34, 197, 94, 0.18);
                    color: #bbf7d0;
                    border: 1px solid rgba(34, 197, 94, 0.42);
                }

                .modal-icon.info {
                    background: rgba(132, 187, 255, 0.18);
                    color: #d7eaff;
                    border: 1px solid rgba(132, 187, 255, 0.42);
                }

            .modal-copy {
                flex: 1 1 auto;
            }

                .modal-copy h2 {
                    margin: 0 0 8px 0;
                }

                .modal-copy p {
                    margin: 0;
                    color: #c8d8ef;
                    line-height: 1.55;
                }

            .btn-danger {
                background: #dc3354;
            }

            .btn-success {
                background: #159957;
            }

            .btn {
                border: 0;
                border-radius: 10px;
                padding: 11px 14px;
                background: #1677ff;
                color: white;
                font-weight: 800;
                cursor: pointer;
            }

            .btn-secondary {
                background: #2d4463;
            }

            .editor-option-card {
                border: 1px solid rgba(132, 187, 255, 0.28);
                border-radius: 12px;
                background: linear-gradient(180deg, rgba(132, 187, 255, 0.10), rgba(22, 119, 255, 0.05));
                padding: 12px;
                margin-bottom: 14px;
            }

            .toggle-row {
                display: flex;
                align-items: flex-start;
                gap: 12px;
                cursor: pointer;
            }

                .toggle-row input {
                    width: auto;
                    margin-top: 3px;
                    accent-color: #35d07f;
                }

                .toggle-row strong {
                    display: block;
                    color: #f5f7fb;
                    font-size: 14px;
                }

                .toggle-row small {
                    display: block;
                    margin-top: 4px;
                    color: #a9bdd8;
                    line-height: 1.4;
                }

            .editor-toast {
                display: none;
                margin-bottom: 14px;
                border: 1px solid rgba(53, 208, 127, 0.45);
                border-radius: 12px;
                background: rgba(53, 208, 127, 0.12);
                color: #bbf7d0;
                padding: 11px 12px;
                font-weight: 800;
                box-shadow: 0 10px 28px rgba(0, 0, 0, 0.22);
            }

                .editor-toast.visible {
                    display: block;
                    animation: plantUmlToastPulse 720ms ease-out;
                }

            @@keyframes plantUmlToastPulse {
                0% {
                    transform: translateY(-4px);
                    opacity: 0;
                }

                100% {
                    transform: translateY(0);
                    opacity: 1;
                }
            }
    </style>
</head>

<body>
    <div class="layout">
        <div class="sidebar" id="editorSidebar">
            <div class="sidebar-header">
                <h1>Article editor</h1>
            </div>

            <nav class="editor-tabs">
                <button id="contentTabButton" class="editor-tab active" type="button" onclick="showEditorTab('content')">Content</button>
                <button id="bodyTabButton" class="editor-tab" type="button" onclick="showEditorTab('body')">Body</button>
            </nav>

            <section id="contentTabPanel" class="tab-panel active">
                <label class="field-label" for="title">Title</label>
                <input id="title" type="text" />

                <label class="field-label" for="slug">Slug</label>
                <input id="slug" type="text" />

                <label class="field-label" for="summary">Summary</label>
                <textarea id="summary"></textarea>

                <label class="field-label" for="dotnetZone">Dotnet Zone</label>
                <select id="dotnetZone"></select>

                <label class="field-label" for="dotnetZoneStep">Dotnet Zone Step</label>
                <select id="dotnetZoneStep"></select>

                <label class="field-label" for="order">Order in selected step</label>
                <input id="order" type="number" min="1" step="1" readonly />

                <label class="field-label" for="tags">Tags comma-separated</label>
                <input id="tags" type="text" />
            </section>

            <section id="bodyTabPanel" class="tab-panel">
                <textarea id="bodyMarkdown"></textarea>
                <div class="editor-option-card">
                    <label class="toggle-row" for="autoCorrectPlantUmlSkinparams">
                        <input id="autoCorrectPlantUmlSkinparams" type="checkbox" checked />
                        <span>
                            <strong>Automatically correct PlantUML when saved</strong>
                            <small>Removes block-level skinparams and comments out PlantUML title lines that would duplicate the block title.</small>
                        </span>
                    </label>
                </div>

                <div id="plantUmlCorrectionToast" class="editor-toast" aria-live="polite">
                    ✓ PlantUML was autocorrected to use the article theme.
                </div>
                <div id="bodyBlocksList" class="block-list"></div>
                <button class="add-content" type="button" onclick="openBlockTypePicker()">Add content</button>
            </section>
        </div>

        <div id="paneSplitter"
             class="splitter"
             role="separator"
             aria-orientation="vertical"
             aria-label="Resize article editor panes">
        </div>

        <div class="preview-area">
            <iframe id="previewFrame"
                    src="@previewUrl"
                    onload="onPreviewFrameLoaded()">
            </iframe>
        </div>
    </div>

    <div id="blockTypePickerModal" class="modal-backdrop">
        <div class="modal block-catalog-modal">
            <h2>Add content</h2>
            <p class="block-catalog-intro">Choose the block type you want to add to the article body.</p>

            <div id="blockTypePickerGrid" class="block-catalog-grid"></div>

            <div class="modal-actions">
                <button class="btn btn-secondary" type="button" onclick="closeBlockTypePicker()">Close</button>
            </div>
        </div>
    </div>

    <div id="blockEditModal" class="modal-backdrop">
        <div class="modal">
            <h2 id="blockEditTitle">Edit block</h2>

            <div id="blockTitleField" class="diagram-title-field">
                <label id="blockEditTitleInputLabel" class="field-label" for="blockEditBlockTitle">Block title</label>
                <input id="blockEditBlockTitle" type="text" maxlength="120" placeholder="Example: Program.cs" />
                <small id="blockEditTitleHelp">This title is shown above the block content in the article.</small>
            </div>

            <div id="blockTitleBarField" class="diagram-title-field">
                <label class="toggle-row" for="blockEditShowTitleBar">
                    <input id="blockEditShowTitleBar" type="checkbox" checked />
                    <span>
                        <strong id="blockEditShowTitleBarText">Show title bar</strong>
                        <small id="blockEditShowTitleBarHelp">Turn this off when the content should start immediately inside the rounded panel.</small>
                    </span>
                </label>
            </div>

            <label id="blockEditTextLabel" class="field-label" for="blockEditText">Content</label>
            <textarea id="blockEditText"></textarea>

            <div class="modal-actions">
                <button class="btn btn-secondary" type="button" onclick="closeBlockEditor()">Cancel</button>
                <button class="btn" type="button" onclick="saveBlockEditor()">Save block</button>
            </div>
        </div>
    </div>

    <div id="deleteBodyBlockModal" class="modal-backdrop">
        <div class="modal">
            <div class="modal-header">
                <div class="modal-icon danger">!</div>
                <div class="modal-copy">
                    <h2>Delete body block?</h2>
                    <p>
                        This block will be removed from the article body. You can still choose Cancel and keep editing safely.
                    </p>
                </div>
            </div>

            <div class="modal-actions">
                <button class="btn btn-secondary" type="button" onclick="closeDeleteBodyBlockModal()">Cancel</button>
                <button class="btn btn-danger" type="button" onclick="confirmDeleteBodyBlock()">Delete block</button>
            </div>
        </div>
    </div>

    <div id="editorFeedbackModal" class="modal-backdrop">
        <div class="modal">
            <div class="modal-header">
                <div id="editorFeedbackIcon" class="modal-icon info">i</div>
                <div class="modal-copy">
                    <h2 id="editorFeedbackTitle">Message</h2>
                    <p id="editorFeedbackMessage"></p>
                </div>
            </div>

            <div class="modal-actions">
                <button class="btn" type="button" onclick="closeEditorFeedbackModal()">OK</button>
            </div>
        </div>
    </div>

    <script>
            const sidebarWidthStorageKey = "blogArticleEditor.sidebarWidth";
            const defaultSidebarWidth = 520;
            const minSidebarWidth = 360;
            const minPreviewWidth = 420;

            let currentArticleKey = null;
            let currentLevel = "Draft";
            let currentFocus = "Preview";
            let originalState = null;
            let isDirty = false;
            let sendSequence = 0;
            let previewFrameLoaded = false;
            let bodyBlocks = [];
            let editedBlockIndex = null;
            let draggedBodyBlockIndex = null;
            let lastMovedBodyBlockUdi = null;
            let pendingDeleteBodyBlockIndex = null;

            const availableBlockTypes = [
                {
                    type: "text",
                    name: "Text Block",
                    alias: "textBlock",
                    icon: "📝",
                    create: () => ({
                        udi: createElementUdi(),
                        type: "text",
                        text: "New text block"
                    })
                },
                {
                    type: "heading",
                    name: "Heading Block",
                    alias: "headingBlock",
                    icon: "H1",
                    create: () => ({
                        udi: createElementUdi(),
                        type: "heading",
                        text: "New heading",
                        level: 2
                    })
                },
                {
                    type: "code",
                    name: "Code Snippet Block",
                    alias: "codeSnippetBlock",
                    icon: "&lt;/&gt;",
                    create: () => ({
                        udi: createElementUdi(),
                        type: "code",
                        language: "csharp",
                        fileName: "Program.cs",
                        codeTitle: "Program.cs",
                        showCodeTitleBar: true,
                        code: "// Add your code snippet here"
                    })
                },
                {
                    type: "mermaid",
                    name: "Mermaid Diagram Block",
                    alias: "mermaidDiagramBlock",
                    icon: "🔀",
                    create: () => ({
                        udi: createElementUdi(),
                        type: "mermaid",
                        title: "Mermaid diagram",
                        showDiagramTitleBar: true,
                        diagram: "flowchart TD\n    A[Start] --> B[Next step]",
                        mermaid: "flowchart TD\n    A[Start] --> B[Next step]"
                    })
                },
                {
                    type: "plantuml",
                    name: "PlantUML Diagram Block",
                    alias: "plantUmlDiagramBlock",
                    icon: "🌱",
                    create: () => ({
                        udi: createElementUdi(),
                        type: "plantuml",
                        title: "PlantUML diagram",
                        showDiagramTitleBar: true,
                        plantUml: "@@startuml\nactor User\nUser -> System: Request\n@enduml"
                    })
                },
                {
                    type: "callout",
                    name: "Callout Block",
                    alias: "calloutBlock",
                    icon: "⚠️",
                    create: () => ({
                        udi: createElementUdi(),
                        type: "callout",
                        calloutType: "tip",
                        text: "New callout block"
                    })
                },
                {
                    type: "summary",
                    name: "Summary Block",
                    alias: "summaryBlock",
                    icon: "📌",
                    create: () => ({
                        udi: createElementUdi(),
                        type: "summary",
                        summary: "Short article summary"
                    })
                },
                {
                    type: "table",
                    name: "Table Block",
                    alias: "tableBlock",
                    icon: "▦",
                    create: () => ({
                        udi: createElementUdi(),
                        type: "table",
                        tableStyle: "dense-engineering",
                        hasHeaderRow: true,
                        hasHeaderColumn: false,
                        autoNumberRows: false,
                        defaultHorizontalAlignment: "left",
                        defaultVerticalAlignment: "middle",
                        rows: createEmptyTableRows(3, 3)
                    })
                }
            ];

            let dotnetRoadmap = [];
            let dotnetZones = [];
            let dotnetZoneSteps = [];

            const frame = document.getElementById("previewFrame");

            const fieldIds = [
                "title",
                "slug",
                "summary",
                "dotnetZone",
                "dotnetZoneStep",
                "order",
                "tags",
                "bodyMarkdown"
            ];

            window.addEventListener("message", onParentMessage);

            document.addEventListener("DOMContentLoaded", async () => {
                initializeResizablePanes();

                await loadDotnetRoadmapOptions();

                attachFieldListeners();

                const articleKey = getRequestedArticleKey();
                const copyArticleKey = getRequestedCopyArticleKey();

                if (copyArticleKey) {
                    await loadArticleCopy(copyArticleKey);
                }
                else if (articleKey) {
                    await loadExistingArticle(articleKey);
                }
                else {
                    await createNewArticle();
                }

                renderBodyBlocks();
                sendPreviewUpdate();
            });

            function showEditorTab(tab) {
                document.getElementById("contentTabButton").classList.toggle("active", tab === "content");
                document.getElementById("bodyTabButton").classList.toggle("active", tab === "body");
                document.getElementById("contentTabPanel").classList.toggle("active", tab === "content");
                document.getElementById("bodyTabPanel").classList.toggle("active", tab === "body");
            }

            function initializeResizablePanes() {
                const splitter = document.getElementById("paneSplitter");
                const savedWidth = Number(localStorage.getItem(sidebarWidthStorageKey));

                setSidebarWidth(Number.isFinite(savedWidth) && savedWidth > 0 ? savedWidth : defaultSidebarWidth);

                splitter.addEventListener("pointerdown", startPaneResize);

                splitter.addEventListener("dblclick", () => {
                    setSidebarWidth(defaultSidebarWidth);
                    localStorage.setItem(sidebarWidthStorageKey, defaultSidebarWidth.toString());
                });

                window.addEventListener("resize", () => {
                    setSidebarWidth(getCurrentSidebarWidth());
                });
            }

            function startPaneResize(event) {
                event.preventDefault();

                const splitter = document.getElementById("paneSplitter");

                splitter.setPointerCapture(event.pointerId);
                document.body.classList.add("resizing");

                const onPointerMove = moveEvent => {
                    setSidebarWidth(moveEvent.clientX);
                };

                const onPointerUp = upEvent => {
                    splitter.releasePointerCapture(upEvent.pointerId);
                    document.body.classList.remove("resizing");

                    localStorage.setItem(
                        sidebarWidthStorageKey,
                        getCurrentSidebarWidth().toString());

                    window.removeEventListener("pointermove", onPointerMove);
                    window.removeEventListener("pointerup", onPointerUp);
                    window.removeEventListener("pointercancel", onPointerUp);
                };

                window.addEventListener("pointermove", onPointerMove);
                window.addEventListener("pointerup", onPointerUp);
                window.addEventListener("pointercancel", onPointerUp);
            }

            function setSidebarWidth(requestedWidth) {
                const maxSidebarWidth =
                    Math.max(
                        minSidebarWidth,
                        window.innerWidth - minPreviewWidth);

                const width =
                    Math.min(
                        Math.max(requestedWidth, minSidebarWidth),
                        maxSidebarWidth);

                document.documentElement.style.setProperty(
                    "--article-editor-sidebar-width",
                    `${width}px`);
            }

            function getCurrentSidebarWidth() {
                const sidebar = document.getElementById("editorSidebar");

                return Math.round(sidebar.getBoundingClientRect().width);
            }

            function getRequestedArticleKey() {
                const parameters = new URLSearchParams(window.location.search);

                return parameters.get("articleKey");
            }

            function getRequestedCopyArticleKey() {
                const parameters = new URLSearchParams(window.location.search);

                return parameters.get("copyArticleKey");
            }

            function onPreviewFrameLoaded() {
                previewFrameLoaded = true;

                console.log("[LIVE_PREVIEW] iframe loaded:", frame.src);

                setTimeout(sendPreviewUpdate, 250);
                setTimeout(sendPreviewUpdate, 750);
                setTimeout(sendPreviewUpdate, 1500);
            }

            async function loadDotnetRoadmapOptions() {
                const response = await fetch("/api/blog-content/dotnet-roadmap");

                if (!response.ok) {
                    console.error("[ARTICLE_EDITOR] failed to load dotnet roadmap:", response.status);
                    dotnetRoadmap = [];
                    dotnetZones = [];
                    dotnetZoneSteps = [];
                    return;
                }

                dotnetRoadmap = await response.json();
                dotnetZones = dotnetRoadmap.map(zone => ({
                    key: zone.key,
                    name: zone.name
                }));
                dotnetZoneSteps = dotnetRoadmap.flatMap(zone =>
                    zone.steps.map(step => ({
                        key: step.key,
                        name: step.name,
                        zoneKey: zone.key
                    })));

                fillSelect("dotnetZone", dotnetZones);
                fillStepSelectForZone(value("dotnetZone"));

                document.getElementById("dotnetZone").addEventListener("change", async () => {
                    fillStepSelectForZone(value("dotnetZone"));
                    await refreshSuggestedArticleOrder();
                    onEditorChanged();
                });

                document.getElementById("dotnetZoneStep").addEventListener("change", async () => {
                    await refreshSuggestedArticleOrder();
                    onEditorChanged();
                });
            }

            function fillSelect(id, items) {
                const select = document.getElementById(id);

                select.innerHTML = "";

                for (const item of items) {
                    select.innerHTML += `
                        <option value="${escapeHtml(item.key)}">
                            ${escapeHtml(item.name)}
                        </option>
                    `;
                }
            }

            function fillStepSelectForZone(zoneKey) {
                const currentStep = value("dotnetZoneStep");
                const zone = dotnetRoadmap.find(item => item.key === zoneKey);
                const steps = zone?.steps ?? [];

                fillSelect("dotnetZoneStep", steps);

                if (steps.some(step => step.key === currentStep)) {
                    setValue("dotnetZoneStep", currentStep);
                }
            }

            function getFirstStepKey(zoneKey) {
                const zone = dotnetRoadmap.find(item => item.key === zoneKey);

                return zone?.steps[0]?.key || "";
            }


            async function refreshSuggestedArticleOrder() {
                const zone = value("dotnetZone");
                const step = value("dotnetZoneStep");

                if (!zone || !step) {
                    setValue("order", "");
                    return;
                }

                const parameters = new URLSearchParams({
                    zone,
                    step
                });

                if (currentArticleKey) {
                    parameters.set("excludeArticleKey", currentArticleKey);
                }

                const response = await fetch(`/api/blog-content/articles/next-order?${parameters.toString()}`);

                if (!response.ok) {
                    console.error("[ARTICLE_EDITOR] failed to load next article order:", response.status);
                    return;
                }

                const nextOrder = await response.json();
                setValue("order", nextOrder?.toString?.() || "1");
            }

            async function loadExistingArticle(articleKey) {
                const response =
                    await fetch(`/api/blog-content/articles/${encodeURIComponent(articleKey)}`);

                if (!response.ok) {
                    console.error(
                        "[ARTICLE_EDITOR] failed to load article:",
                        articleKey,
                        response.status);

                    return;
                }

                const article = await response.json();

                populateArticle(article);

                originalState = getCurrentState();

                setDirty(false);

                notifyParent(false);
                sendPreviewUpdate();
            }

            function populateArticle(article) {
                currentArticleKey = article.key;
                currentLevel = article.level || "Draft";
                currentFocus = article.focus || "Preview";

                setValue("title", article.title);
                setValue("slug", article.slug);
                setValue("summary", article.summary);
                setValue("dotnetZone", article.dotnetZone || dotnetZones[0]?.key || "");
                fillStepSelectForZone(value("dotnetZone"));
                setValue("dotnetZoneStep", article.dotnetZoneStep || getFirstStepKey(value("dotnetZone")));
                setValue("order", article.order || 1);
                setValue("tags", article.tags);
                setValue("bodyMarkdown", article.bodyBlocks);

                bodyBlocks = readBodyBlocksFromBodyMarkdown();
                renderBodyBlocks();
            }

            async function loadArticleCopy(articleKey) {
                const response =
                    await fetch(`/api/blog-content/articles/${encodeURIComponent(articleKey)}`);

                if (!response.ok) {
                    console.error(
                        "[ARTICLE_EDITOR] failed to load source article for copy:",
                        articleKey,
                        response.status);

                    await createNewArticle();

                    showEditorFeedbackModal(
                        "Article copy could not be prepared",
                        "The source article could not be loaded. A clean new article was opened instead.",
                        "danger");

                    return;
                }

                const article = await response.json();

                populateArticleCopy(article);

                originalState = getCurrentState();

                setDirty(true);

                notifyParent(false);
                sendPreviewUpdate();
            }

            function populateArticleCopy(article) {
                currentArticleKey = null;
                currentLevel = article.level || "Draft";
                currentFocus = article.focus || "Preview";

                const sourceTitle = article.title || "Untitled article";

                setValue("title", `Copy of ${sourceTitle}`);
                setValue("slug", createCopySlug(article.slug || sourceTitle));
                setValue("summary", article.summary);
                setValue("dotnetZone", article.dotnetZone || dotnetZones[0]?.key || "");
                fillStepSelectForZone(value("dotnetZone"));
                setValue("dotnetZoneStep", article.dotnetZoneStep || getFirstStepKey(value("dotnetZone")));
                setValue("order", article.order || 1);
                setValue("tags", article.tags);
                setValue("bodyMarkdown", cloneBodyBlocksJson(article.bodyBlocks));

                bodyBlocks = readBodyBlocksFromBodyMarkdown();
                renderBodyBlocks();

                refreshSuggestedArticleOrder();
            }

            function createCopySlug(source) {
                const baseSlug = (source || "article")
                    .toString()
                    .trim()
                    .toLowerCase()
                    .replace(/[^a-z0-9]+/g, "-")
                    .replace(/^-+|-+$/g, "") || "article";

                return `copy-of-${baseSlug}`;
            }

            function cloneBodyBlocksJson(bodyBlocksJson) {
                if (!isValidBlockListJson(bodyBlocksJson)) {
                    return bodyBlocksJson || "";
                }

                const parsed = JSON.parse(bodyBlocksJson);
                const udiMap = new Map();

                parsed.contentData = (parsed.contentData || []).map(item => {
                    const oldUdi = item.udi;
                    const newUdi = createElementUdi();

                    if (oldUdi) {
                        udiMap.set(oldUdi, newUdi);
                    }

                    return {
                        ...item,
                        udi: newUdi
                    };
                });

                const blockList = parsed.layout?.["Umbraco.BlockList"] || [];

                for (const layoutItem of blockList) {
                    if (layoutItem.contentUdi && udiMap.has(layoutItem.contentUdi)) {
                        layoutItem.contentUdi = udiMap.get(layoutItem.contentUdi);
                    }
                }

                return JSON.stringify(parsed, null, 2);
            }

            async function createNewArticle() {
                currentArticleKey = null;
                currentLevel = "Draft";
                currentFocus = "Preview";

                setValue("title", "Example article title");
                setValue("slug", "example-article");
                setValue("summary", "Short article summary.");
                setValue("dotnetZone", dotnetZones[0]?.key || "");
                fillStepSelectForZone(value("dotnetZone"));
                setValue("dotnetZoneStep", getFirstStepKey(value("dotnetZone")));
                await refreshSuggestedArticleOrder();
                setValue("tags", ".NET, Architecture, Azure");

                bodyBlocks = [
                    {
                        udi: createElementUdi(),
                        type: "heading",
                        text: "First heading",
                        level: 2
                    },
                    {
                        udi: createElementUdi(),
                        type: "text",
                        text: "This is the first paragraph."
                    },
                    {
                        udi: createElementUdi(),
                        type: "code",
                        language: "csharp",
                        fileName: "Example.cs",
                        code: "public sealed class Example\n{\n    public string Name { get; set; } = string.Empty;\n}"
                    }
                ];

                syncBodyMarkdownFromBlocks();

                originalState = getCurrentState();

                setDirty(false);

                notifyParent(false);
                sendPreviewUpdate();
            }

            function attachFieldListeners() {
                for (const fieldId of fieldIds) {
                    const field = document.getElementById(fieldId);

                    field.addEventListener("input", onEditorChanged);
                    field.addEventListener("change", onEditorChanged);
                }
            }

            function onEditorChanged() {
                if (document.activeElement?.id === "bodyMarkdown") {
                    bodyBlocks = readBodyBlocksFromBodyMarkdown();
                    renderBodyBlocks();
                }

                const changed =
                    JSON.stringify(getCurrentState()) !==
                    JSON.stringify(originalState);

                setDirty(changed);

                sendPreviewUpdate();
            }

            function getCurrentState() {
                return {
                    title: value("title"),
                    slug: value("slug"),
                    summary: value("summary"),
                    dotnetZone: value("dotnetZone"),
                    dotnetZoneStep: value("dotnetZoneStep"),
                    order: parseArticleOrder(),
                    tags: value("tags"),
                    bodyMarkdown: value("bodyMarkdown"),
                    level: currentLevel,
                    focus: currentFocus
                };
            }

            function sendPreviewUpdate() {
                sendSequence++;

                const article = {
                    slug: value("slug"),
                    title: value("title"),
                    summary: value("summary"),
                    level: currentLevel,
                    focus: currentFocus,
                    dotnetZone: value("dotnetZone"),
                    dotnetZoneStep: value("dotnetZoneStep"),
                    order: parseArticleOrder(),
                    tags:
                        value("tags")
                            .split(",")
                            .map(x => x.trim())
                            .filter(Boolean),
                    publishedDate: null,
                    bodyHtml: getBodyBlocksForPreview()
                };

                try {
                    frame.contentWindow.postMessage({
                        type: "BLOG_ARTICLE_PREVIEW",
                        sequence: sendSequence,
                        article
                    }, "*");

                    console.log(
                        "[LIVE_PREVIEW] message sent:",
                        sendSequence,
                        article.title);
                }
                catch (error) {
                    console.error(
                        "[LIVE_PREVIEW] failed to send preview message:",
                        error);
                }
            }

            function getBodyBlocksForPreview() {
                return value("bodyMarkdown");
            }

            function getBodyBlocksForSave() {
                return value("bodyMarkdown");
            }

            function readBodyBlocksFromBodyMarkdown() {
                const body = value("bodyMarkdown");

                if (isValidBlockListJson(body)) {
                    const parsed = JSON.parse(body);

                    return parsed.contentData.map((item, index) => ({
                        ...item,
                        udi: item.udi || parsed.layout["Umbraco.BlockList"][index]?.contentUdi || createElementUdi(),
                        type: getBlockType(item)
                    }));
                }

                return parseMarkdownBlocks(body).map(block => ({
                    ...block,
                    udi: createElementUdi(),
                    type: getBlockType(block)
                }));
            }

            function syncBodyMarkdownFromBlocks() {
                const layoutItems = [];
                const contentData = [];

                for (const block of bodyBlocks) {
                    const udi = block.udi || createElementUdi();

                    layoutItems.push({
                        contentUdi: udi
                    });

                    const content = { ...block };
                    content.udi = udi;
                    delete content.type;

                    contentData.push(content);
                }

                setValue("bodyMarkdown", JSON.stringify({
                    layout: {
                        "Umbraco.BlockList": layoutItems
                    },
                    contentData,
                    settingsData: []
                }));
            }

            function renderBodyBlocks() {
                const container = document.getElementById("bodyBlocksList");

                if (!bodyBlocks.length) {
                    container.innerHTML = `
                        <div class="block-row">
                            <div></div>
                            <div class="block-icon block-document-type-icon">◇</div>
                            <div class="block-title">No body blocks yet</div>
                            <div></div>
                        </div>
                    `;

                    return;
                }

                container.innerHTML = bodyBlocks
                    .map((block, index) => `
                        <article class="block-row${block.udi && block.udi === lastMovedBodyBlockUdi ? " just-moved" : ""}"
                                 draggable="true"
                                 data-block-index="${index}"
                                 ondragstart="startBodyBlockDrag(event, ${index})"
                                 ondragover="dragBodyBlockOver(event, ${index})"
                                 ondragleave="clearBodyBlockDropCue(event.currentTarget)"
                                 ondrop="dropBodyBlock(event, ${index})"
                                 ondragend="finishBodyBlockDrag()">
                            <div class="block-drag-handle" title="Drag to reorder" aria-label="Drag to reorder">⋮⋮</div>
                            <div class="block-icon block-document-type-icon" title="${escapeHtml(getBlockDocumentTypeAlias(block))}">${getBlockIcon(block)}</div>
                            <div class="block-title" title="${escapeHtml(getBlockLabel(block))}">${escapeHtml(getBlockLabel(block))}</div>
                            <div class="block-actions">
                                <button class="icon-button" type="button" title="Edit" onclick="openBlockEditor(${index})">✎</button>
                                <button class="icon-button" type="button" title="Copy" onclick="copyBodyBlock(${index})">⧉</button>
                                <button class="icon-button danger" type="button" title="Delete" onclick="deleteBodyBlock(${index})">🗑</button>
                            </div>
                        </article>
                    `)
                    .join("");
            }


            function startBodyBlockDrag(event, index) {
                if (event.target.closest(".block-actions")) {
                    event.preventDefault();
                    return;
                }

                draggedBodyBlockIndex = index;

                event.dataTransfer.effectAllowed = "move";
                event.dataTransfer.setData("text/plain", index.toString());

                const row = event.currentTarget;

                requestAnimationFrame(() => {
                    row.classList.add("dragging");
                });
            }

            function dragBodyBlockOver(event, targetIndex) {
                if (draggedBodyBlockIndex === null || draggedBodyBlockIndex === targetIndex) {
                    return;
                }

                event.preventDefault();
                event.dataTransfer.dropEffect = "move";

                const row = event.currentTarget;
                const isAfter = shouldDropAfter(event, row);

                clearAllBodyBlockDropCues();
                row.classList.toggle("drag-over-before", !isAfter);
                row.classList.toggle("drag-over-after", isAfter);
            }

            function dropBodyBlock(event, targetIndex) {
                event.preventDefault();

                if (draggedBodyBlockIndex === null) {
                    return;
                }

                const row = event.currentTarget;
                const isAfter = shouldDropAfter(event, row);
                let requestedIndex = isAfter ? targetIndex + 1 : targetIndex;

                if (draggedBodyBlockIndex < requestedIndex) {
                    requestedIndex -= 1;
                }

                moveBodyBlock(draggedBodyBlockIndex, requestedIndex);
                finishBodyBlockDrag();
            }

            function finishBodyBlockDrag() {
                draggedBodyBlockIndex = null;
                clearAllBodyBlockDropCues();
            }

            function moveBodyBlock(fromIndex, toIndex) {
                if (!Number.isInteger(fromIndex) || !Number.isInteger(toIndex)) {
                    return;
                }

                if (fromIndex < 0 || fromIndex >= bodyBlocks.length) {
                    return;
                }

                const safeToIndex = Math.max(0, Math.min(toIndex, bodyBlocks.length - 1));

                if (fromIndex === safeToIndex) {
                    return;
                }

                const [movedBlock] = bodyBlocks.splice(fromIndex, 1);
                bodyBlocks.splice(safeToIndex, 0, movedBlock);

                lastMovedBodyBlockUdi = movedBlock.udi || null;

                syncBodyMarkdownFromBlocks();
                renderBodyBlocks();
                onEditorChanged();

                window.setTimeout(() => {
                    lastMovedBodyBlockUdi = null;
                    renderBodyBlocks();
                }, 760);
            }

            function shouldDropAfter(event, row) {
                const rectangle = row.getBoundingClientRect();
                const verticalMiddle = rectangle.top + rectangle.height / 2;

                return event.clientY > verticalMiddle;
            }

            function clearBodyBlockDropCue(row) {
                if (!row) {
                    return;
                }

                row.classList.remove("drag-over-before", "drag-over-after");
            }

            function clearAllBodyBlockDropCues() {
                document
                    .querySelectorAll(".block-row.dragging, .block-row.drag-over-before, .block-row.drag-over-after")
                    .forEach(row => {
                        row.classList.remove("dragging", "drag-over-before", "drag-over-after");
                    });
            }

            function getBlockType(block) {
                if (block.level || block.type === "heading") {
                    return "heading";
                }

                if (block.code || block.language || block.fileName || block.type === "code") {
                    return "code";
                }

                if (
                    block.plantUml ||
                    block.plantuml ||
                    block.type === "plantuml" ||
                    (block.diagram && block.diagram.trimStart().startsWith("@@startuml"))
                ) {
                    return "plantuml";
                }

                if (block.diagram || block.mermaid || block.type === "mermaid") {
                    return "mermaid";
                }

                if (block.calloutType || block.type === "callout") {
                    return "callout";
                }

                if (block.summary || block.type === "summary") {
                    return "summary";
                }

                if (block.rows || block.type === "table") {
                    return "table";
                }

                return "text";
            }

            function getBlockIcon(block) {
                const type = getBlockType(block);

                if (type === "heading") {
                    return "H1";
                }

                if (type === "code") {
                    return "&lt;/&gt;";
                }

                if (type === "mermaid") {
                    return "🔀";
                }

                if (type === "plantuml") {
                    return "🌱";
                }

                if (type === "callout") {
                    return "⚠️";
                }

                if (type === "text") {
                    return "📝";
                }

                if (type === "summary") {
                    return "📌";
                }

                if (type === "table") {
                    return "▦";
                }

                return "◇";
            }

            function getBlockDocumentTypeAlias(block) {
                const type = getBlockType(block);

                if (type === "heading") {
                    return "headingBlock";
                }

                if (type === "code") {
                    return "codeSnippetBlock";
                }

                if (type === "mermaid") {
                    return "mermaidDiagramBlock";
                }

                if (type === "plantuml") {
                    return "plantUmlDiagramBlock";
                }

                if (type === "callout") {
                    return "calloutBlock";
                }

                if (type === "text") {
                    return "textBlock";
                }

                if (type === "summary") {
                    return "summaryBlock";
                }

                if (type === "table") {
                    return "tableBlock";
                }

                return "Unknown block";
            }

            function getDefaultDiagramTitle(type) {
                if (type === "mermaid") {
                    return "Mermaid diagram";
                }

                if (type === "plantuml") {
                    return "PlantUML diagram";
                }

                return "Diagram";
            }

            function getDefaultCodeTitle(block) {
                return block.codeTitle || block.title || block.fileName || block.language || "Code snippet";
            }

            function configureBlockTitleEditor(type, block) {
                const isDiagram = type === "mermaid" || type === "plantuml";
                const isCode = type === "code";
                const supportsTitleBar = isDiagram || isCode;

                document.getElementById("blockTitleField").classList.toggle("active", supportsTitleBar);
                document.getElementById("blockTitleBarField").classList.toggle("active", supportsTitleBar);

                if (!supportsTitleBar) {
                    return;
                }

                const titleInput = document.getElementById("blockEditBlockTitle");
                const titleLabel = document.getElementById("blockEditTitleInputLabel");
                const titleHelp = document.getElementById("blockEditTitleHelp");
                const showTitleBar = document.getElementById("blockEditShowTitleBar");
                const showTitleBarText = document.getElementById("blockEditShowTitleBarText");
                const showTitleBarHelp = document.getElementById("blockEditShowTitleBarHelp");

                if (isCode) {
                    titleLabel.innerText = "Code title";
                    titleInput.placeholder = "Example: Program.cs";
                    titleInput.value = getDefaultCodeTitle(block);
                    titleHelp.innerText = "This title is shown above the code snippet in the article.";
                    showTitleBar.checked = block.showCodeTitleBar !== false;
                    showTitleBarText.innerText = "Show code title bar";
                    showTitleBarHelp.innerText = "Turn this off when the code should start immediately inside the rounded panel.";
                    return;
                }

                titleLabel.innerText = "Diagram title";
                titleInput.placeholder = "Example: Components of the .NET Framework";
                titleInput.value = block.title || block.diagramTitle || getDefaultDiagramTitle(type);
                titleHelp.innerText = "This title is shown above the diagram in the article.";
                showTitleBar.checked = block.showDiagramTitleBar !== false;
                showTitleBarText.innerText = "Show diagram title bar";
                showTitleBarHelp.innerText = "Turn this off when the diagram should start immediately inside the rounded panel.";
            }

            function getBlockLabel(block) {
                const type = getBlockType(block);
                const definition = availableBlockTypes.find(item => item.type === type);

                return definition?.name || "Text Block";
            }

            function openBlockEditor(index) {
                editedBlockIndex = index;
                const block = bodyBlocks[index];
                const type = getBlockType(block);
                const isDiagram = type === "mermaid" || type === "plantuml";

                document.getElementById("blockEditTitle").innerText = `Edit ${getBlockLabel(block)}`;
                configureBlockTitleEditor(type, block);
                document.getElementById("blockEditTextLabel").innerText =
                    isDiagram ? "Diagram source" : type === "code" ? "Code source" : "Content";

                if (type === "code") {
                    document.getElementById("blockEditText").value = block.code || "";
                }
                else {
                    document.getElementById("blockEditText").value =
                        block.text ||
                        block.diagram ||
                        block.mermaid ||
                        block.plantUml ||
                        block.plantuml ||
                        block.summary ||
                        "";
                }

                document.getElementById("blockEditModal").style.display = "flex";
            }

            function closeBlockEditor() {
                editedBlockIndex = null;
                document.getElementById("blockEditModal").style.display = "none";
                document.getElementById("blockTitleField").classList.remove("active");
                document.getElementById("blockTitleBarField").classList.remove("active");
            }

            function saveBlockEditor() {
                if (editedBlockIndex === null) {
                    return;
                }

                const block = bodyBlocks[editedBlockIndex];
                const newValue = document.getElementById("blockEditText").value;
                const newBlockTitle = document.getElementById("blockEditBlockTitle").value.trim();
                const showTitleBar = document.getElementById("blockEditShowTitleBar").checked;
                const type = getBlockType(block);

                if (type === "code") {
                    block.code = newValue;
                    block.codeTitle = newBlockTitle || getDefaultCodeTitle(block);
                    block.showCodeTitleBar = showTitleBar;

                    delete block.title;
                    delete block.diagramTitle;
                    delete block.diagram;
                    delete block.mermaid;
                    delete block.plantUml;
                    delete block.plantuml;
                }
                else if (type === "mermaid") {
                    block.title = newBlockTitle || getDefaultDiagramTitle(type);
                    block.showDiagramTitleBar = showTitleBar;
                    block.diagram = newValue;
                    block.mermaid = newValue;

                    delete block.diagramTitle;
                    delete block.plantUml;
                    delete block.plantuml;
                }
                else if (type === "summary") {
                    block.summary = newValue;

                    delete block.text;
                    delete block.diagram;
                    delete block.diagramTitle;
                    delete block.mermaid;
                    delete block.plantUml;
                    delete block.plantuml;
                    delete block.code;
                    delete block.language;
                    delete block.fileName;
                    delete block.calloutType;
                    delete block.kind;
                }
                else if (type === "plantuml") {
                    const correction = isPlantUmlAutocorrectEnabled()
                        ? autocorrectPlantUmlSource(newValue)
                        : {
                            source: newValue,
                            corrected: false,
                            removedSkinparams: []
                        };

                    block.title = newBlockTitle || getDefaultDiagramTitle(type);
                    block.showDiagramTitleBar = showTitleBar;
                    block.plantUml = correction.source;

                    delete block.diagram;
                    delete block.diagramTitle;
                    delete block.mermaid;
                    delete block.plantuml;

                    if (correction.corrected) {
                        showPlantUmlCorrectionToast(correction.removedSkinparams);
                    }
                }
                else {
                    block.text = newValue;
                }

                syncBodyMarkdownFromBlocks();
                renderBodyBlocks();
                closeBlockEditor();
                onEditorChanged();
            }

            function copyBodyBlock(index) {
                const source = bodyBlocks[index];
                const copy = JSON.parse(JSON.stringify(source));

                copy.udi = createElementUdi();

                bodyBlocks.splice(index + 1, 0, copy);

                syncBodyMarkdownFromBlocks();
                renderBodyBlocks();
                onEditorChanged();
            }

            function deleteBodyBlock(index) {
                pendingDeleteBodyBlockIndex = index;
                document.getElementById("deleteBodyBlockModal").style.display = "flex";
            }

            function closeDeleteBodyBlockModal() {
                pendingDeleteBodyBlockIndex = null;
                document.getElementById("deleteBodyBlockModal").style.display = "none";
            }

            function confirmDeleteBodyBlock() {
                if (pendingDeleteBodyBlockIndex === null) {
                    return;
                }

                bodyBlocks.splice(pendingDeleteBodyBlockIndex, 1);

                closeDeleteBodyBlockModal();
                syncBodyMarkdownFromBlocks();
                renderBodyBlocks();
                onEditorChanged();
            }

            function renderBlockTypePicker() {
                const grid = document.getElementById("blockTypePickerGrid");

                grid.innerHTML = availableBlockTypes
                    .map(blockType => `
                        <button class="block-type-card" type="button" onclick="addBodyBlock('${escapeJs(blockType.type)}')">
                            <span class="block-type-icon-area">${blockType.icon}</span>
                            <span class="block-type-name">${escapeHtml(blockType.name)}</span>
                        </button>
                    `)
                    .join("");
            }

            function openBlockTypePicker() {
                renderBlockTypePicker();
                document.getElementById("blockTypePickerModal").style.display = "flex";
            }

            function closeBlockTypePicker() {
                document.getElementById("blockTypePickerModal").style.display = "none";
            }

            function addBodyBlock(blockType) {
                const definition =
                    availableBlockTypes.find(item => item.type === blockType) ||
                    availableBlockTypes[0];

                bodyBlocks.push(definition.create());

                closeBlockTypePicker();
                syncBodyMarkdownFromBlocks();
                renderBodyBlocks();
                onEditorChanged();
            }

            function isValidBlockListJson(body) {
                if (!body || !body.trim().startsWith("{")) {
                    return false;
                }

                try {
                    const parsed = JSON.parse(body);

                    return Boolean(
                        parsed &&
                        parsed.layout &&
                        parsed.layout["Umbraco.BlockList"] &&
                        Array.isArray(parsed.contentData));
                }
                catch {
                    return false;
                }
            }

            function parseMarkdownBlocks(markdown) {
                const lines = (markdown || "")
                    .replace(/\r\n/g, "\n")
                    .split("\n");

                const blocks = [];
                let paragraphLines = [];
                let insideCodeBlock = false;
                let codeLanguage = "";
                let codeLines = [];

                const flushParagraph = () => {
                    const text = paragraphLines.join(" ").trim();

                    if (text) {
                        blocks.push({
                            text
                        });
                    }

                    paragraphLines = [];
                };

                const flushCode = () => {
                    blocks.push({
                        code: codeLines.join("\n"),
                        language: codeLanguage || "text",
                        fileName: codeLanguage ? `example.${codeLanguage}` : "example.txt",
                        codeTitle: codeLanguage ? `example.${codeLanguage}` : "example.txt",
                        showCodeTitleBar: true
                    });

                    codeLines = [];
                    codeLanguage = "";
                };

                for (const line of lines) {
                    const trimmed = line.trim();

                    if (trimmed.startsWith("```")) {
                        if (insideCodeBlock) {
                            flushCode();
                            insideCodeBlock = false;
                        }
                        else {
                            flushParagraph();
                            insideCodeBlock = true;
                            codeLanguage = trimmed.replace("```", "").trim();
                            codeLines = [];
                        }

                        continue;
                    }

                    if (insideCodeBlock) {
                        codeLines.push(line);
                        continue;
                    }

                    if (trimmed.startsWith("#### ")) {
                        flushParagraph();

                        blocks.push({
                            text: trimmed.substring(5).trim(),
                            level: 4
                        });

                        continue;
                    }

                    if (trimmed.startsWith("### ")) {
                        flushParagraph();

                        blocks.push({
                            text: trimmed.substring(4).trim(),
                            level: 3
                        });

                        continue;
                    }

                    if (trimmed.startsWith("## ")) {
                        flushParagraph();

                        blocks.push({
                            text: trimmed.substring(3).trim(),
                            level: 2
                        });

                        continue;
                    }

                    if (!trimmed) {
                        flushParagraph();
                        continue;
                    }

                    paragraphLines.push(trimmed);
                }

                if (insideCodeBlock) {
                    flushCode();
                }

                flushParagraph();

                if (blocks.length === 0) {
                    blocks.push({
                        text: "Start writing your article content here."
                    });
                }

                return blocks;
            }

            function createElementUdi() {
                return `umb://element/${createGuid()}`;
            }

            function createGuid() {
                if (crypto && crypto.randomUUID) {
                    return crypto.randomUUID().replaceAll("-", "");
                }

                return "xxxxxxxxxxxx4xxxyxxxxxxxxxxxxxxx".replace(/[xy]/g, character => {
                    const random = Math.random() * 16 | 0;
                    const value = character === "x" ? random : (random & 0x3 | 0x8);

                    return value.toString(16);
                });
            }

            function setDirty(value) {
                isDirty = value;
                notifyParent(false);
            }

            function isArticleValid() {
                return Boolean(
                    value("title").trim() &&
                    value("slug").trim() &&
                    value("summary").trim() &&
                    value("dotnetZone").trim() &&
                    value("dotnetZoneStep").trim() &&
                    value("tags").trim() &&
                    value("bodyMarkdown").trim());
            }

            function onParentMessage(event) {
                const message = event.data;

                if (!message || message.type !== "BLOG_ARTICLE_EDITOR_SAVE") {
                    return;
                }

                if (!isArticleValid()) {
                    notifyParent(false);
                    return;
                }

                saveArticle();
            }

            function showEditorFeedbackModal(title, message, tone) {
                const icon = document.getElementById("editorFeedbackIcon");

                icon.className = `modal-icon ${tone || "info"}`;
                icon.innerText = tone === "success" ? "✓" : tone === "danger" ? "!" : "i";

                document.getElementById("editorFeedbackTitle").innerText = title;
                document.getElementById("editorFeedbackMessage").innerText = message || "";

                document.getElementById("editorFeedbackModal").style.display = "flex";
            }

            function closeEditorFeedbackModal() {
                document.getElementById("editorFeedbackModal").style.display = "none";
            }

            async function saveArticle() {
                const payload = {
                    title: value("title"),
                    slug: value("slug"),
                    summary: value("summary"),
                    tags: value("tags"),
                    bodyBlocks: getBodyBlocksForSave(),
                    level: currentLevel,
                    focus: currentFocus,
                    dotnetZone: value("dotnetZone"),
                    dotnetZoneStep: value("dotnetZoneStep"),
                    order: parseArticleOrder()
                };

                let response;

                if (currentArticleKey) {
                    response = await fetch(
                        `/api/blog-content/articles/${currentArticleKey}`,
                        {
                            method: "PUT",
                            headers: {
                                "Content-Type": "application/json"
                            },
                            body: JSON.stringify(payload)
                        });
                }
                else {
                    response = await fetch(
                        "/api/blog-content/articles",
                        {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json"
                            },
                            body: JSON.stringify(payload)
                        });
                }

                const result = await response.json();

                if (result.success) {
                    currentArticleKey = result.key;

                    originalState = getCurrentState();

                    setDirty(false);

                    notifyParent(true);

                    showEditorFeedbackModal(
                        currentArticleKey ? "Article updated" : "Article saved",
                        result.message || "The article was saved successfully.",
                        "success");
                }
                else {
                    showEditorFeedbackModal(
                        "Article could not be saved",
                        result.message || "Please check the article fields and try again.",
                        "danger");
                }
            }

            function notifyParent(saved) {
                try {
                    window.parent.postMessage({
                        type: "BLOG_ARTICLE_EDITOR_STATE",
                        articleKey: currentArticleKey,
                        title: value("title"),
                        isDirty,
                        isValid: isArticleValid(),
                        mode: currentArticleKey ? "existing" : (getRequestedCopyArticleKey() ? "copy" : "new"),
                        saved: Boolean(saved)
                    }, "*");
                }
                catch (error) {
                    console.error("[ARTICLE_EDITOR] failed to notify parent:", error);
                }
            }

            function parseArticleOrder() {
                const order = Number.parseInt(value("order"), 10);

                return Number.isInteger(order) && order > 0
                    ? order
                    : null;
            }

            function value(id) {
                return document.getElementById(id).value;
            }

            function setValue(id, value) {
                document.getElementById(id).value = value ?? "";
            }

            function selectedText(id) {
                const select = document.getElementById(id);

                return select.options[select.selectedIndex]?.text ?? "";
            }

            function escapeHtml(value) {
                return String(value ?? "")
                    .replaceAll("&", "&amp;")
                    .replaceAll("<", "&lt;")
                    .replaceAll(">", "&gt;")
                    .replaceAll("\"", "&quot;")
                    .replaceAll("'", "&#039;");
            }


            function escapeJs(value) {
                return String(value ?? "")
                    .replaceAll("\\", "\\\\")
                    .replaceAll("'", "\\'");
            }


            function isPlantUmlAutocorrectEnabled() {
                return Boolean(document.getElementById("autoCorrectPlantUmlSkinparams")?.checked);
            }

            function autocorrectPlantUmlSource(rawSource) {
                const protectedBlockNames = new Set([
                    "rectangle",
                    "class",
                    "component",
                    "package"
                ]);

                const protectedSingleParams = new Set([
                    "backgroundcolor",
                    "shadowing",
                    "defaultfontname",
                    "defaultfontcolor",
                    "arrowcolor",
                    "arrowfontcolor",
                    "arrowthickness"
                ]);

                const lines = String(rawSource || "").replace(/\r\n/g, "\n").split("\n");
                const result = [];
                const removedSkinparams = [];

                let skippingProtectedBlock = false;
                let protectedBlockDepth = 0;

                for (const line of lines) {
                    const trimmed = line.trim();

                    if (skippingProtectedBlock) {
                        protectedBlockDepth += countCharacters(trimmed, "{");
                        protectedBlockDepth -= countCharacters(trimmed, "}");

                        if (protectedBlockDepth <= 0) {
                            skippingProtectedBlock = false;
                        }

                        continue;
                    }

                    if (isPlantUmlTitleLine(trimmed)) {
                        result.push(commentOutPlantUmlLine(line));
                        removedSkinparams.push("title");
                        continue;
                    }

                    if (!trimmed.toLowerCase().startsWith("skinparam ")) {
                        result.push(line);
                        continue;
                    }

                    const skinparamBody = trimmed.substring("skinparam ".length).trim();
                    const firstToken = skinparamBody.split(/[\s{]+/).filter(Boolean)[0];

                    if (!firstToken) {
                        continue;
                    }

                    const normalizedToken = firstToken.toLowerCase();

                    if (protectedSingleParams.has(normalizedToken)) {
                        removedSkinparams.push(firstToken);
                        continue;
                    }

                    if (protectedBlockNames.has(normalizedToken) && skinparamBody.includes("{")) {
                        removedSkinparams.push(firstToken);
                        skippingProtectedBlock = true;
                        protectedBlockDepth = 1;
                        continue;
                    }

                    result.push(line);
                }

                const source = result.join("\n").trim();

                return {
                    source,
                    corrected: removedSkinparams.length > 0,
                    removedSkinparams
                };
            }

            function isPlantUmlTitleLine(trimmedLine) {
                const normalized = String(trimmedLine || "").toLowerCase();

                return normalized.startsWith("title ") || normalized === "title";
            }

            function commentOutPlantUmlLine(line) {
                const value = String(line || "");

                if (value.trimStart().startsWith("'")) {
                    return value;
                }

                const leadingWhitespace = value.match(/^\s*/)?.[0] || "";
                const content = value.substring(leadingWhitespace.length);

                return `${leadingWhitespace}' ${content}`;
            }

            function countCharacters(value, character) {
                return [...String(value || "")]
                    .filter(current => current === character)
                    .length;
            }

            function showPlantUmlCorrectionToast(removedSkinparams) {
                const toast = document.getElementById("plantUmlCorrectionToast");

                if (!toast) {
                    return;
                }

                const uniqueNames = [...new Set(removedSkinparams)].join(", ");

                toast.innerText = uniqueNames
                    ? `✓ PlantUML autocorrected. Updated protected lines: ${uniqueNames}.`
                    : "✓ PlantUML was autocorrected to use the article theme.";

                toast.classList.add("visible");

                window.setTimeout(() => {
                    toast.classList.remove("visible");
                }, 4200);
            }

    </script>
    <script src="/js/blog-admin-rich-table-editor.js"></script>
</body>
</html>
