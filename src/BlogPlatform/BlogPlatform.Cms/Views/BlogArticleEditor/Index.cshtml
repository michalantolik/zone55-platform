@{
    Layout = null;
    var previewUrl = (string)(ViewData["PreviewUrl"] ?? "/preview/article");
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Article Editor</title>

    <style>
            body {
                margin: 0;
                font-family: system-ui, sans-serif;
                background: #0f172a;
                color: #e5e7eb;
            }

            .editor-shell {
                display: grid;
                grid-template-columns: 480px 1fr;
                height: 100vh;
            }

            .editor-panel {
                padding: 24px;
                border-right: 1px solid #334155;
                overflow: auto;
            }

            .preview-panel iframe {
                width: 100%;
                height: 100vh;
                border: 0;
                background: white;
            }

            label {
                display: block;
                margin-top: 16px;
                font-weight: 700;
            }

            input,
            textarea {
                width: 100%;
                margin-top: 6px;
                padding: 10px;
                border-radius: 8px;
                border: 1px solid #475569;
                background: #020617;
                color: #e5e7eb;
                font: inherit;
            }

            textarea {
                min-height: 180px;
                resize: vertical;
            }

            .hint {
                color: #94a3b8;
                font-size: 13px;
                line-height: 1.5;
            }
    </style>
</head>

<body>
    <div class="editor-shell">
        <section class="editor-panel">
            <h1>Article editor</h1>

            <p class="hint">
                This is the CMS-side editor shell. The preview on the right is rendered by BlogPlatform.App.
            </p>

            <label>Title</label>
            <input id="title" value="New article title" />

            <label>Slug</label>
            <input id="slug" value="new-article" />

            <label>Summary</label>
            <textarea id="summary">Short article summary.</textarea>

            <label>Category</label>
            <input id="category" value="Backend (.NET)" />

            <label>Category slug</label>
            <input id="categorySlug" value="backend-dotnet" />

            <label>Tags comma-separated</label>
            <input id="tags" value=".NET, Architecture, Azure" />

            <label>Body</label>
            <textarea id="body">## First heading

This is the first paragraph.

```csharp
public sealed class Example
{
    public string Name { get; set; } = string.Empty;
}
```</textarea>

            <p class="hint">
                Supported syntax:
                <br />## Heading
                <br />normal paragraph
                <br />```csharp code block ```
            </p>
        </section>

        <section class="preview-panel">
            <iframe id="previewFrame" src="@previewUrl"></iframe>
        </section>
    </div>

    <script>
            const frame = document.getElementById('previewFrame');

            const fields = [
                'title',
                'slug',
                'summary',
                'category',
                'categorySlug',
                'tags',
                'body'
            ];

            for (const field of fields) {
                document.getElementById(field).addEventListener('input', sendPreview);
            }

            frame.addEventListener('load', sendPreview);

            function sendPreview() {
                const article = {
                    slug: value('slug'),
                    title: value('title'),
                    summary: value('summary'),
                    category: value('category'),
                    categorySlug: value('categorySlug'),
                    level: 'Draft',
                    focus: 'Preview',
                    tags: value('tags').split(',').map(x => x.trim()).filter(Boolean),
                    publishedDate: null,
                    bodyHtml: createUmbracoBlockListJson(value('body'))
                };

                frame.contentWindow.postMessage({
                    type: 'BLOG_ARTICLE_PREVIEW',
                    article
                }, '*');
            }

            function value(id) {
                return document.getElementById(id).value;
            }

            function createUmbracoBlockListJson(text) {
                const blocks = [];
                const layout = [];

                const lines = text.replace(/\r\n/g, '\n').split('\n');
                let index = 0;

                while (index < lines.length) {
                    const line = lines[index];

                    if (line.startsWith('```')) {
                        const language = line.replace('```', '').trim() || 'text';
                        index++;

                        const codeLines = [];

                        while (index < lines.length && !lines[index].startsWith('```')) {
                            codeLines.push(lines[index]);
                            index++;
                        }

                        index++;

                        addBlock({
                            language,
                            fileName: 'preview.' + language,
                            code: codeLines.join('\n')
                        });

                        continue;
                    }

                    if (line.startsWith('## ')) {
                        addBlock({
                            level: 2,
                            text: line.substring(3)
                        });

                        index++;
                        continue;
                    }

                    if (line.trim().length > 0) {
                        addBlock({
                            text: line.trim()
                        });
                    }

                    index++;
                }

                function addBlock(data) {
                    const udi = 'umb://element/' + crypto.randomUUID().replaceAll('-', '');

                    blocks.push({
                        udi,
                        contentTypeKey: crypto.randomUUID(),
                        ...data
                    });

                    layout.push({
                        contentUdi: udi,
                        settingsUdi: null
                    });
                }

                return JSON.stringify({
                    layout: {
                        'Umbraco.BlockList': layout
                    },
                    contentData: blocks,
                    settingsData: []
                });
            }
    </script>
</body>
</html>
