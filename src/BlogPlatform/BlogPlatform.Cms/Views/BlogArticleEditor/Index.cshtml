@{
    Layout = null;

    var previewUrl =
        (string)(ViewData["PreviewUrl"]
            ?? "https://localhost:7252/preview/article");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Article editor</title>

    <style>
        * { box-sizing: border-box; }

        :root {
            --article-editor-sidebar-width: 520px;
            --article-editor-sidebar-min-width: 360px;
            --article-editor-preview-min-width: 420px;
            --article-editor-splitter-width: 10px;
        }

        body {
            margin: 0;
            overflow: hidden;
            font-family: Inter, Arial, sans-serif;
            background: #061325;
            color: #f5f7fb;
        }

        body.resizing {
            cursor: col-resize;
            user-select: none;
        }

        body.resizing iframe {
            pointer-events: none;
        }

        .layout {
            display: flex;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
        }

        .sidebar {
            flex: 0 0 var(--article-editor-sidebar-width);
            min-width: var(--article-editor-sidebar-min-width);
            overflow-y: auto;
            background: #06152b;
            border-right: 1px solid #29405f;
        }

        .sidebar-header {
            padding: 20px 20px 0 20px;
        }

        h1 {
            margin: 0 0 18px 0;
            font-size: 28px;
        }

        .editor-tabs {
            display: flex;
            gap: 0;
            border-bottom: 1px solid #29405f;
            padding: 0 20px;
            background: #071a33;
        }

        .editor-tab {
            border: 0;
            border-bottom: 3px solid transparent;
            background: transparent;
            color: #c8d8ef;
            padding: 15px 18px 12px 18px;
            font: inherit;
            font-weight: 800;
            cursor: pointer;
        }

        .editor-tab:hover,
        .editor-tab.active {
            color: white;
            border-bottom-color: #84bbff;
            background: rgba(255, 255, 255, 0.04);
        }

        .tab-panel {
            display: none;
            padding: 20px;
        }

        .tab-panel.active {
            display: block;
        }

        .field-label {
            display: block;
            margin-top: 26px;
            margin-bottom: 10px;
            color: #84bbff;
            font-weight: 800;
            font-size: 13px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .field-label:first-of-type {
            margin-top: 0;
        }

        input,
        textarea,
        select {
            width: 100%;
            border-radius: 10px;
            border: 1px solid #35527a;
            background: #020b18;
            color: white;
            padding: 12px;
            font-size: 15px;
        }

        textarea {
            min-height: 150px;
            resize: vertical;
        }

        #bodyMarkdown {
            display: none;
        }

        .block-list {
            display: grid;
            gap: 8px;
        }

        .block-row {
            display: grid;
            grid-template-columns: 34px 1fr auto;
            align-items: center;
            gap: 10px;
            border: 1px solid #35527a;
            border-radius: 8px;
            background: #020b18;
            padding: 10px;
        }

        .block-icon {
            width: 28px;
            height: 28px;
            display: grid;
            place-items: center;
            color: #d7eaff;
            font-weight: 900;
            font-size: 14px;
        }

        .block-title {
            font-weight: 800;
            color: #f5f7fb;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .block-actions {
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .icon-button {
            width: 30px;
            height: 30px;
            border: 0;
            border-radius: 8px;
            background: rgba(132, 187, 255, 0.12);
            color: #d7eaff;
            cursor: pointer;
            font-weight: 900;
        }

        .icon-button:hover {
            background: rgba(132, 187, 255, 0.22);
        }

        .icon-button.danger:hover {
            background: rgba(208, 56, 77, 0.3);
        }

        .add-content {
            width: 100%;
            margin-top: 10px;
            border: 1px dashed #5f7fa8;
            border-radius: 8px;
            background: rgba(132, 187, 255, 0.06);
            color: #d7eaff;
            padding: 12px;
            font-weight: 800;
            cursor: pointer;
        }

        .add-content:hover {
            background: rgba(132, 187, 255, 0.14);
        }

        .splitter {
            flex: 0 0 var(--article-editor-splitter-width);
            width: var(--article-editor-splitter-width);
            cursor: col-resize;
            background: #11243e;
            border-left: 1px solid #29405f;
            border-right: 1px solid #29405f;
            position: relative;
            touch-action: none;
        }

        .splitter::after {
            content: "";
            position: absolute;
            top: 50%;
            left: 50%;
            width: 3px;
            height: 64px;
            border-radius: 999px;
            background: #5f7fa8;
            transform: translate(-50%, -50%);
            opacity: 0.8;
        }

        .splitter:hover,
        body.resizing .splitter {
            background: #17365d;
        }

        .preview-area {
            flex: 1 1 auto;
            min-width: var(--article-editor-preview-min-width);
            padding: 18px;
            background: radial-gradient(circle at top, #103b69, #04111d);
        }

        iframe {
            width: 100%;
            height: calc(100vh - 36px);
            border: 0;
            border-radius: 18px;
            background: white;
        }

        .modal-backdrop {
            position: fixed;
            inset: 0;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 24px;
            background: rgba(0, 0, 0, 0.72);
            z-index: 10000;
        }

        .modal {
            width: min(620px, 100%);
            border: 1px solid #48678f;
            border-radius: 18px;
            background: #0d1d35;
            padding: 22px;
            box-shadow: 0 24px 80px rgba(0, 0, 0, 0.5);
        }

        .modal h2 {
            margin: 0 0 14px 0;
        }

        .modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            margin-top: 16px;
        }

        .btn {
            border: 0;
            border-radius: 10px;
            padding: 11px 14px;
            background: #1677ff;
            color: white;
            font-weight: 800;
            cursor: pointer;
        }

        .btn-secondary {
            background: #2d4463;
        }
    </style>
</head>

<body>
    <div class="layout">
        <div class="sidebar" id="editorSidebar">
            <div class="sidebar-header">
                <h1>Article editor</h1>
            </div>

            <nav class="editor-tabs">
                <button id="contentTabButton" class="editor-tab active" type="button" onclick="showEditorTab('content')">Content</button>
                <button id="bodyTabButton" class="editor-tab" type="button" onclick="showEditorTab('body')">Body</button>
            </nav>

            <section id="contentTabPanel" class="tab-panel active">
                <label class="field-label" for="title">Title</label>
                <input id="title" type="text" />

                <label class="field-label" for="slug">Slug</label>
                <input id="slug" type="text" />

                <label class="field-label" for="summary">Summary</label>
                <textarea id="summary"></textarea>

                <label class="field-label" for="articleCategory">Category</label>
                <select id="articleCategory"></select>

                <label class="field-label" for="tags">Tags comma-separated</label>
                <input id="tags" type="text" />
            </section>

            <section id="bodyTabPanel" class="tab-panel">
                <textarea id="bodyMarkdown"></textarea>
                <div id="bodyBlocksList" class="block-list"></div>
                <button class="add-content" type="button" onclick="addBodyBlock()">Add content</button>
            </section>
        </div>

        <div id="paneSplitter"
             class="splitter"
             role="separator"
             aria-orientation="vertical"
             aria-label="Resize article editor panes">
        </div>

        <div class="preview-area">
            <iframe id="previewFrame"
                    src="@previewUrl"
                    onload="onPreviewFrameLoaded()">
            </iframe>
        </div>
    </div>

    <div id="blockEditModal" class="modal-backdrop">
        <div class="modal">
            <h2 id="blockEditTitle">Edit block</h2>
            <textarea id="blockEditText"></textarea>

            <div class="modal-actions">
                <button class="btn btn-secondary" type="button" onclick="closeBlockEditor()">Cancel</button>
                <button class="btn" type="button" onclick="saveBlockEditor()">Save block</button>
            </div>
        </div>
    </div>

    <script>
        const sidebarWidthStorageKey = "blogArticleEditor.sidebarWidth";
        const defaultSidebarWidth = 520;
        const minSidebarWidth = 360;
        const minPreviewWidth = 420;

        let currentArticleKey = null;
        let currentLevel = "Draft";
        let currentFocus = "Preview";
        let originalState = null;
        let isDirty = false;
        let sendSequence = 0;
        let previewFrameLoaded = false;
        let bodyBlocks = [];
        let editedBlockIndex = null;

        const frame = document.getElementById("previewFrame");

        const fieldIds = [
            "title",
            "slug",
            "summary",
            "articleCategory",
            "tags",
            "bodyMarkdown"
        ];

        window.addEventListener("message", onParentMessage);

        document.addEventListener("DOMContentLoaded", async () => {
            initializeResizablePanes();

            await loadCategories();

            attachFieldListeners();

            const articleKey = getRequestedArticleKey();

            if (articleKey) {
                await loadExistingArticle(articleKey);
            }
            else {
                createNewArticle();
            }

            renderBodyBlocks();
            sendPreviewUpdate();
        });

        function showEditorTab(tab) {
            document.getElementById("contentTabButton").classList.toggle("active", tab === "content");
            document.getElementById("bodyTabButton").classList.toggle("active", tab === "body");
            document.getElementById("contentTabPanel").classList.toggle("active", tab === "content");
            document.getElementById("bodyTabPanel").classList.toggle("active", tab === "body");
        }

        function initializeResizablePanes() {
            const splitter = document.getElementById("paneSplitter");
            const savedWidth = Number(localStorage.getItem(sidebarWidthStorageKey));

            setSidebarWidth(Number.isFinite(savedWidth) && savedWidth > 0 ? savedWidth : defaultSidebarWidth);

            splitter.addEventListener("pointerdown", startPaneResize);

            splitter.addEventListener("dblclick", () => {
                setSidebarWidth(defaultSidebarWidth);
                localStorage.setItem(sidebarWidthStorageKey, defaultSidebarWidth.toString());
            });

            window.addEventListener("resize", () => {
                setSidebarWidth(getCurrentSidebarWidth());
            });
        }

        function startPaneResize(event) {
            event.preventDefault();

            const splitter = document.getElementById("paneSplitter");

            splitter.setPointerCapture(event.pointerId);
            document.body.classList.add("resizing");

            const onPointerMove = moveEvent => {
                setSidebarWidth(moveEvent.clientX);
            };

            const onPointerUp = upEvent => {
                splitter.releasePointerCapture(upEvent.pointerId);
                document.body.classList.remove("resizing");

                localStorage.setItem(
                    sidebarWidthStorageKey,
                    getCurrentSidebarWidth().toString());

                window.removeEventListener("pointermove", onPointerMove);
                window.removeEventListener("pointerup", onPointerUp);
                window.removeEventListener("pointercancel", onPointerUp);
            };

            window.addEventListener("pointermove", onPointerMove);
            window.addEventListener("pointerup", onPointerUp);
            window.addEventListener("pointercancel", onPointerUp);
        }

        function setSidebarWidth(requestedWidth) {
            const maxSidebarWidth =
                Math.max(
                    minSidebarWidth,
                    window.innerWidth - minPreviewWidth);

            const width =
                Math.min(
                    Math.max(requestedWidth, minSidebarWidth),
                    maxSidebarWidth);

            document.documentElement.style.setProperty(
                "--article-editor-sidebar-width",
                `${width}px`);
        }

        function getCurrentSidebarWidth() {
            const sidebar = document.getElementById("editorSidebar");

            return Math.round(sidebar.getBoundingClientRect().width);
        }

        function getRequestedArticleKey() {
            const parameters = new URLSearchParams(window.location.search);

            return parameters.get("articleKey");
        }

        function onPreviewFrameLoaded() {
            previewFrameLoaded = true;

            console.log("[LIVE_PREVIEW] iframe loaded:", frame.src);

            setTimeout(sendPreviewUpdate, 250);
            setTimeout(sendPreviewUpdate, 750);
            setTimeout(sendPreviewUpdate, 1500);
        }

        async function loadCategories() {
            const response = await fetch("/api/blog-content/categories");
            const categories = await response.json();
            const articleCategory = document.getElementById("articleCategory");

            articleCategory.innerHTML = "";

            for (const category of categories) {
                articleCategory.innerHTML += `
                    <option value="${escapeHtml(category.slug)}">
                        ${escapeHtml(category.name)}
                    </option>
                `;
            }
        }

        async function loadExistingArticle(articleKey) {
            const response =
                await fetch(`/api/blog-content/articles/${encodeURIComponent(articleKey)}`);

            if (!response.ok) {
                console.error(
                    "[ARTICLE_EDITOR] failed to load article:",
                    articleKey,
                    response.status);

                return;
            }

            const article = await response.json();

            populateArticle(article);

            originalState = getCurrentState();

            setDirty(false);

            notifyParent(false);
            sendPreviewUpdate();
        }

        function populateArticle(article) {
            currentArticleKey = article.key;
            currentLevel = article.level || "Draft";
            currentFocus = article.focus || "Preview";

            setValue("title", article.title);
            setValue("slug", article.slug);
            setValue("summary", article.summary);
            setValue("articleCategory", article.categorySlug);
            setValue("tags", article.tags);
            setValue("bodyMarkdown", article.bodyBlocks);

            bodyBlocks = readBodyBlocksFromBodyMarkdown();
            renderBodyBlocks();
        }

        function createNewArticle() {
            currentArticleKey = null;
            currentLevel = "Draft";
            currentFocus = "Preview";

            setValue("title", "Example article title");
            setValue("slug", "example-article");
            setValue("summary", "Short article summary.");
            setValue("tags", ".NET, Architecture, Azure");

            bodyBlocks = [
                {
                    udi: createElementUdi(),
                    type: "heading",
                    text: "First heading",
                    level: 2
                },
                {
                    udi: createElementUdi(),
                    type: "text",
                    text: "This is the first paragraph."
                },
                {
                    udi: createElementUdi(),
                    type: "code",
                    language: "csharp",
                    fileName: "Example.cs",
                    code: "public sealed class Example\n{\n    public string Name { get; set; } = string.Empty;\n}"
                }
            ];

            syncBodyMarkdownFromBlocks();

            originalState = getCurrentState();

            setDirty(false);

            notifyParent(false);
            sendPreviewUpdate();
        }

        function attachFieldListeners() {
            for (const fieldId of fieldIds) {
                const field = document.getElementById(fieldId);

                field.addEventListener("input", onEditorChanged);
                field.addEventListener("change", onEditorChanged);
            }
        }

        function onEditorChanged() {
            if (document.activeElement?.id === "bodyMarkdown") {
                bodyBlocks = readBodyBlocksFromBodyMarkdown();
                renderBodyBlocks();
            }

            const changed =
                JSON.stringify(getCurrentState()) !==
                JSON.stringify(originalState);

            setDirty(changed);

            sendPreviewUpdate();
        }

        function getCurrentState() {
            return {
                title: value("title"),
                slug: value("slug"),
                summary: value("summary"),
                categorySlug: value("articleCategory"),
                tags: value("tags"),
                bodyMarkdown: value("bodyMarkdown"),
                level: currentLevel,
                focus: currentFocus
            };
        }

        function sendPreviewUpdate() {
            sendSequence++;

            const article = {
                slug: value("slug"),
                title: value("title"),
                summary: value("summary"),
                category: selectedText("articleCategory"),
                categorySlug: value("articleCategory"),
                level: currentLevel,
                focus: currentFocus,
                tags:
                    value("tags")
                        .split(",")
                        .map(x => x.trim())
                        .filter(Boolean),
                publishedDate: null,
                bodyHtml: getBodyBlocksForPreview()
            };

            try {
                frame.contentWindow.postMessage({
                    type: "BLOG_ARTICLE_PREVIEW",
                    sequence: sendSequence,
                    article
                }, "*");

                console.log(
                    "[LIVE_PREVIEW] message sent:",
                    sendSequence,
                    article.title);
            }
            catch (error) {
                console.error(
                    "[LIVE_PREVIEW] failed to send preview message:",
                    error);
            }
        }

        function getBodyBlocksForPreview() {
            return value("bodyMarkdown");
        }

        function getBodyBlocksForSave() {
            return value("bodyMarkdown");
        }

        function readBodyBlocksFromBodyMarkdown() {
            const body = value("bodyMarkdown");

            if (isValidBlockListJson(body)) {
                const parsed = JSON.parse(body);

                return parsed.contentData.map((item, index) => ({
                    ...item,
                    udi: item.udi || parsed.layout["Umbraco.BlockList"][index]?.contentUdi || createElementUdi(),
                    type: getBlockType(item)
                }));
            }

            return parseMarkdownBlocks(body).map(block => ({
                ...block,
                udi: createElementUdi(),
                type: getBlockType(block)
            }));
        }

        function syncBodyMarkdownFromBlocks() {
            const layoutItems = [];
            const contentData = [];

            for (const block of bodyBlocks) {
                const udi = block.udi || createElementUdi();

                layoutItems.push({
                    contentUdi: udi
                });

                const content = { ...block };
                content.udi = udi;
                delete content.type;

                contentData.push(content);
            }

            setValue("bodyMarkdown", JSON.stringify({
                layout: {
                    "Umbraco.BlockList": layoutItems
                },
                contentData,
                settingsData: []
            }));
        }

        function renderBodyBlocks() {
            const container = document.getElementById("bodyBlocksList");

            if (!bodyBlocks.length) {
                container.innerHTML = `
                    <div class="block-row">
                        <div class="block-icon">◇</div>
                        <div class="block-title">No body blocks yet</div>
                        <div></div>
                    </div>
                `;

                return;
            }

            container.innerHTML = bodyBlocks
                .map((block, index) => `
                    <article class="block-row">
                        <div class="block-icon">${getBlockIcon(block)}</div>
                        <div class="block-title">${escapeHtml(getBlockLabel(block))}</div>
                        <div class="block-actions">
                            <button class="icon-button" type="button" title="Edit" onclick="openBlockEditor(${index})">✎</button>
                            <button class="icon-button" type="button" title="Copy" onclick="copyBodyBlock(${index})">⧉</button>
                            <button class="icon-button danger" type="button" title="Delete" onclick="deleteBodyBlock(${index})">🗑</button>
                        </div>
                    </article>
                `)
                .join("");
        }

        function getBlockType(block) {
            if (block.level || block.type === "heading") {
                return "heading";
            }

            if (block.code || block.language || block.fileName || block.type === "code") {
                return "code";
            }

            if (block.diagram || block.mermaid || block.type === "mermaid") {
                return "mermaid";
            }

            if (block.plantUml || block.plantuml || block.type === "plantuml") {
                return "plantuml";
            }

            if (block.calloutType || block.type === "callout") {
                return "callout";
            }

            return "text";
        }

        function getBlockIcon(block) {
            const type = getBlockType(block);

            if (type === "heading") {
                return `H${block.level || 2}`;
            }

            if (type === "code") {
                return "&lt;&gt;";
            }

            if (type === "mermaid") {
                return "⌘";
            }

            if (type === "plantuml") {
                return "⌘";
            }

            if (type === "callout") {
                return "△";
            }

            return "□";
        }

        function getBlockLabel(block) {
            const type = getBlockType(block);

            if (type === "heading") {
                return `H${block.level || 2}  ${block.text || "Heading Block"}`;
            }

            if (type === "code") {
                return `${block.language || "code"} - ${block.fileName || "Code Snippet Block"}`;
            }

            if (type === "mermaid") {
                return "Mermaid diagram";
            }

            if (type === "plantuml") {
                return "PlantUML diagram";
            }

            if (type === "callout") {
                return block.calloutType || "Callout Block";
            }

            return block.text || "Text Block";
        }

        function openBlockEditor(index) {
            editedBlockIndex = index;
            const block = bodyBlocks[index];

            document.getElementById("blockEditTitle").innerText = `Edit ${getBlockLabel(block)}`;

            if (getBlockType(block) === "code") {
                document.getElementById("blockEditText").value = block.code || "";
            }
            else {
                document.getElementById("blockEditText").value =
                    block.text ||
                    block.diagram ||
                    block.mermaid ||
                    block.plantUml ||
                    block.plantuml ||
                    "";
            }

            document.getElementById("blockEditModal").style.display = "flex";
        }

        function closeBlockEditor() {
            editedBlockIndex = null;
            document.getElementById("blockEditModal").style.display = "none";
        }

        function saveBlockEditor() {
            if (editedBlockIndex === null) {
                return;
            }

            const block = bodyBlocks[editedBlockIndex];
            const newValue = document.getElementById("blockEditText").value;
            const type = getBlockType(block);

            if (type === "code") {
                block.code = newValue;
            }
            else if (type === "mermaid") {
                block.diagram = newValue;
                block.mermaid = newValue;
            }
            else if (type === "plantuml") {
                block.plantUml = newValue;
            }
            else {
                block.text = newValue;
            }

            syncBodyMarkdownFromBlocks();
            renderBodyBlocks();
            closeBlockEditor();
            onEditorChanged();
        }

        function copyBodyBlock(index) {
            const source = bodyBlocks[index];
            const copy = JSON.parse(JSON.stringify(source));

            copy.udi = createElementUdi();

            bodyBlocks.splice(index + 1, 0, copy);

            syncBodyMarkdownFromBlocks();
            renderBodyBlocks();
            onEditorChanged();
        }

        function deleteBodyBlock(index) {
            if (!confirm("Delete this body block?")) {
                return;
            }

            bodyBlocks.splice(index, 1);

            syncBodyMarkdownFromBlocks();
            renderBodyBlocks();
            onEditorChanged();
        }

        function addBodyBlock() {
            bodyBlocks.push({
                udi: createElementUdi(),
                type: "text",
                text: "New text block"
            });

            syncBodyMarkdownFromBlocks();
            renderBodyBlocks();
            onEditorChanged();
        }

        function isValidBlockListJson(body) {
            if (!body || !body.trim().startsWith("{")) {
                return false;
            }

            try {
                const parsed = JSON.parse(body);

                return Boolean(
                    parsed &&
                    parsed.layout &&
                    parsed.layout["Umbraco.BlockList"] &&
                    Array.isArray(parsed.contentData));
            }
            catch {
                return false;
            }
        }

        function parseMarkdownBlocks(markdown) {
            const lines = (markdown || "")
                .replace(/\r\n/g, "\n")
                .split("\n");

            const blocks = [];
            let paragraphLines = [];
            let insideCodeBlock = false;
            let codeLanguage = "";
            let codeLines = [];

            const flushParagraph = () => {
                const text = paragraphLines.join(" ").trim();

                if (text) {
                    blocks.push({
                        text
                    });
                }

                paragraphLines = [];
            };

            const flushCode = () => {
                blocks.push({
                    code: codeLines.join("\n"),
                    language: codeLanguage || "text",
                    fileName: codeLanguage ? `example.${codeLanguage}` : "example.txt"
                });

                codeLines = [];
                codeLanguage = "";
            };

            for (const line of lines) {
                const trimmed = line.trim();

                if (trimmed.startsWith("```")) {
                    if (insideCodeBlock) {
                        flushCode();
                        insideCodeBlock = false;
                    }
                    else {
                        flushParagraph();
                        insideCodeBlock = true;
                        codeLanguage = trimmed.replace("```", "").trim();
                        codeLines = [];
                    }

                    continue;
                }

                if (insideCodeBlock) {
                    codeLines.push(line);
                    continue;
                }

                if (trimmed.startsWith("#### ")) {
                    flushParagraph();

                    blocks.push({
                        text: trimmed.substring(5).trim(),
                        level: 4
                    });

                    continue;
                }

                if (trimmed.startsWith("### ")) {
                    flushParagraph();

                    blocks.push({
                        text: trimmed.substring(4).trim(),
                        level: 3
                    });

                    continue;
                }

                if (trimmed.startsWith("## ")) {
                    flushParagraph();

                    blocks.push({
                        text: trimmed.substring(3).trim(),
                        level: 2
                    });

                    continue;
                }

                if (!trimmed) {
                    flushParagraph();
                    continue;
                }

                paragraphLines.push(trimmed);
            }

            if (insideCodeBlock) {
                flushCode();
            }

            flushParagraph();

            if (blocks.length === 0) {
                blocks.push({
                    text: "Start writing your article content here."
                });
            }

            return blocks;
        }

        function createElementUdi() {
            return `umb://element/${createGuid()}`;
        }

        function createGuid() {
            if (crypto && crypto.randomUUID) {
                return crypto.randomUUID().replaceAll("-", "");
            }

            return "xxxxxxxxxxxx4xxxyxxxxxxxxxxxxxxx".replace(/[xy]/g, character => {
                const random = Math.random() * 16 | 0;
                const value = character === "x" ? random : (random & 0x3 | 0x8);

                return value.toString(16);
            });
        }

        function setDirty(value) {
            isDirty = value;
            notifyParent(false);
        }

        function isArticleValid() {
            return Boolean(
                value("title").trim() &&
                value("slug").trim() &&
                value("summary").trim() &&
                value("articleCategory").trim() &&
                value("tags").trim() &&
                value("bodyMarkdown").trim());
        }

        function onParentMessage(event) {
            const message = event.data;

            if (!message || message.type !== "BLOG_ARTICLE_EDITOR_SAVE") {
                return;
            }

            if (!isArticleValid()) {
                notifyParent(false);
                return;
            }

            saveArticle();
        }

        async function saveArticle() {
            const payload = {
                title: value("title"),
                slug: value("slug"),
                summary: value("summary"),
                categorySlug: value("articleCategory"),
                tags: value("tags"),
                bodyBlocks: getBodyBlocksForSave(),
                level: currentLevel,
                focus: currentFocus
            };

            let response;

            if (currentArticleKey) {
                response = await fetch(
                    `/api/blog-content/articles/${currentArticleKey}`,
                    {
                        method: "PUT",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify(payload)
                    });
            }
            else {
                response = await fetch(
                    "/api/blog-content/articles",
                    {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify(payload)
                    });
            }

            const result = await response.json();

            if (result.success) {
                currentArticleKey = result.key;

                originalState = getCurrentState();

                setDirty(false);

                notifyParent(true);

                alert(result.message);
            }
            else {
                alert(result.message);
            }
        }

        function notifyParent(saved) {
            try {
                window.parent.postMessage({
                    type: "BLOG_ARTICLE_EDITOR_STATE",
                    articleKey: currentArticleKey,
                    title: value("title"),
                    isDirty,
                    isValid: isArticleValid(),
                    mode: currentArticleKey ? "existing" : "new",
                    saved: Boolean(saved)
                }, "*");
            }
            catch (error) {
                console.error("[ARTICLE_EDITOR] failed to notify parent:", error);
            }
        }

        function value(id) {
            return document.getElementById(id).value;
        }

        function setValue(id, value) {
            document.getElementById(id).value = value ?? "";
        }

        function selectedText(id) {
            const select = document.getElementById(id);

            return select.options[select.selectedIndex]?.text ?? "";
        }

        function escapeHtml(value) {
            return String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll("\"", "&quot;")
                .replaceAll("'", "&#039;");
        }
    </script>
</body>
</html>
