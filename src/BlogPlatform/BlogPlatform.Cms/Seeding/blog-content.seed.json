  "articles": [
    {
      "name": "A Simple C# Program",
      "slug": "a-simple-csharp-program",
      "level": "Draft",
      "focus": "Preview",
      "summary": "We\u2019ll start by demonstrating a simple program and explaining its components one by one. This will introduce a range of topics, from the structure of a C# program to the method of producing program output to the screen.",
      "dotnetZone": "foundation",
      "dotnetZoneStep": "basic-syntax",
      "order": 1,
      "tags": [
        "Basic Syntax"
      ],
      "bodyBlocks": [
        {
          "type": "text",
          "text": "- When the code is compiled and executed, it displays the string \u201CHi there!\u201D in a window on the screen.\n\n- Line 5 contains two contiguous slash characters. These characters\u2014and everything following them on the line\u2014are ignored by the compiler. This is called a *single-line comment*."
        },
        {
          "type": "codeSnippet",
          "language": "csharp",
          "fileName": "Example.cs",
          "code": "using System;\n\nnamespace Simple\n{\n    class Program // declare a class\n    {\n        static void Main()\n        {\n            Console.WriteLine(\u0022Hi there!\u0022);\n        }\n    }\n}"
        }
      ]
    },
    {
      "name": "Components of the .NET Framework",
      "slug": "components-of-the-dotnet-framework",
      "level": "Draft",
      "focus": "Preview",
      "summary": ".NET Framework consists of three components:\n\n- CLR runs the application\n- BCL gives reusable classes\n- Tools compile the source code",
      "dotnetZone": "foundation",
