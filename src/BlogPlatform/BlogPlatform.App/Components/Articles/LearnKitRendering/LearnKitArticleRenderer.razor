@using BlogPlatform.App.Components.Articles.Shared
@using BlogPlatform.App.Models.LearnKit
@using BlogPlatform.App.Models.LearnKit.Articles
@using Microsoft.JSInterop
@inject IJSRuntime JS

@if (Article is not null)
{
    <article class="article-card" @key="Article.Id + Article.Title + Article.Summary">
        <div class="tag-row">
        </div>

        <h1>@Article.Title</h1>

        <div class="article-meta">
            <strong>Engineering note</strong>
            <span>·</span>
            <span>Michał Antolik</span>
            <span>·</span>
        </div>

        <div class="article-summary">
            @MarkdownRenderer.Render(Article.Summary)
        </div>

        <div class="article-body">
            <CascadingValue Value="_plantUmlTheme">
                <CascadingValue Value="CopyToClipboardDelegate">
                    @foreach (var block in Article.Blocks.OrderBy(block => block.SortOrder))
                    {
                        <LearnKitBlockRenderer Block="block" />
                    }
                </CascadingValue>
            </CascadingValue>
        </div>
    </article>
}

@code {
    [Parameter]
    public LearnKitArticleDetails? Article { get; set; }

    private Func<string?, Task> CopyToClipboardDelegate => CopyToClipboardAsync;

    private PlantUmlThemeValues _plantUmlTheme = new(
        "#a7b4c8",
        "#E5E7EB",
        "#7d8ca3",
        "#374151",
        "SansSerif");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _plantUmlTheme = await JS.InvokeAsync<PlantUmlThemeValues>(
                "blogPlatformArticle.getPlantUmlThemeValues");

            StateHasChanged();
        }

        try
        {
            await JS.InvokeVoidAsync(
                "blogPlatformArticle.renderDiagrams");
        }
        catch (JSException ex)
        {
            Console.WriteLine(
                $"LearnKit diagram rendering failed: {ex.Message}");
        }
    }

    private async Task CopyToClipboardAsync(string? value)
    {
        if (!string.IsNullOrEmpty(value))
        {
            await JS.InvokeVoidAsync("blogPlatformArticle.copyToClipboard", value);
        }
    }
}
