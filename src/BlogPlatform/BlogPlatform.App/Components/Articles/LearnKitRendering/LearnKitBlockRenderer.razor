@using BlogPlatform.App.Components.Articles.LearnKitRendering.Provider
@using BlogPlatform.App.Models.LearnKit

@inject LearnKitBlockComponentTypeProvider ComponentTypeProvider

@if (Block is not null)
{
    var componentType = ComponentTypeProvider.GetComponentType(Block);

    if (componentType is not null)
    {
        <DynamicComponent Type="componentType"
                          Parameters="GetParameters()" />
    }
    else
    {
        <div class="article-unsupported-block">Unsupported LearnKit block: @Block.Type</div>
    }
}

@code
{
    [Parameter]
    public required LearnKitArticleBlockDetails Block { get; set; }

    private Dictionary<string, object?> GetParameters()
    {
        return new()
        {
            ["Block"] = Block
        };
    }
}
