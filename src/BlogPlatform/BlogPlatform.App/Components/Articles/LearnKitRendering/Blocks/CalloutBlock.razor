@using BlogPlatform.App.Components.Articles.LearnKitRendering.Serialization
@using BlogPlatform.App.Models.LearnKit
@using BlogPlatform.App.Models.LearnKit.Articles

@if (Block is not null)
{
    var model = LearnKitBlockDeserializer.ToCalloutBlock(Block);

    <aside class="callout callout-@model.Kind">
        <strong>@model.Kind</strong>
        <p>@model.Text</p>
    </aside>
}

@code {
    [Parameter]
    public required LearnKitArticleBlockDetails Block { get; set; }
}
