@using BlogPlatform.App.Components.Articles.Rendering
@using BlogPlatform.App.Components.Articles.Rendering.Context
@using BlogPlatform.App.Components.Articles.Rendering.Provider
@using BlogPlatform.App.Models
@using BlogPlatform.Contracts.Posts
@using Microsoft.JSInterop
@inject IJSRuntime JS
@inject IArticleBlockRenderStrategyProvider BlockRenderStrategyProvider

@if (Article is not null)
{
    var blocks = ArticleBlockParser.Parse(Article.BodyHtml);
    var renderContext = CreateRenderContext();

    <article class="article-card" @key="Article.Title + Article.Summary + Article.BodyHtml">
        <div class="tag-row">
            @foreach (var tag in Article.Tags ?? [])
            {
                <span>@tag</span>
            }
        </div>

        <h1>@Article.Title</h1>

        <div class="article-meta">
            <strong>Engineering note</strong>
            <span>·</span>
            <span>Michał Antolik</span>
            <span>·</span>
        </div>

        <div class="article-summary">
            @ArticleBlockRenderContext.RenderMarkdown(Article.Summary)
        </div>

        <div class="article-body">
            @foreach (var block in blocks)
            {
                @BlockRenderStrategyProvider.GetStrategy(block.Type).Render(block, renderContext)
            }
        </div>
    </article>
}

@code {
    [Parameter, EditorRequired]
    public PostDetails? Article { get; set; }

    private PlantUmlThemeValues _plantUmlTheme = new(
        "#a7b4c8",
        "#E5E7EB",
        "#7d8ca3",
        "#374151",
        "SansSerif");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _plantUmlTheme = await JS.InvokeAsync<PlantUmlThemeValues>(
                "blogPlatformArticle.getPlantUmlThemeValues");

            StateHasChanged();
        }

        try
        {
            await JS.InvokeVoidAsync(
                "blogPlatformArticle.renderDiagrams");
        }
        catch (JSException ex)
        {
            Console.WriteLine(
                $"Diagram rendering failed: {ex.Message}");
        }
    }

    private ArticleBlockRenderContext CreateRenderContext()
    {
        return new ArticleBlockRenderContext(
            _plantUmlTheme,
            this,
            CopyToClipboardAsync);
    }

    private async Task CopyToClipboardAsync(string? value)
    {
        if (!string.IsNullOrEmpty(value))
        {
            await JS.InvokeVoidAsync("blogPlatformArticle.copyToClipboard", value);
        }
    }
}
