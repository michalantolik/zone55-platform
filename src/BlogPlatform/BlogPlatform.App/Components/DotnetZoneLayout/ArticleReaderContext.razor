@using BlogPlatform.App.Components.Articles
@using BlogPlatform.App.Models
@using BlogPlatform.App.Services

@if (Article is not null && _activeLevel is not null && _activeStep is not null)
{
    <section class="article-reader-context-shell">
        <div class="article-reader-context-top">
            <div class="article-reader-breadcrumbs">
                <a href="/?view=DotnetRoadmap">.NET Zones</a>
                <span>→</span>
                <span>@_activeLevel.Title</span>
                <span>→</span>
                <span>@_activeStep.Title</span>
                <span>→</span>
                <strong>@Article.Title</strong>
            </div>

            <div class="article-reader-pill">
                Article @_currentArticleNumber of @_stepArticles.Count
            </div>
        </div>

        <div class="article-reader-context-body">
            <aside class="article-reader-sidebar">
                @foreach (var article in _stepArticles.Select((Value, Index) => new { Value, Index }))
                {
                    var isActive = string.Equals(article.Value.Slug, Article.Slug, StringComparison.OrdinalIgnoreCase);

                    <a class="article-reader-step-link @(isActive ? "is-active" : null)"
                           href="@GetDotnetZonesArticleUrl(article.Value.Slug)">
                        <span class="article-reader-step-number">@((article.Index + 1).ToString("00"))</span>

                        <span class="article-reader-step-text">
                            <strong>@article.Value.Title</strong>
                            <small>Suggested reading order</small>
                        </span>
                    </a>
                }
            </aside>

            <div class="article-reader-main-context">
                <ArticleRenderer Article="Article" />

                <div class="article-reader-navigation">
                    <a class="article-reader-nav-button" href="/?view=DotnetRoadmap">
                        ← Back to .NET Zones
                    </a>

                    @if (_nextArticle is not null)
                    {
                        <a class="article-reader-nav-button article-reader-nav-button-primary"
                               href="@GetDotnetZonesArticleUrl(_nextArticle.Slug)">
                            Continue to Article @(_currentArticleNumber + 1) →
                        </a>
                    }
                    else
                    {
                        <a class="article-reader-nav-button article-reader-nav-button-primary"
                               href="/?view=DotnetRoadmap">
                            Back to roadmap →
                        </a>
                    }
                </div>
            </div>
        </div>
    </section>
}

@code {
    [Parameter, EditorRequired]
    public PostDetails? Article { get; set; }

    [Parameter, EditorRequired]
    public IReadOnlyCollection<PostListItem> Posts { get; set; } = [];

    private LearningPathLevel? _activeLevel;
    private LearningPathStep? _activeStep;
    private IReadOnlyList<PostListItem> _stepArticles = [];
    private PostListItem? _nextArticle;
    private int _currentArticleNumber = 1;

    protected override void OnParametersSet()
    {
        _activeLevel = null;
        _activeStep = null;
        _stepArticles = [];
        _nextArticle = null;
        _currentArticleNumber = 1;

        if (Article is null || Posts.Count == 0)
        {
            return;
        }

        var levels = LearningPathCatalog.Build(Posts);

        foreach (var level in levels)
        {
            foreach (var step in level.Steps)
            {
                var isMatchingStep =
                    string.Equals(Article.DotnetZoneStep, step.Key, StringComparison.OrdinalIgnoreCase)
                    || step.Posts.Any(post => string.Equals(post.Slug, Article.Slug, StringComparison.OrdinalIgnoreCase));

                if (!isMatchingStep)
                {
                    continue;
                }

                _activeLevel = level;
                _activeStep = step;
                _stepArticles = step.Posts.ToList();

                SetArticleNavigation();
                return;
            }
        }
    }

    private void SetArticleNavigation()
    {
        if (Article is null || _stepArticles.Count == 0)
        {
            return;
        }

        var currentIndex = _stepArticles
            .Select((Post, Index) => new { Post, Index })
            .FirstOrDefault(item =>
                string.Equals(item.Post.Slug, Article.Slug, StringComparison.OrdinalIgnoreCase))
            ?.Index ?? 0;

        _currentArticleNumber = currentIndex + 1;

        if (currentIndex < _stepArticles.Count - 1)
        {
            _nextArticle = _stepArticles[currentIndex + 1];
        }
    }

    private static string GetDotnetZonesArticleUrl(string slug)
    {
        return $"/articles/{slug}?visualization={LearningPathVisualizationType.DotnetZones}";
    }
}
