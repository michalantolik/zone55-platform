@using BlogPlatform.App.Components.Articles.Rendering.Context
@inject NavigationManager Navigation
@inject IConfiguration Configuration

<article class="@PostCardCssClass"
         role="link"
         tabindex="0"
         style="cursor: pointer;"
         @onclick="OpenArticle"
         @onkeydown="OpenArticleFromKeyboard">
    <div class="post-card-meta">
        @if (ShouldShowArticleCardTag)
        {
            <span class="post-card-step-pill">@StepTitle</span>
        }

        @if (ArticleOrder is not null)
        {
            <span class="post-card-order-badge"
                  aria-label="Article @ArticleOrder in this step">
                @ArticleOrder
            </span>
        }
    </div>

    @if (IsExtensiveArticleCard)
    {
        <div class="post-card-top">
            <span class="badge">@Level</span>
        </div>
    }

    <h3 class="post-title">
        <a href="@Url" @onclick:stopPropagation="true">@Title</a>
    </h3>

    <div class="post-summary post-summary-markdown">
        @ArticleBlockRenderContext.RenderMarkdown(Summary)
    </div>

    @if (IsExtensiveArticleCard && TechStack?.Any() == true)
    {
        <div class="post-tech">
            @foreach (var tech in TechStack.Take(4))
            {
                <span>@tech</span>
            }
        </div>
    }

    @if (IsExtensiveArticleCard)
    {
        <div class="post-footer">
            <span>@Focus</span>
            <a href="@Url"
                   class="read-btn"
                   @onclick:stopPropagation="true">
                Read →
            </a>
        </div>
    }
</article>

<style>
    .post-card {
        position: relative;
        transition: transform .28s ease, border-color .28s ease, box-shadow .28s ease, background .28s ease, filter .28s ease;
        will-change: transform;
    }

        .post-card:hover {
            transform: translateY(-4px);
            border-color: rgba(125, 211, 252, .60);
            background: linear-gradient(135deg, #152943 0%, #16304f 42%, #112842 100%);
            box-shadow: 0 10px 40px rgba(59, 130, 246, .12), 0 0 0 1px rgba(125, 211, 252, .18), inset 0 1px 0 rgba(255, 255, 255, .08);
            filter: brightness(1.03);
        }

            .post-card:hover .post-title a {
                color: #ffffff;
            }

            .post-card:hover .post-summary {
                color: rgba(226, 239, 255, .88);
            }

            .post-card:hover .post-card-step-pill {
                border-color: rgba(125, 211, 252, .48);
                background: rgba(18, 63, 102, .30);
                color: rgba(220, 238, 255, .92);
            }

            .post-card:hover .post-card-order-badge {
                border-color: rgba(125, 211, 252, .66);
                background: rgba(23, 54, 88, .82);
                color: #ffffff;
                box-shadow: 0 0 0 1px rgba(125, 211, 252, .12), 0 10px 24px rgba(0, 0, 0, .22);
            }

        .post-card:focus-visible {
            outline: 2px solid rgba(125, 211, 252, .85);
            outline-offset: 4px;
            border-color: rgba(125, 211, 252, .70);
            box-shadow: 0 10px 40px rgba(59, 130, 246, .12), 0 0 0 4px rgba(56, 189, 248, .16);
        }

    .post-card-meta {
        position: absolute;
        top: 18px;
        right: 18px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        z-index: 1;
    }

    .post-card-top {
        margin-bottom: 10px;
        padding-right: 190px;
    }

    .post-title,
    .post-summary {
        padding-right: 190px;
    }

    .post-card-tag-collapsed .post-card-top,
    .post-card-tag-collapsed .post-title,
    .post-card-tag-collapsed .post-summary {
        padding-right: 56px;
    }

    .post-summary-markdown p {
        margin: 0 0 10px;
    }

        .post-summary-markdown p:last-child {
            margin-bottom: 0;
        }

    .post-summary-markdown strong {
        color: inherit;
        font-weight: 800;
    }

    .post-summary-markdown em {
        color: inherit;
    }

    .post-summary-markdown code {
        padding: 2px 6px;
        border-radius: 7px;
        color: rgba(238, 246, 255, .95);
        background: rgba(15, 23, 42, .38);
        border: 1px solid rgba(125, 211, 252, .18);
        font-size: .92em;
    }

    .post-summary-markdown ul,
    .post-summary-markdown ol {
        margin: 8px 0 0;
        padding-left: 20px;
    }

    .post-summary-markdown li {
        margin: 4px 0;
    }

    .post-summary-markdown blockquote {
        margin: 10px 0 0;
        padding: 10px 14px;
        border-left: 3px solid rgba(125, 211, 252, .55);
        border-radius: 12px;
        background: rgba(14, 47, 78, .24);
    }

    .post-summary-markdown h2,
    .post-summary-markdown h3 {
        margin: 12px 0 8px;
        color: var(--post-title-text);
        font-size: 1.05rem;
        line-height: 1.25;
    }

    .post-card-order-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 31px;
        height: 31px;
        border-radius: 999px;
        color: rgba(238, 246, 255, .96);
        background: rgba(23, 54, 88, .64);
        border: 1px solid rgba(148, 195, 238, .48);
        font-size: .82rem;
        font-weight: 950;
        line-height: 1;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, .08);
        transition: border-color .22s ease, background .22s ease, color .22s ease, box-shadow .22s ease;
    }

    .post-card-step-pill {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        padding: 4px 10px;
        border: 1px solid rgba(125, 211, 252, .34);
        border-radius: 999px;
        background: rgba(14, 47, 78, .24);
        color: rgba(190, 220, 250, .82);
        font-size: .78rem;
        font-weight: 600;
        line-height: 1;
        letter-spacing: .01em;
        white-space: nowrap;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, .05);
        transition: border-color .22s ease, background .22s ease, color .22s ease;
    }

    .post-card-compact .post-summary {
        margin-bottom: 0;
    }

    @@media (max-width: 700px) {
        .post-card-meta {
            position: static;
            justify-content: flex-end;
            margin-bottom: 12px;
        }

        .post-card-top,
        .post-title,
        .post-summary,
        .post-card-tag-collapsed .post-card-top,
        .post-card-tag-collapsed .post-title,
        .post-card-tag-collapsed .post-summary {
            padding-right: 0;
        }
    }

    @@media (prefers-reduced-motion: reduce) {
        .post-card {
            transition: none;
        }

            .post-card:hover {
                transform: none;
            }
    }
</style>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Summary { get; set; } = string.Empty;
    [Parameter] public string StepTitle { get; set; } = string.Empty;
    [Parameter] public string Level { get; set; } = "Intermediate";
    [Parameter] public string Focus { get; set; } = "Practical";
    [Parameter] public string Url { get; set; } = "#";
    [Parameter] public IEnumerable<string>? TechStack { get; set; }
    [Parameter] public int? ArticleOrder { get; set; }

    private bool IsExtensiveArticleCard =>
        Configuration.GetValue<bool>("Features:ExtensiveStandardArticleCard");

    private bool ShouldCollapseArticleCardTag =>
        Configuration.GetValue<bool>("Features:CollapseArticleCardTagByDefault");

    private bool ShouldShowArticleCardTag =>
        !ShouldCollapseArticleCardTag &&
        !string.IsNullOrWhiteSpace(StepTitle);

    private string PostCardCssClass =>
        $"post-card {(IsExtensiveArticleCard ? "post-card-extensive" : "post-card-compact")} {(ShouldShowArticleCardTag ? string.Empty : "post-card-tag-collapsed")}";

    private void OpenArticle()
    {
        if (!string.IsNullOrWhiteSpace(Url) && Url != "#")
        {
            Navigation.NavigateTo(Url);
        }
    }

    private void OpenArticleFromKeyboard(KeyboardEventArgs args)
    {
        if (args.Key is "Enter" or " ")
        {
            OpenArticle();
        }
    }
}
