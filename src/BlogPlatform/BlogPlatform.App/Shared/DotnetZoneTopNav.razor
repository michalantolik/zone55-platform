@inject NavigationManager Navigation

<nav class="dotnet-zone-top-nav" aria-label=".NET roadmap zones">
    @foreach (var level in Levels.OrderBy(level => level.Number))
    {
        <div class="dotnet-zone-tab-shell">
            <a class="dotnet-zone-tab @level.AccentClass @(IsActive(level) ? "active" : null)"
                   href="@GetZoneUrl(level)">
                <strong>@GetShortTitle(level.Title)</strong>
            </a>

            @if (!IsLast(level))
            {
                <span class="dotnet-zone-connector dotnet-zone-connector-@level.Number" aria-hidden="true"></span>
            }
        </div>
    }
</nav>

@code {
    [Parameter]
    public IReadOnlyCollection<LearningPathLevel> Levels { get; set; } = [];

    private bool IsActive(LearningPathLevel level)
    {
        var selectedZone = GetZoneFromPath()
            ?? GetQueryValue("zone")
            ?? Levels.OrderBy(item => item.Number).FirstOrDefault()?.Key;

        return string.Equals(level.Key, selectedZone, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsLast(LearningPathLevel level)
    {
        var lastLevel = Levels
            .OrderBy(item => item.Number)
            .LastOrDefault();

        return lastLevel is not null && lastLevel.Number == level.Number;
    }

    private static string GetZoneUrl(LearningPathLevel level)
    {
        var firstStep = level.Steps.OrderBy(step => step.StepOrder).FirstOrDefault();

        if (firstStep is null)
        {
            return $"/{Uri.EscapeDataString(level.Key)}";
        }

        return $"/{Uri.EscapeDataString(level.Key)}/{Uri.EscapeDataString(firstStep.Key)}";
    }

    private static string GetShortTitle(string title) =>
        title switch
        {
            "Web & Apps" => "Web & Apps",
            _ => title
        };

    private string? GetZoneFromPath()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var pathSegments = uri.AbsolutePath
            .Trim('/')
            .Split('/', StringSplitOptions.RemoveEmptyEntries);

        return pathSegments.Length >= 2
            ? Uri.UnescapeDataString(pathSegments[0])
            : null;
    }

    private string? GetQueryValue(string name)
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);

        if (string.IsNullOrWhiteSpace(uri.Query))
        {
            return null;
        }

        foreach (var parameter in uri.Query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = parameter.Split('=', 2);
            var parameterName = Uri.UnescapeDataString(parts[0]);

            if (!string.Equals(parameterName, name, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            return parts.Length == 2
                ? Uri.UnescapeDataString(parts[1])
                : null;
        }

        return null;
    }
}
