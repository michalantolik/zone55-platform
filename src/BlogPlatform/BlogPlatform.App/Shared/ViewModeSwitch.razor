<section class="content-view-selector">
    <div class="content-view-selector-header">
        <span class="content-view-selector-kicker">
            CONTENT VIEW
        </span>

        <h3>
            Choose how to explore the blog
        </h3>

        <p>
            Browse the newest engineering notes or switch to a guided
            .NET learning roadmap organized from fundamentals to
            cloud and architecture topics.
        </p>
    </div>

    <div class="content-view-selector-buttons">
        <a class="content-view-button @(CurrentView == "latest" ? "active" : null)"
               href="/?view=latest">

            <div class="content-view-button-top">
                <span class="content-view-indicator"></span>

                <strong>
                    Latest Engineering Notes
                </strong>
            </div>

            <small>
                Traditional blog view sorted by newest content.
            </small>
        </a>

        <a class="content-view-button @(CurrentView == "path" ? "active" : null)"
               href="/?view=path">

            <div class="content-view-button-top">
                <span class="content-view-indicator"></span>

                <strong>
                    Guided .NET Roadmap
                </strong>
            </div>

            <small>
                Structured backend and cloud engineering learning path.
            </small>
        </a>
    </div>
</section>

@code {
    [Parameter]
    public string CurrentView { get; set; } = "latest";
}
