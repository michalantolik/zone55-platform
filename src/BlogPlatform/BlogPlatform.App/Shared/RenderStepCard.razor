@using BlogPlatform.App.Models

<article class="learning-path-step-card">
    <div class="learning-path-step-top">
        <span>Step @Step.GlobalOrder</span>
        <em>@Step.Difficulty</em>
    </div>

    <h4>@Step.Title</h4>

    <p>@Step.Description</p>

    <div class="learning-path-step-meta">
        <span>@Step.Posts.Count article(s)</span>
        <span>Recommended</span>
    </div>

    @if (Step.Posts.Any())
    {
        <div class="learning-path-step-posts">
            @foreach (var post in Step.Posts.Take(3))
            {
                <a href="/articles/@post.Slug">
                    @post.Title
                </a>
            }
        </div>
    }
    else
    {
        <div class="learning-path-step-empty">
            No matching articles yet.
        </div>
    }
</article>

@code {
    [Parameter, EditorRequired]
    public LearningPathStep Step { get; set; } = default!;
}
