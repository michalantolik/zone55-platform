<section class="learning-path-shell">
    <div class="learning-path-journey">
        @foreach (var level in Levels)
        {
            <div class="learning-path-zone-header @level.AccentClass">
                <span>Zone @level.Number.ToString("00")</span>
                <h4>@level.Title</h4>
            </div>
        }

        @foreach (var level in Levels)
        {
            <div class="learning-path-zone-steps">
                @foreach (var step in level.Steps)
                {
                    <a class="@GetStepCssClass()" href="@GetStepUrl(level, step)">
                        <span>@step.StepOrder</span>

                        <strong>@step.Title</strong>

                        @if (DisplayStepArticleCounts)
                        {
                            <small>
                                @(step.Posts.Count == 0
                                    ? "No articles yet"
                                    : $"{step.Posts.Count} article(s)")
                            </small>
                        }
                    </a>
                }
            </div>
        }
    </div>

    <section class="learning-path-page-story" aria-label="Zone55 project story and public links">
        <article class="learning-path-info-card learning-path-why-card">
            <div class="learning-path-info-kicker">Why Zone55 exists</div>

            <div class="learning-path-quote-mark" aria-hidden="true">“</div>

            <p>
                After 15 years building enterprise software, cloud solutions and automation platforms,
                I wanted one place to organize practical engineering knowledge.
            </p>

            <strong>
                Zone55 is both a learning platform and a real cloud project continuously built in public.
            </strong>

            <a class="learning-path-card-action" href="/about">
                Learn more about Zone55 <span aria-hidden="true">→</span>
            </a>
        </article>

        <article class="learning-path-info-card learning-path-passport-card">
            <div class="learning-path-info-kicker">Engineering Passport</div>

            <div class="learning-path-passport-main">
                <div class="learning-path-avatar" aria-hidden="true">
                    <span>MA</span>
                    <i></i>
                </div>

                <div class="learning-path-passport-copy">
                    <h3>Michał Antolik</h3>
                    <p>.NET Backend &amp; Cloud Engineer</p>

                    <div class="learning-path-skill-tags" aria-label="Core skills">
                        <span>15 Years</span>
                        <span>Azure</span>
                        <span>Terraform</span>
                        <span>GitHub Actions</span>
                        <span>.NET</span>
                        <span>C#</span>
                        <span>ASP.NET Core</span>
                        <span>Cloud</span>
                        <span>DevOps</span>
                    </div>
                </div>
            </div>

            <div class="learning-path-passport-stats">
                <span><small>Experience</small><strong>15+ Years</strong></span>
                <span><small>Projects</small><strong>10+</strong></span>
                <span><small>Certifications</small><strong>3 Microsoft</strong></span>
                <span><small>Focus</small><strong>Platform Engineering</strong></span>
            </div>

            <div class="learning-path-passport-actions">
                <a class="learning-path-card-action learning-path-card-action-primary" href="/about">
                    About the author <span aria-hidden="true">→</span>
                </a>
                <a class="learning-path-card-action learning-path-card-action-secondary" href="https://www.linkedin.com" target="_blank" rel="noreferrer">
                    LinkedIn
                </a>
                <a class="learning-path-card-action learning-path-card-action-secondary" href="https://github.com/michalantolik/zone55" target="_blank" rel="noreferrer">
                    GitHub
                </a>
            </div>
        </article>

        <article class="learning-path-info-card learning-path-public-card">
            <div class="learning-path-info-kicker">Zone55 in public</div>

            <div class="learning-path-public-links">
                <a href="https://github.com/michalantolik/zone55" target="_blank" rel="noreferrer">
                    <span aria-hidden="true">●</span>
                    <strong>GitHub Repository</strong>
                    <small>github.com/michalantolik/zone55</small>
                    <em aria-hidden="true">›</em>
                </a>

                <a href="https://github.com/michalantolik/zone55/commits" target="_blank" rel="noreferrer">
                    <span aria-hidden="true">◷</span>
                    <strong>Latest Commit</strong>
                    <small>2 hours ago</small>
                    <em aria-hidden="true">›</em>
                </a>

                <a href="/">
                    <span aria-hidden="true">&lt;/&gt;</span>
                    <strong>Built With</strong>
                    <small>.NET • Azure • Terraform • GitHub Actions</small>
                    <em aria-hidden="true">›</em>
                </a>

                <a href="/">
                    <span aria-hidden="true">☁</span>
                    <strong>Infrastructure</strong>
                    <small>100% Cloud (Azure)</small>
                    <em aria-hidden="true">›</em>
                </a>
            </div>
        </article>
    </section>

    <footer class="learning-path-footer">
        <span>© 2025 Zone55. All rights reserved.</span>
        <span class="learning-path-footer-heart">♡ Built with passion for engineering and learning</span>
        <nav aria-label="Footer links">
            <a href="/about">About Author</a>
            <a href="https://github.com/michalantolik/zone55" target="_blank" rel="noreferrer">GitHub</a>
            <a href="https://www.linkedin.com" target="_blank" rel="noreferrer">LinkedIn</a>
            <a href="/privacy">Privacy</a>
        </nav>
    </footer>
</section>

@code {
    [Parameter]
    public IReadOnlyCollection<LearningPathLevel> Levels { get; set; } = [];

    [Parameter]
    public bool DisplayStepArticleCounts { get; set; } = true;

    private string GetStepCssClass()
    {
        return DisplayStepArticleCounts
            ? "learning-path-zone-step"
            : "learning-path-zone-step learning-path-zone-step-compact";
    }

    private static string GetStepUrl(
        LearningPathLevel level,
        LearningPathStep step)
    {
        return $"/{Uri.EscapeDataString(level.Key)}/{Uri.EscapeDataString(step.Key)}";
    }
}
