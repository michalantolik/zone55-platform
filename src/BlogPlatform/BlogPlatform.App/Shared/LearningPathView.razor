<section class="learning-path-shell">
    <div class="learning-path-journey" aria-label="Zone55 learning roadmap">
        @foreach (var item in OrderedLevels.Select((level, index) => new { Level = level, Index = index }))
        {
            <article class="learning-path-zone-card @GetZoneVisualClass(item.Level)">
                <header class="learning-path-zone-card-header">
                    <div class="learning-path-zone-icon" aria-hidden="true">@GetZoneIcon(item.Level)</div>
                    <div>
                        <span>Zone @item.Level.Number.ToString("00")</span>
                        <h2>@item.Level.Title</h2>
                    </div>
                </header>

                <div class="learning-path-zone-steps" aria-label="@item.Level.Title steps">
                    @foreach (var step in item.Level.Steps.OrderBy(step => step.StepOrder))
                    {
                        <a class="@GetStepCssClass(item.Level)" href="@GetStepUrl(item.Level, step)">
                            <span>@step.StepOrder</span>
                            <strong>@step.Title</strong>

                            @if (DisplayStepArticleCounts)
                            {
                                <small>
                                    @(step.Articles.Count == 0
                                        ? "No articles yet"
                                        : $"{step.Articles.Count} article(s)")
                                </small>
                            }
                        </a>
                    }
                </div>

                @if (item.Index < OrderedLevels.Count - 1)
                {
                    var nextLevel = OrderedLevels[item.Index + 1];

                    <div class="learning-path-zone-connector @GetZoneConnectorClass(item.Level, nextLevel)" aria-hidden="true">
                        <svg class="learning-path-zone-connector-svg" viewBox="0 0 100 128" preserveAspectRatio="none" focusable="false">
                            <defs>
                                <linearGradient id="learning-path-zone-connector-gradient-@item.Index" x1="0%" y1="0%" x2="100%" y2="0%">
                                    <stop offset="0%" stop-color="rgb(var(--connector-from-rgb))" stop-opacity="0.18" />
                                    <stop offset="10%" stop-color="rgb(var(--connector-from-rgb))" stop-opacity="0.48" />
                                    <stop offset="24%" stop-color="rgb(var(--connector-from-rgb))" stop-opacity="0.92" />
                                    <stop offset="42%" stop-color="rgb(var(--connector-from-rgb))" stop-opacity="0.86" />
                                    <stop offset="58%" stop-color="rgb(var(--connector-to-rgb))" stop-opacity="0.92" />
                                    <stop offset="76%" stop-color="rgb(var(--connector-to-rgb))" stop-opacity="0.86" />
                                    <stop offset="90%" stop-color="rgb(var(--connector-to-rgb))" stop-opacity="0.46" />
                                    <stop offset="100%" stop-color="rgb(var(--connector-to-rgb))" stop-opacity="0.18" />
                                </linearGradient>
                                <linearGradient id="learning-path-zone-connector-fade-@item.Index" x1="0%" y1="0%" x2="0%" y2="100%">
                                    <stop offset="0%" stop-color="white" stop-opacity="0.18" />
                                    <stop offset="15%" stop-color="white" stop-opacity="0.44" />
                                    <stop offset="32%" stop-color="white" stop-opacity="0.82" />
                                    <stop offset="48%" stop-color="white" stop-opacity="1" />
                                    <stop offset="62%" stop-color="white" stop-opacity="0.94" />
                                    <stop offset="83%" stop-color="white" stop-opacity="0.46" />
                                    <stop offset="100%" stop-color="white" stop-opacity="0.18" />
                                </linearGradient>
                                <mask id="learning-path-zone-connector-mask-@item.Index" maskUnits="userSpaceOnUse" x="-24" y="-24" width="148" height="176">
                                    <rect x="-24" y="-24" width="148" height="176" fill="url(#learning-path-zone-connector-fade-@item.Index)" />
                                </mask>
                            </defs>
                            <g mask="url(#learning-path-zone-connector-mask-@item.Index)">
                                <path class="learning-path-zone-connector-cut" d="M 0 0 L 0 45 C 0 55 5 60 15 60 L 85 60 C 95 60 100 65 100 75 L 100 128" pathLength="100" />
                                <path class="learning-path-zone-connector-aura" d="M 0 0 L 0 45 C 0 55 5 60 15 60 L 85 60 C 95 60 100 65 100 75 L 100 128" pathLength="100" />
                                <path class="learning-path-zone-connector-glow" d="M 0 0 L 0 45 C 0 55 5 60 15 60 L 85 60 C 95 60 100 65 100 75 L 100 128" pathLength="100" />
                                <path class="learning-path-zone-connector-path" d="M 0 0 L 0 45 C 0 55 5 60 15 60 L 85 60 C 95 60 100 65 100 75 L 100 128" pathLength="100" stroke="url(#learning-path-zone-connector-gradient-@item.Index)" />
                                <path class="learning-path-zone-connector-core" d="M 0 0 L 0 45 C 0 55 5 60 15 60 L 85 60 C 95 60 100 65 100 75 L 100 128" pathLength="100" />
                                <path class="learning-path-zone-connector-bright" d="M 0 0 L 0 45 C 0 55 5 60 15 60 L 85 60 C 95 60 100 65 100 75 L 100 128" pathLength="100" />
                            </g>
                        </svg>
                        <span class="learning-path-zone-arrow">›</span>
                    </div>
                }
            </article>
        }
    </div>

    <section class="learning-path-page-story" aria-label="Zone55 project story and public links">
