@code {
    [Parameter]
    public IReadOnlyCollection<LearningPathLevel> Levels { get; set; } = [];

    [Parameter]
    public bool DisplayStepArticleCounts { get; set; } = true;

    private IReadOnlyList<LearningPathLevel> OrderedLevels =>
        Levels.OrderBy(level => level.Number).ToList();

    private string GetStepCssClass(LearningPathLevel level)
    {
        var classes = $"learning-path-zone-step {GetZoneVisualClass(level)}";

        return DisplayStepArticleCounts
            ? classes
            : $"{classes} learning-path-zone-step-compact";
    }

    private static string GetZoneVisualClass(LearningPathLevel level) =>
        level.Number switch
        {
            1 => "learning-path-zone-foundation",
            2 => "learning-path-zone-web",
            3 => "learning-path-zone-architecture",
            4 => "learning-path-zone-cloud",
            _ => level.AccentClass
        };

    private static string GetZoneConnectorClass(
        LearningPathLevel currentLevel,
        LearningPathLevel nextLevel) =>
        $"learning-path-zone-connector-{currentLevel.Number}-to-{nextLevel.Number}";

    private static string GetZoneIcon(LearningPathLevel level) =>
        level.Number switch
        {
            1 => "▰",
            2 => "◎",
            3 => "◫",
            4 => "☁",
            _ => "◆"
        };

    private static string GetStepUrl(
        LearningPathLevel level,
        LearningPathStep step)
    {
        return $"/{Uri.EscapeDataString(level.Key)}/{Uri.EscapeDataString(step.Key)}";
    }
}
