@page "/preview/article"
@layout PreviewLayout
@implements IDisposable

@using System.Text.Json
@using BlogPlatform.App.Components.Articles.LearnKitRendering
@using BlogPlatform.App.Components.Articles.LearnKitRendering.Serialization
@using BlogPlatform.App.Models
@using BlogPlatform.App.Models.LearnKit
@using BlogPlatform.App.Models.LearnKit.Articles
@using BlogPlatform.App.Services
@using Microsoft.JSInterop

@inject IJSRuntime JS
@inject IPreviewDiagnosticsClient Diagnostics

<PageTitle>Article preview</PageTitle>

<style>
    html {
        scrollbar-width: thin;
        scrollbar-color: rgba(132, 187, 255, 0.75) rgba(6, 19, 37, 0.9);
    }

    body::-webkit-scrollbar {
        width: 12px;
    }

    body::-webkit-scrollbar-track {
        background: rgba(6, 19, 37, 0.95);
        border-radius: 999px;
    }

    body::-webkit-scrollbar-thumb {
        min-height: 80px;
        border: 3px solid rgba(6, 19, 37, 0.95);
        border-radius: 999px;
        background: linear-gradient(180deg, #84bbff, #1677ff);
    }

        body::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(180deg, #b7d8ff, #4ea1ff);
        }

    body::-webkit-scrollbar-corner {
        background: rgba(6, 19, 37, 0.95);
    }
</style>

<section class="article-shell container-xl" @key="_renderKey">
    @if (_article is null)
    {
        <article class="article-card">
            <h1>Waiting for preview data...</h1>
            <p>Open this page inside the CMS preview iframe.</p>
        </article>
    }
    else
    {
        <LearnKitArticleRenderer Article="_article" @key="_renderKey" />
    }
</section>

@code {
    private LearnKitArticleDetails? _article;
    private DotNetObjectReference<ArticlePreview>? _objectReference;
    private int _renderKey;
    private int _lastSequence;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            await Diagnostics.WriteAsync(
                "APP",
                "ArticlePreview.AfterRender",
                _lastSequence,
                $"Render completed. RenderKey={_renderKey}; Title={_article?.Title}");

            return;
        }

        _objectReference = DotNetObjectReference.Create(this);

        await JS.InvokeVoidAsync(
            "blogPlatformPreview.register",
            _objectReference);

        await Diagnostics.WriteAsync(
            "APP",
            "ArticlePreview.Registered",
            0,
            "Preview JS listener registered.");
    }

    [JSInvokable]
    public async Task LoadPreviewArticle(string json, int sequence)
    {
        try
        {
            await Diagnostics.WriteAsync(
                "APP",
                "LoadPreviewArticle.Start",
                sequence,
                $"JsonIsNull={json is null}; JsonLength={json?.Length ?? 0}");

            var previewArticle = JsonSerializer.Deserialize<PostDetails>(
                json,
                new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });

            await Diagnostics.WriteAsync(
                "APP",
                "AfterDeserialize",
                sequence,
                $"ArticleIsNull={previewArticle is null}; Title={previewArticle?.Title}; BodyHtmlIsNull={previewArticle?.BodyHtml is null}");

            if (previewArticle is null)
            {
                return;
            }

            var article = LegacyPreviewArticleMapper.ToLearnKitArticle(previewArticle);

            _article = article;
            _lastSequence = sequence;
            _renderKey++;

            await Diagnostics.WriteAsync(
                "APP",
                "BeforeStateHasChanged",
                sequence,
                $"Title={_article.Title}; SummaryLength={_article.Summary?.Length ?? 0}; Blocks={_article.Blocks.Count}; RenderKey={_renderKey}");

            await InvokeAsync(StateHasChanged);

            await Diagnostics.WriteAsync(
                "APP",
                "AfterStateHasChanged",
                sequence,
                $"StateHasChanged completed. Title={_article.Title}; RenderKey={_renderKey}");

            await JS.InvokeVoidAsync(
                "blogPlatformPreview.sendAck",
                sequence,
                _article.Title,
                _article.Blocks.Count);

            await Diagnostics.WriteAsync(
                "APP",
                "AfterAck",
                sequence,
                $"ACK sent. Title={_article.Title}; Blocks={_article.Blocks.Count}; RenderKey={_renderKey}");
        }
        catch (Exception ex)
        {
            await Diagnostics.WriteAsync(
                "APP",
                "LoadPreviewArticle.Exception",
                sequence,
                $"{ex.GetType().Name}: {ex.Message}");

            throw;
        }
    }

    public void Dispose()
    {
        _objectReference?.Dispose();
    }
}
