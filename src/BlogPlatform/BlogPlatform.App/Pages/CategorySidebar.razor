<div class="sidebar-inner">
    <a class="category-pill @(string.IsNullOrWhiteSpace(ActiveSlug) ? "active" : null)"
           href="/?view=DotnetStandard">
        <span class="category-icon"></span>
        <strong>All notes</strong>
    </a>

    @foreach (var category in Categories)
    {
        <a class="category-pill @(ActiveSlug == category.Slug ? "active" : null)"
               href="@GetCategoryUrl(category.Slug)">
            <span class="category-icon"></span>
            <strong>@category.Name</strong>
            <em>@category.Count</em>
        </a>
    }

    <div class="author-card">
        <small>About the author</small>
        <h5>Michał</h5>
        <p>
            .NET backend developer focused on cloud-ready systems,
            APIs, CI/CD, and practical software architecture.
        </p>
    </div>
</div>

@code {
    private const string DotnetStandardView = "DotnetStandard";

    [Parameter]
    public string? ActiveSlug { get; set; }

    [Parameter]
    public IReadOnlyCollection<CategoryItem> Categories { get; set; } = [];

    private static string GetCategoryUrl(string slug)
    {
        return $"/?view={DotnetStandardView}&category={Uri.EscapeDataString(slug)}";
    }
}
