@page "/articles/{Slug}"
@using BlogPlatform.App.Components.DotnetZoneLayout
@using BlogPlatform.App.Components.Articles
@inject IBlogApiClient BlogApi

@if (_isLoading)
{
    <PageTitle>Loading article...</PageTitle>

    <section class="article-shell container-xl">
        <article class="article-card">
            <p>Loading article from Umbraco CMS...</p>
        </article>
    </section>
}
else if (_article is null)
{
    <PageTitle>Article not found</PageTitle>

    <section class="article-shell container-xl">
        <article class="article-card">
            <h1>Article not found</h1>
            <p>The requested article does not exist or is not published.</p>
            <p><a href="/">← Back to all notes</a></p>
        </article>
    </section>
}
else
{
    <PageTitle>@_article.Title | .NET Backend & Cloud Engineering Notes</PageTitle>

    <section class="article-shell container-xl">
        @if (IsDotnetZonesArticleContext)
        {
            <ArticleReaderContext Article="_article" Posts="_posts" />
        }
        else
        {
            <div class="article-top">
                <div class="breadcrumbs">
                    <a href="/">← All notes</a>
                    <span>›</span>
                    <a href="/?category=@_article.CategorySlug">@_article.Category</a>
                    <span>›</span>
                    <strong>@_article.Title</strong>
                </div>

                <a class="browse-button" href="/">Browse all notes</a>
            </div>

            <ArticleRenderer Article="_article" />
        }
    </section>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "visualization")]
    public string? Visualization { get; set; }

    private PostDetails? _article;
    private IReadOnlyCollection<PostListItem> _posts = [];
    private bool _isLoading = true;

    private bool IsDotnetZonesArticleContext =>
        string.Equals(
            Visualization,
            nameof(LearningPathVisualizationType.DotnetZones),
            StringComparison.OrdinalIgnoreCase);

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;

        _article = await BlogApi.GetPostBySlugAsync(Slug);

        _posts = IsDotnetZonesArticleContext
            ? await BlogApi.GetPostsAsync(null)
            : [];

        _isLoading = false;
    }
}
