@page "/articles/{Slug}"
@using System.IO.Compression
@using System.Text
@using System.Text.Encodings.Web
@using System.Text.Json
@using Microsoft.JSInterop
@inject IBlogApiClient BlogApi
@inject IJSRuntime JS

@if (_isLoading)
{
    <PageTitle>Loading article...</PageTitle>

    <section class="article-shell container-xl">
        <article class="article-card">
            <p>Loading article from Umbraco CMS...</p>
        </article>
    </section>
}
else if (_article is null)
{
    <PageTitle>Article not found</PageTitle>

    <section class="article-shell container-xl">
        <article class="article-card">
            <h1>Article not found</h1>
            <p>The requested article does not exist or is not published.</p>
            <p><a href="/">← Back to all notes</a></p>
        </article>
    </section>
}
else
{
    <PageTitle>@_article.Title | .NET Backend & Cloud Engineering Notes</PageTitle>

    <section class="article-shell container-xl">
        <div class="article-top">
            <div class="breadcrumbs">
                <a href="/">← All notes</a>
                <span>›</span>
                <a href="/?category=@_article.CategorySlug">@_article.Category</a>
                <span>›</span>
                <strong>@_article.Title</strong>
            </div>

            <a class="browse-button" href="/">Browse all notes</a>
        </div>

        <article class="article-card">
            <div class="tag-row">
                @foreach (var tag in _article.Tags)
                {
                    <span>@tag</span>
                }
            </div>

            <h1>@_article.Title</h1>

            <div class="article-meta">
                <strong>Engineering note</strong>
                <span>·</span>
                <span>Michał Antolik</span>
                <span>·</span>
                <span>@_article.Category</span>
            </div>

            <div class="article-summary">
                @_article.Summary
            </div>

            <div class="article-body">
                @foreach (var block in _blocks)
                {
                    @switch (block.Type)
                    {
                        case ArticleBlockType.Heading:
                            <DynamicComponent Type="@GetHeadingComponent(block.Level)" Parameters="@CreateHeadingParameters(block.Text)" />
                            break;

                        case ArticleBlockType.Text:
                            <p>@block.Text</p>
                            break;

                        case ArticleBlockType.Code:
                            <figure class="code-block">
                                <div class="snippet-toolbar">
                                    <figcaption>@(block.FileName ?? block.Language ?? "code")</figcaption>
                                    <button type="button" class="copy-button" @onclick="() => CopyToClipboardAsync(block.Code)">Copy</button>
                                </div>
                                <pre><code class="language-@block.Language">@foreach (var line in GetCodeLines(block.Code))
                                    {
                                        <span class="code-line"><span class="line-number">@line.Number</span><span class="line-content">@line.Text</span></span>
                                    }
                                </code></pre>
                            </figure>
                            break;

                        case ArticleBlockType.Mermaid:
                            <figure class="diagram-block mermaid-block">
                                <figcaption>Mermaid diagram</figcaption>
                                <pre class="mermaid">@block.Diagram</pre>
                            </figure>
                            break;

                        case ArticleBlockType.PlantUml:
                            <figure class="diagram-block plantuml-block">
                                <figcaption>PlantUML diagram</figcaption>
                                <img src="@CreatePlantUmlUrl(block.Diagram, _plantUmlTheme)" alt="PlantUML diagram" />
                                <details>
                                    <summary class="plantuml-source-summary">PlantUML source</summary>
                                    <div class="snippet-toolbar snippet-toolbar-nested">
                                        <figcaption>context.puml</figcaption>
                                        <button type="button" class="copy-button" @onclick="() => CopyToClipboardAsync(block.Diagram)">Copy</button>
                                    </div>
                                    <pre><code class="language-plantuml">@foreach (var line in GetCodeLines(block.Diagram))
                                        {
                                            <span class="code-line"><span class="line-number">@line.Number</span><span class="line-content">@line.Text</span></span>
                                        }
                                    </code></pre>
                                </details>
                            </figure>
                            break;

                        case ArticleBlockType.Callout:
                            <aside class="callout callout-@block.Kind">
                                <strong>@block.Kind</strong>
                                <p>@block.Text</p>
                            </aside>
                            break;
                    }
                }
            </div>
        </article>
    </section>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private PostDetails? _article;
    private bool _isLoading = true;
    private bool _shouldRenderDiagrams;
    private bool _shouldLoadDiagramTheme;
    private PlantUmlThemeSettings _plantUmlTheme = PlantUmlThemeSettings.Default;
    private IReadOnlyCollection<ArticleBlock> _blocks = [];

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;

        _article = await BlogApi.GetPostBySlugAsync(Slug);
        _blocks = ParseBlocks(_article?.BodyHtml);

        _isLoading = false;
        _shouldLoadDiagramTheme = true;
        _shouldRenderDiagrams = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldLoadDiagramTheme)
        {
            _shouldLoadDiagramTheme = false;

            var updatedTheme = await LoadPlantUmlThemeSettingsAsync();

            if (updatedTheme != _plantUmlTheme)
            {
                _plantUmlTheme = updatedTheme;
                StateHasChanged();
                return;
            }
        }

        if (_shouldRenderDiagrams)
        {
            _shouldRenderDiagrams = false;
            await JS.InvokeVoidAsync("blogPlatformArticle.renderDiagrams");
        }
    }

    private static IReadOnlyCollection<ArticleBlock> ParseBlocks(string? rawJson)
    {
        if (string.IsNullOrWhiteSpace(rawJson))
        {
            return [];
        }

        using var document = JsonDocument.Parse(rawJson);

        var root = document.RootElement;

        var layoutItems = root
            .GetProperty("layout")
            .GetProperty("Umbraco.BlockList")
            .EnumerateArray()
            .ToList();

        var contentData = root
            .GetProperty("contentData")
            .EnumerateArray()
            .ToDictionary(
                x => x.GetProperty("udi").GetString() ?? string.Empty,
                x => x);

        var blocks = new List<ArticleBlock>();

        foreach (var layoutItem in layoutItems)
        {
            var contentUdi = layoutItem.GetProperty("contentUdi").GetString();

            if (string.IsNullOrWhiteSpace(contentUdi) ||
                !contentData.TryGetValue(contentUdi, out var block))
            {
                continue;
            }

            blocks.Add(ParseBlock(block));
        }

        return blocks;
    }

    private static ArticleBlock ParseBlock(JsonElement block)
    {
        var text = GetString(block, "text");
        var level = GetInt(block, "level") ?? 2;
        var code = GetString(block, "code");
        var diagram = GetString(block, "diagram");
        var kind = GetString(block, "kind");
        var language = GetString(block, "language");
        var fileName = GetString(block, "fileName");

        if (!string.IsNullOrWhiteSpace(code))
        {
            return new ArticleBlock(ArticleBlockType.Code)
            {
                Code = code,
                Language = language,
                FileName = fileName
            };
        }

        if (!string.IsNullOrWhiteSpace(diagram))
        {
            return diagram.TrimStart().StartsWith("@startuml", StringComparison.OrdinalIgnoreCase)
                ? new ArticleBlock(ArticleBlockType.PlantUml) { Diagram = diagram }
                : new ArticleBlock(ArticleBlockType.Mermaid) { Diagram = diagram };
        }

        if (!string.IsNullOrWhiteSpace(kind))
        {
            return new ArticleBlock(ArticleBlockType.Callout)
            {
                Kind = kind,
                Text = text
            };
        }

        if (block.TryGetProperty("level", out _))
        {
            return new ArticleBlock(ArticleBlockType.Heading)
            {
                Level = Math.Clamp(level, 2, 4),
                Text = text
            };
        }

        return new ArticleBlock(ArticleBlockType.Text)
        {
            Text = text
        };
    }

    private static string? GetString(JsonElement element, string propertyName)
    {
        return element.TryGetProperty(propertyName, out var value)
            ? value.GetString()
            : null;
    }

    private static int? GetInt(JsonElement element, string propertyName)
    {
        return element.TryGetProperty(propertyName, out var value) &&
               value.TryGetInt32(out var number)
            ? number
            : null;
    }

    private static Type GetHeadingComponent(int level)
    {
        return level switch
        {
            3 => typeof(H3),
            4 => typeof(H4),
            _ => typeof(H2)
        };
    }

    private static Dictionary<string, object?> CreateHeadingParameters(string? text)
    {
        return new Dictionary<string, object?>
        {
            ["ChildContent"] = (RenderFragment)(builder => builder.AddContent(0, text))
        };
    }

    private async Task CopyToClipboardAsync(string? value)
    {
        if (!string.IsNullOrEmpty(value))
        {
            await JS.InvokeVoidAsync("blogPlatformArticle.copyToClipboard", value);
        }
    }

    private static IReadOnlyCollection<CodeLine> GetCodeLines(string? code)
    {
        if (string.IsNullOrEmpty(code))
        {
            return [];
        }

        return code
            .Replace("\r\n", "\n", StringComparison.Ordinal)
            .Split('\n')
            .Select((text, index) => new CodeLine(index + 1, text))
            .ToArray();
    }

    private async Task<PlantUmlThemeSettings> LoadPlantUmlThemeSettingsAsync()
    {
        var fontFamily = await GetThemeValueAsync("--diagram-font-family", PlantUmlThemeSettings.Default.FontFamily);
        var textColor = await GetThemeValueAsync("--diagram-plantuml-node-text", PlantUmlThemeSettings.Default.TextColor);
        var arrowColor = await GetThemeValueAsync("--diagram-plantuml-line", PlantUmlThemeSettings.Default.ArrowColor);
        var nodeBackground = await GetThemeValueAsync("--diagram-plantuml-node-bg", PlantUmlThemeSettings.Default.NodeBackground);
        var nodeBorder = await GetThemeValueAsync("--diagram-plantuml-node-border", PlantUmlThemeSettings.Default.NodeBorder);

        return new PlantUmlThemeSettings(
            fontFamily,
            textColor,
            arrowColor,
            nodeBackground,
            nodeBorder);
    }

    private async Task<string> GetThemeValueAsync(string cssVariableName, string fallback)
    {
        var value = await JS.InvokeAsync<string>("blogPlatformArticle.getThemeValue", cssVariableName);

        return string.IsNullOrWhiteSpace(value)
            ? fallback
            : value;
    }

    private static string ApplyPlantUmlTheme(string source, PlantUmlThemeSettings themeSettings)
    {
        var theme = $$"""

skinparam backgroundColor transparent
skinparam defaultFontName {{themeSettings.FontFamily}}
skinparam defaultFontColor {{themeSettings.TextColor}}
skinparam ArrowColor {{themeSettings.ArrowColor}}

skinparam rectangle {
    BackgroundColor {{themeSettings.NodeBackground}}
    BorderColor {{themeSettings.NodeBorder}}
    FontColor {{themeSettings.TextColor}}
}

skinparam actor {
    BorderColor {{themeSettings.ArrowColor}}
    FontColor {{themeSettings.TextColor}}
}

skinparam shadowing false
skinparam roundcorner 8

""";

        return source.Replace("@startuml", $"@startuml{theme}", StringComparison.OrdinalIgnoreCase);
    }

    private static string CreatePlantUmlUrl(string? diagram, PlantUmlThemeSettings themeSettings)
    {
        if (string.IsNullOrWhiteSpace(diagram))
        {
            return string.Empty;
        }

        return $"https://www.plantuml.com/plantuml/svg/{EncodePlantUml(ApplyPlantUmlTheme(diagram, themeSettings))}";
    }

    private static string EncodePlantUml(string source)
    {
        var bytes = Encoding.UTF8.GetBytes(source);

        using var output = new MemoryStream();

        using (var deflate = new DeflateStream(output, CompressionLevel.SmallestSize, leaveOpen: true))
        {
            deflate.Write(bytes, 0, bytes.Length);
        }

        return EncodePlantUmlBytes(output.ToArray());
    }

    private static string EncodePlantUmlBytes(byte[] data)
    {
        const string alphabet = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz-_";

        var result = new StringBuilder();

        for (var i = 0; i < data.Length; i += 3)
        {
            var b1 = data[i];
            var b2 = i + 1 < data.Length ? data[i + 1] : 0;
            var b3 = i + 2 < data.Length ? data[i + 2] : 0;

            result.Append(alphabet[b1 >> 2]);
            result.Append(alphabet[((b1 & 0x3) << 4) | (b2 >> 4)]);
            result.Append(alphabet[((b2 & 0xF) << 2) | (b3 >> 6)]);
            result.Append(alphabet[b3 & 0x3F]);
        }

        return result.ToString();
    }

    private enum ArticleBlockType
    {
        Heading,
        Text,
        Code,
        Mermaid,
        PlantUml,
        Callout
    }

    private sealed record CodeLine(int Number, string Text);

    private sealed record PlantUmlThemeSettings(
        string FontFamily,
        string TextColor,
        string ArrowColor,
        string NodeBackground,
        string NodeBorder)
    {
        public static PlantUmlThemeSettings Default { get; } = new(
            "SansSerif",
            "#E5E7EB",
            "#A7B4C8",
            "#374151",
            "#7D8CA3");
    }

    private sealed class ArticleBlock
    {
        public ArticleBlock(ArticleBlockType type)
        {
            Type = type;
        }

        public ArticleBlockType Type { get; }

        public string? Text { get; init; }

        public int Level { get; init; } = 2;

        public string? Code { get; init; }

        public string? Language { get; init; }

        public string? FileName { get; init; }

        public string? Diagram { get; init; }

        public string? Kind { get; init; }
    }

    private sealed class H2 : ComponentBase
    {
        [Parameter] public RenderFragment? ChildContent { get; set; }

        protected override void BuildRenderTree(RenderTreeBuilder builder)
        {
            builder.OpenElement(0, "h2");
            builder.AddContent(1, ChildContent);
            builder.CloseElement();
        }
    }

    private sealed class H3 : ComponentBase
    {
        [Parameter] public RenderFragment? ChildContent { get; set; }

        protected override void BuildRenderTree(RenderTreeBuilder builder)
        {
            builder.OpenElement(0, "h3");
            builder.AddContent(1, ChildContent);
            builder.CloseElement();
        }
    }

    private sealed class H4 : ComponentBase
    {
        [Parameter] public RenderFragment? ChildContent { get; set; }

        protected override void BuildRenderTree(RenderTreeBuilder builder)
        {
            builder.OpenElement(0, "h4");
            builder.AddContent(1, ChildContent);
            builder.CloseElement();
        }
    }
}
