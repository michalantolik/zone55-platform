@page "/articles/{Slug}"

<PageTitle>@Article.Title | .NET Backend & Cloud Engineering Notes</PageTitle>

<section class="article-shell container-xl">
    <div class="article-top">
        <div class="breadcrumbs">
            <a href="/">← All notes</a>
            <span>›</span>
            <a href="/?category=@Article.CategorySlug">@Article.Category</a>
            <span>›</span>
            <strong>@Article.Title</strong>
        </div>

        <a class="browse-button" href="/articles">Browse all notes</a>
    </div>

    <article class="article-card">
        <div class="tag-row">
            @foreach (var tag in Article.Tags)
            {
                <span>@tag</span>
            }
        </div>

        <h1>@Article.Title</h1>

        <div class="article-meta">
            <strong>Engineering note</strong>
            <span>·</span>
            <span>Michał Antolik</span>
            <span>·</span>
            <span>@Article.Category</span>
        </div>

        <div class="article-summary">
            @Article.Description
        </div>

        <h2>Why this topic matters</h2>

        <p>
            This note is part of my .NET backend + cloud portfolio. The focus is not only theory,
            but how this decision affects real systems: maintainability, deployment, configuration,
            testing, and long-term ownership.
        </p>

        <h2>Practical approach</h2>

        <p>
            I prefer simple, explicit solutions first. A backend system should be understandable,
            deployable, and easy to change. The implementation should support local development,
            cloud environments, and automated deployment without unnecessary complexity.
        </p>

        <h2>What I would document</h2>

        <ul>
            <li>the problem this solves</li>
            <li>the chosen implementation approach</li>
            <li>trade-offs and alternatives</li>
            <li>how it works in development and cloud environments</li>
            <li>how it can be tested or automated</li>
        </ul>
    </article>
</section>

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private ArticleItem Article =>
        Articles.FirstOrDefault(x => x.Slug == Slug) ?? Articles[0];

    private static readonly ArticleItem[] Articles =
    {
        new(
            "aspnet-core-configuration-cloud-ready",
            "Backend (.NET)",
            "backend-dotnet",
            "How I structure configuration in ASP.NET Core",
            "A practical approach to appsettings, environments, Options pattern, and cloud-ready configuration.",
            new[] { ".NET", "ASP.NET Core", "Configuration", "Azure" }),

        new(
            "aspnet-core-authentication-authorization",
            "Backend (.NET)",
            "backend-dotnet",
            "Authentication and authorization in ASP.NET Core",
            "How I think about identity, access control, and secure backend endpoints in real projects.",
            new[] { ".NET", "Security", "Auth", "APIs" }),

        new(
            "github-actions-dotnet-ci-cd",
            "Cloud & DevOps",
            "cloud-devops",
            "CI/CD pipeline for a .NET application",
            "Build, test, and deploy workflow for a backend application using GitHub Actions.",
            new[] { "GitHub Actions", ".NET", "CI/CD", "Automation" }),

        new(
            "system-architecture-blog-platform",
            "Architecture",
            "architecture",
            "Architecture of this blog platform",
            "How this portfolio system is structured: frontend, backend, deployment, and documentation flow.",
            new[] { "Architecture", "PlantUML", ".NET", "Cloud" })
    };

    private sealed record ArticleItem(
        string Slug,
        string Category,
        string CategorySlug,
        string Title,
        string Description,
        string[] Tags);
}
