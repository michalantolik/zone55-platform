@page "/articles/{Slug}"
@inject IBlogApiClient BlogApi

@if (_isLoading)
{
    <PageTitle>Loading article...</PageTitle>

    <section class="article-shell container-xl">
        <article class="article-card">
            <p>Loading article from Umbraco CMS...</p>
        </article>
    </section>
}
else if (_article is null)
{
    <PageTitle>Article not found</PageTitle>

    <section class="article-shell container-xl">
        <article class="article-card">
            <h1>Article not found</h1>
            <p>The requested article does not exist or is not published.</p>
            <p><a href="/">← Back to all notes</a></p>
        </article>
    </section>
}
else
{
    <PageTitle>@_article.Title | .NET Backend & Cloud Engineering Notes</PageTitle>

    <section class="article-shell container-xl">
        <div class="article-top">
            <div class="breadcrumbs">
                <a href="/">← All notes</a>
                <span>›</span>
                <a href="/?category=@_article.CategorySlug">@_article.Category</a>
                <span>›</span>
                <strong>@_article.Title</strong>
            </div>

            <a class="browse-button" href="/articles">Browse all notes</a>
        </div>

        <article class="article-card">
            <div class="tag-row">
                @foreach (var tag in _article.Tags)
                {
                    <span>@tag</span>
                }
            </div>

            <h1>@_article.Title</h1>

            <div class="article-meta">
                <strong>Engineering note</strong>
                <span>·</span>
                <span>Michał Antolik</span>
                <span>·</span>
                <span>@_article.Category</span>
            </div>

            <div class="article-summary">
                @_article.Summary
            </div>

            @if (!string.IsNullOrWhiteSpace(_article.BodyHtml))
            {
                @((MarkupString)_article.BodyHtml)
            }
            else
            {
                <h2>Content managed in Umbraco</h2>
                <p>
                    This article metadata is loaded from Umbraco CMS through the API boundary.
                    Rich body rendering can be extended by mapping Umbraco block list content into
                    typed application content blocks.
                </p>
            }
        </article>
    </section>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private PostDetails? _article;
    private bool _isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _article = await BlogApi.GetPostBySlugAsync(Slug);
        _isLoading = false;
    }
}
