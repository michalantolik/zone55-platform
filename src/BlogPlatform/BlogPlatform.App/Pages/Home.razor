@page "/"
@page "/articles"
@inject IBlogApiClient BlogApi
@inject IConfiguration Configuration

<PageTitle>.NET Backend & Cloud Engineering Notes</PageTitle>

<section class="hero container-xl">
    <div class="hero-main">
        <div class="eyebrow">
            <span></span>
            Portfolio blog · .NET backend · cloud-ready systems
        </div>

        <h1>
            .NET Backend Engineer<br />
            <span>building cloud-ready systems</span>
        </h1>

        <p>
            I design and build APIs, backend services, and cloud solutions using .NET and Azure.
            This blog documents practical engineering decisions, patterns, and real-world implementations.
        </p>

        <div class="hero-tags">
            <span>.NET</span>
            <span>ASP.NET Core</span>
            <span>Azure</span>
            <span>CI/CD</span>
            <span>Architecture</span>
        </div>
    </div>

    <div class="hero-side">
        <div class="signal-card">
            <small>Primary focus</small>
            <strong>.NET Backend + Cloud</strong>
        </div>

        <div class="signal-card">
            <small>Engineering signal</small>
            <strong>APIs · DevOps · Architecture</strong>
        </div>

        <div class="author-visual-card">
            <div class="author-visual-image">
                <img src="/images/michal-cartoon.png"
                     alt="Cartoon-style photo representing the blog author working with technology" />
            </div>

            <div class="author-visual-text">
                <small>Personal engineering notebook</small>
                <strong>Practical notes from real implementation work</strong>
            </div>
        </div>
    </div>
</section>

<section class="intro-strip container-xl">
    <div>
        <h2>Current focus</h2>
        <ul>
            <li>ASP.NET Core backend architecture</li>
            <li>Azure services: App Service, Storage, Key Vault</li>
            <li>CI/CD pipelines with GitHub Actions and Azure DevOps</li>
            <li>Infrastructure as Code basics and environment configuration</li>
        </ul>
    </div>

    <div>
        <h2>This blog is also a working system</h2>
        <p>
            I use this platform as a portfolio project to show how I structure, document,
            build, and deploy backend applications with cloud and automation in mind.
        </p>
        <a class="inline-link" href="/projects">See how it is built →</a>
    </div>
</section>

@if (IsBlogDisplayModeSwitchEnabled)
{
    <section class="container-xl blog-view-switch-section">
        <ViewModeSwitch CurrentView="@CurrentView" />
    </section>
}

@if (_isLoading)
{
    <section class="content-frame container-xl">
        <section class="posts-area">
            <p>Loading posts from Umbraco CMS...</p>
        </section>
    </section>
}
else if (IsLearningPathView)
{
    <section class="content-frame content-frame-learning-path container-xl">
        <LearningPathView Levels="@_learningPathLevels"
                          Visualization="@_learningPathVisualization" />
    </section>
}
else
{
    <section class="content-frame container-xl">
        <aside class="sidebar">
            <CategorySidebar ActiveSlug="@Category"
                             Categories="@_categories" />
        </aside>

        <section class="posts-area">
            <div class="section-header">
                <div>
                    <div class="section-kicker">LATEST CONTENT</div>
                    <h2>@PageTitleText</h2>
                    <p>@Subtitle</p>
                </div>

                <a href="/articles">Browse all posts</a>
            </div>

            @if (_posts.Count == 0)
            {
                <p>No posts found.</p>
            }
            else
            {
                <div class="post-grid">
                    @foreach (var post in _posts)
                    {
                        <PostCard Title="@post.Title"
                                  Summary="@post.Summary"
                                  Category="@post.Category"
                                  Level="@post.Level"
                                  Focus="@post.Focus"
                                  Url="@($"/articles/{post.Slug}")"
                                  TechStack="@post.Tags" />
                    }
                </div>
            }
        </section>
    </section>
}

@code {
    [SupplyParameterFromQuery(Name = "category")]
    public string? Category { get; set; }

    [SupplyParameterFromQuery(Name = "view")]
    public string? View { get; set; }

    private IReadOnlyCollection<PostListItem> _posts = [];
    private IReadOnlyCollection<CategoryItem> _categories = [];
    private IReadOnlyCollection<LearningPathLevel> _learningPathLevels = [];
    private LearningPathVisualizationType _learningPathVisualization;
    private bool _isLoading = true;

    private bool IsBlogDisplayModeSwitchEnabled =>
    Configuration.GetValue<bool>(
        "Features:EnableBlogDisplayModeSwitch",
        true);

    private bool IsLearningPathView =>
        string.Equals(CurrentView, "path", StringComparison.OrdinalIgnoreCase);

    private string CurrentView =>
        string.Equals(View, "path", StringComparison.OrdinalIgnoreCase)
            ? "path"
            : "latest";

    private string PageTitleText =>
        string.IsNullOrWhiteSpace(Category)
            ? "Recent engineering notes"
            : _categories.FirstOrDefault(x => x.Slug == Category)?.Name ?? "Recent engineering notes";

    private string Subtitle =>
        string.IsNullOrWhiteSpace(Category)
            ? "Compact notes focused on backend systems, cloud deployment, and architecture."
            : "Filtered notes for this engineering area.";

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;

        _learningPathVisualization = ReadLearningPathVisualization();

        var homeContent = await BlogApi.GetHomeContentAsync(Category);

        _categories = homeContent.Categories;
        _posts = homeContent.Posts;
        _learningPathLevels = LearningPathCatalog.Build(homeContent.Posts);

        _isLoading = false;
    }

    private LearningPathVisualizationType ReadLearningPathVisualization()
    {
        var configuredValue = Configuration["LearningPath:Visualization"];

        if (Enum.TryParse<LearningPathVisualizationType>(
                configuredValue,
                ignoreCase: true,
                out var visualization))
        {
            return visualization;
        }

        return LearningPathVisualizationType.DotnetVertical;
    }
}
