@page "/"
@page "/articles"

<PageTitle>.NET Backend & Cloud Engineering Notes</PageTitle>

<section class="hero container-xl">
    <div class="hero-main">
        <div class="eyebrow">
            <span></span>
            Portfolio blog · .NET backend · cloud-ready systems
        </div>

        <h1>
            .NET Backend Engineer<br />
            <span>building cloud-ready systems</span>
        </h1>

        <p>
            I design and build APIs, backend services, and cloud solutions using .NET and Azure.
            This blog documents practical engineering decisions, patterns, and real-world implementations.
        </p>

        <div class="hero-tags">
            <span>.NET</span>
            <span>ASP.NET Core</span>
            <span>Azure</span>
            <span>CI/CD</span>
            <span>Architecture</span>
        </div>
    </div>

    <div class="hero-side">
        <div class="signal-card">
            <small>Primary focus</small>
            <strong>.NET Backend + Cloud</strong>
        </div>
        <div class="signal-card">
            <small>Engineering signal</small>
            <strong>APIs · DevOps · Architecture</strong>
        </div>
    </div>
</section>

<section class="intro-strip container-xl">
    <div>
        <h2>Current focus</h2>
        <ul>
            <li>ASP.NET Core backend architecture</li>
            <li>Azure services: App Service, Storage, Key Vault</li>
            <li>CI/CD pipelines with GitHub Actions and Azure DevOps</li>
            <li>Infrastructure as Code basics and environment configuration</li>
        </ul>
    </div>

    <div>
        <h2>This blog is also a working system</h2>
        <p>
            I use this platform as a portfolio project to show how I structure, document,
            build, and deploy backend applications with cloud and automation in mind.
        </p>
        <a class="inline-link" href="/projects">See how it is built →</a>
    </div>
</section>

<section class="content-frame container-xl">
    <aside class="sidebar">
        <CategorySidebar ActiveSlug="@Category" />
    </aside>

    <section class="posts-area">
        <div class="section-header">
            <div>
                <div class="section-kicker">LATEST CONTENT</div>
                <h2>@PageTitleText</h2>
                <p>@Subtitle</p>
            </div>

            <a href="/articles">Browse all posts</a>
        </div>

        <div class="post-grid">
            @foreach (var post in VisiblePosts)
            {
                <PostCard Title="@post.Title"
                          Summary="@post.Description"
                          Category="@post.Category"
                          Level="@post.Level"
                          Focus="@post.Focus"
                          Url="@($"/articles/{post.Slug}")"
                          TechStack="@post.TechStack" />
            }
        </div>

        <div class="pagination-bar">
            <span>Page 1 of 1</span>

            <div class="pagination-buttons">
                <button disabled>← Previous</button>
                <button class="active">1</button>
                <button disabled>Next →</button>
            </div>
        </div>
    </section>
</section>

@code {
    [SupplyParameterFromQuery(Name = "category")]
    public string? Category { get; set; }

    private string PageTitleText =>
        string.IsNullOrWhiteSpace(Category)
            ? "Recent engineering notes"
            : Categories.FirstOrDefault(x => x.Slug == Category)?.Name ?? "Recent engineering notes";

    private string Subtitle =>
        string.IsNullOrWhiteSpace(Category)
            ? "Compact notes focused on backend systems, cloud deployment, and architecture."
            : "Filtered notes for this engineering area.";

    private IEnumerable<PostItem> VisiblePosts =>
        string.IsNullOrWhiteSpace(Category)
            ? Posts
            : Posts.Where(x => x.CategorySlug == Category);

