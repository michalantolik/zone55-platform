@page "/learnkit-test/{Slug}"

@using BlogPlatform.App.Components.Articles.LearnKitRendering
@using BlogPlatform.App.Models.LearnKit
@using BlogPlatform.App.Services

@inject IBlogApiClient BlogApiClient

@if (_article is null)
{
    <p>Loading LearnKit article...</p>
}
else
{
    <LearnKitArticleRenderer Article="_article" />
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private LearnKitArticleDetails? _article;

    protected override async Task OnParametersSetAsync()
    {
        _article = await BlogApiClient.GetLearnKitArticleBySlugAsync(Slug);
    }
}
