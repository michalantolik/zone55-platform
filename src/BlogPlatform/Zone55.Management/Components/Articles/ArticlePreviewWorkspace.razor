@implements IAsyncDisposable
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@inject IConfiguration Configuration
@inject IJSRuntime JS

<div class="preview-workspace">
    <div class="preview-workspace__toolbar">
        <div>
            <strong>Portal article preview</strong>
            <span>Rendered by BlogPlatform.App from the current unsaved draft.</span>
            <code>@PreviewUrl</code>
        </div>
        <div class="preview-workspace__actions">
            <span class="preview-status preview-status--@_connectionState.ToString().ToLowerInvariant()">
                @ConnectionLabel
            </span>
            <a class="preview-open-link" href="@PreviewUrl" target="_blank" rel="noopener noreferrer">
                Open preview page
            </a>
        </div>
    </div>

    <div class="preview-frame-shell">
        <iframe @ref="_previewFrame"
                src="@PreviewUrl"
                title="Article preview"
                loading="eager"
                sandbox="allow-scripts allow-same-origin"
                referrerpolicy="strict-origin-when-cross-origin">
        </iframe>
    </div>

    @if (_connectionState == PreviewConnectionState.Unavailable)
    {
        <p class="preview-runtime-note preview-runtime-note--error" role="alert">
            The portal preview did not become ready. Start BlogPlatform.App and verify the configured
            <code>Portal:BaseUrl</code> value.
        </p>
    }
    else
    {
        <p class="preview-runtime-note">
            Metadata and valid unsaved block changes are sent directly to the portal renderer. Invalid draft JSON
            remains in the editor and is omitted until it becomes valid.
        </p>
    }
</div>

@code {
    [Parameter] public string Slug { get; set; } = "preview";
    [Parameter] public string Title { get; set; } = "Untitled article";
    [Parameter] public string? Summary { get; set; }
    [Parameter] public string BodyContent { get; set; } = "[]";

    private string _portalOrigin = string.Empty;
    private string _previewUrl = string.Empty;
    private ElementReference _previewFrame;
    private IJSObjectReference? _module;
    private DotNetObjectReference<ArticlePreviewWorkspace>? _objectReference;
    private PreviewConnectionState _connectionState = PreviewConnectionState.Connecting;
    private int _payloadVersion;
    private int _sentPayloadVersion = -1;
    private bool _connected;

    private string PreviewUrl => _previewUrl;

    private string ConnectionLabel => _connectionState switch
    {
        PreviewConnectionState.Connecting => "Connecting to portal",
        PreviewConnectionState.Ready => "Portal ready",
        PreviewConnectionState.Rendered => "Draft rendered",
        PreviewConnectionState.Unavailable => "Portal unavailable",
        _ => "Preview status unknown"
    };

    protected override void OnInitialized()
    {
        var configuredBaseUrl = Configuration["Portal:BaseUrl"];
        if (string.IsNullOrWhiteSpace(configuredBaseUrl))
        {
            throw new InvalidOperationException("Portal:BaseUrl is missing.");
        }

        var portalBaseUri = new Uri(configuredBaseUrl, UriKind.Absolute);
        _portalOrigin = portalBaseUri.GetLeftPart(UriPartial.Authority);
        _previewUrl = new Uri(portalBaseUri, "preview/article").AbsoluteUri;
    }

    protected override void OnParametersSet()
    {
        _payloadVersion++;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import",
                "./js/article-preview-workspace.js");
            _objectReference = DotNetObjectReference.Create(this);

            await _module.InvokeVoidAsync(
                "connectArticlePreview",
                _previewFrame,
                _objectReference,
                _portalOrigin);

            _connected = true;
        }

        if (_connected && _module is not null && _sentPayloadVersion != _payloadVersion)
        {
            _sentPayloadVersion = _payloadVersion;
            _connectionState = PreviewConnectionState.Connecting;

            await _module.InvokeVoidAsync(
                "sendArticlePreview",
                _previewFrame,
                new PreviewArticlePayload(
                    Normalize(Slug, "preview"),
                    Normalize(Title, "Untitled article"),
                    Summary,
                    BodyContent));
        }
    }

    [JSInvokable]
    public Task NotifyPreviewReady()
    {
        _connectionState = PreviewConnectionState.Ready;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task NotifyPreviewRendered()
    {
        _connectionState = PreviewConnectionState.Rendered;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task NotifyPreviewUnavailable()
    {
        if (_connectionState is not PreviewConnectionState.Ready and not PreviewConnectionState.Rendered)
        {
            _connectionState = PreviewConnectionState.Unavailable;
        }

        return InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("disconnectArticlePreview", _previewFrame);
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // The browser session has already ended.
            }
        }

        _objectReference?.Dispose();
    }

    private static string Normalize(string? value, string fallback) =>
        string.IsNullOrWhiteSpace(value) ? fallback : value.Trim();

    private sealed record PreviewArticlePayload(
        string Slug,
        string Title,
        string? Summary,
        string BodyHtml);

    private enum PreviewConnectionState
    {
        Connecting,
        Ready,
        Rendered,
        Unavailable
    }
}
