@using System.Text.Json
@implements IAsyncDisposable
@inject IJSRuntime JavaScript

<div class="preview-workspace">
    <div class="preview-workspace__toolbar">
        <div>
            <strong>Live article preview</strong>
            <span>Rendered by BlogPlatform.App at <code>@PreviewUrl</code></span>
        </div>
        <a class="preview-open-link" href="@PreviewUrl" target="_blank" rel="noopener noreferrer">
            Open portal preview
        </a>
    </div>

    <div class="preview-frame-shell">
        <iframe @ref="_frame"
                title="Article preview"
                src="@PreviewUrl"
                loading="eager"></iframe>
    </div>

    <p class="preview-runtime-note">
        BlogPlatform.App must be running at the configured portal address. The preview reconnects automatically when the iframe becomes ready.
    </p>
</div>

@code {
    [Parameter, EditorRequired] public string PreviewUrl { get; set; } = string.Empty;
    [Parameter] public string Slug { get; set; } = "preview";
    [Parameter] public string Title { get; set; } = "Untitled article";
    [Parameter] public string? Summary { get; set; }
    [Parameter] public string BodyContent { get; set; } = "[]";

    private ElementReference _frame;
    private string _lastPayload = string.Empty;
    private IJSObjectReference? _module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        _module ??= await JavaScript.InvokeAsync<IJSObjectReference>(
            "import",
            "./js/article-preview-workspace.js");

        if (firstRender)
        {
            await _module.InvokeVoidAsync("connectArticlePreview", _frame);
        }

        await SendPreviewAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_module is not null)
        {
            await SendPreviewAsync();
        }
    }

    private async Task SendPreviewAsync()
    {
        if (_module is null)
        {
            return;
        }

        var payload = JsonSerializer.Serialize(new
        {
            slug = Slug,
            title = Title,
            summary = Summary,
            bodyHtml = BodyContent
        });

        if (payload == _lastPayload)
        {
            return;
        }

        _lastPayload = payload;

        await _module.InvokeVoidAsync(
            "sendArticlePreview",
            _frame,
            JsonSerializer.Deserialize<object>(payload));
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            await _module.DisposeAsync();
        }
    }
}
