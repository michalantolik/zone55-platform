@inherits LayoutComponentBase
@inject Zone55.Management.Authentication.ManagementAuthenticationService Authentication
@inject NavigationManager Navigation

<div class="management-shell">
    <aside class="sidebar">
        <NavLink class="brand" href="/" Match="NavLinkMatch.All">
            <span class="brand-mark">Z55</span>
            <span>
                <strong>Zone55</strong>
                <small>Management</small>
            </span>
        </NavLink>

        <nav aria-label="Management navigation">
            <NavLink href="/" Match="NavLinkMatch.All">Articles</NavLink>
            <NavLink href="/structure">Structure</NavLink>
        </nav>

        <AuthorizeView>
            <Authorized>
                <button type="button" class="sidebar-signout" @onclick="SignOutAsync">Sign out</button>
            </Authorized>
        </AuthorizeView>
    </aside>

    <main class="management-content">
        @Body
    </main>
</div>

@code {
    private async Task SignOutAsync()
    {
        await Authentication.LogoutAsync();
        Navigation.NavigateTo("/login", replace: true);
    }
}
