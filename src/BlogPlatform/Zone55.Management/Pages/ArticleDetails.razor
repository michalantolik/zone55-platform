@page "/articles/{ArticleId:guid}"
@attribute [Authorize]
@using System.Text.Json
@inject ILearnKitManagementClient ManagementClient
@inject Microsoft.Extensions.Options.IOptions<LearnKitManagementOptions> ManagementOptions
@inject NavigationManager Navigation
@inject IJSRuntime JavaScript

<PageTitle>@(_article?.Title ?? "Article") | Zone55 Management</PageTitle>

@if (_isLoading)
{
    <div class="state-card" role="status">
        <strong>Loading article…</strong>
        <p>Reading article details from Zone55.Api.</p>
    </div>
}
else if (_errorMessage is not null && _article is null)
{
    <div class="state-card state-card--error" role="alert">
        <strong>Could not load article</strong>
        <p>@_errorMessage</p>
        <div class="button-row">
            <button class="primary-button" type="button" @onclick="LoadAsync">Try again</button>
            <a class="secondary-button button-link" href="/">Back to articles</a>
        </div>
    </div>
}
else if (_article is null)
{
    <div class="state-card">
        <strong>Article not found</strong>
        <p>No LearnKit article exists with this identifier.</p>
        <a class="secondary-button button-link" href="/">Back to articles</a>
    </div>
}
else
{
    <header class="page-header details-header">
        <div>
            <a class="back-link" href="/">← Articles</a>
            <p class="eyebrow">LearnKit article</p>
            <h1>@_article.Title</h1>
            <code class="article-slug">@_article.Slug</code>
        </div>
        <span class="status-badge @(IsPublished(_article.Status) ? "status-badge--published" : "status-badge--draft")">
            @_article.Status
        </span>
    </header>

    @if (_operationMessage is not null)
    {
        <div class="operation-message operation-message--success" role="status">@_operationMessage</div>
    }

    @if (_errorMessage is not null)
    {
        <div class="operation-message operation-message--error" role="alert">@_errorMessage</div>
    }

    <div class="workspace-mode-toolbar" role="group" aria-label="Article workspace mode">
        <div>
            <strong>Article workspace</strong>
            <span>Choose editing, split, or full preview mode.</span>
        </div>
        <div class="preview-mode-switcher">
            @foreach (var mode in WorkspaceModes)
            {
                <button type="button"
                        class="@(_workspaceMode == mode ? "active" : null)"
                        aria-pressed="@(_workspaceMode == mode)"
                        @onclick="() => SetWorkspaceMode(mode)">
                    @mode
                </button>
            }
        </div>
    </div>

    <div class="article-workspace article-workspace--@_workspaceMode.ToLowerInvariant()">
    <div class="article-workspace__editor">
    <section class="editor-card" aria-labelledby="article-editor-title">
        <div class="section-heading editor-heading">
            <div>
                <p class="eyebrow">Management</p>
                <h2 id="article-editor-title">Edit article details</h2>
            </div>
            <div class="button-row editor-actions">
                @if (IsPublished(_article.Status))
                {
                    <button class="secondary-button" type="button" @onclick="UnpublishAsync" disabled="@_isSaving">
                        Unpublish
                    </button>
                }
                else
                {
                    <button class="secondary-button" type="button" @onclick="PublishAsync" disabled="@_isSaving">
                        Publish
                    </button>
                }
                <button class="danger-button" type="button" @onclick="DeleteArticleAsync" disabled="@IsBusy">
                    Delete article
                </button>
                <button class="primary-button" type="button" @onclick="SaveAsync" disabled="@IsBusy">
                    @(_isSaving ? "Saving…" : "Save changes")
                </button>
            </div>
        </div>

        <div class="form-grid">
            <label class="form-field form-field--wide">
                <span>Title</span>
                <input @bind="_title" @bind:event="oninput" maxlength="300" disabled="@_isSaving" />
            </label>

            <label class="form-field">
                <span>Slug</span>
                <input @bind="_slug" @bind:event="oninput" disabled="@_isSaving" />
            </label>

            <label class="form-field">
                <span>Sort order</span>
                <input type="number" min="1" @bind="_sortOrder" disabled="@_isSaving" />
            </label>

            <label class="form-field form-field--wide">
                <span>Learning step</span>
                <select @bind="_learningStepId" disabled="@_isSaving">
                    @foreach (var step in _learningSteps)
                    {
                        <option value="@step.Id">@step.Title</option>
                    }
                </select>
            </label>

            <label class="form-field form-field--full">
                <span>Summary</span>
                <textarea rows="6" @bind="_summary" @bind:event="oninput" disabled="@_isSaving"></textarea>
            </label>
        </div>
    </section>

    <section class="details-grid" aria-label="Article details">
        <article class="details-card details-card--wide">
            <h2>Summary</h2>
            <p class="summary-text">@(_article.Summary.Length > 0 ? _article.Summary : "No summary.")</p>
        </article>

        <article class="details-card">
            <h2>Learning step</h2>
            <strong>@_learningStepTitle</strong>
            <code>@_article.LearningStepId</code>
        </article>

        <article class="details-card">
            <h2>Order</h2>
            <strong>@_article.SortOrder</strong>
        </article>

        <article class="details-card">
            <h2>Blocks</h2>
            <strong>@_article.Blocks.Count</strong>
        </article>
    </section>

    <section class="blocks-section">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Content</p>
                <h2>Article blocks</h2>
            </div>
            <button class="primary-button" type="button" @onclick="BeginBlockCreate" disabled="@IsBusy">
                Add block
            </button>
        </div>

        @if (_isCreatingBlock)
        {
            <article class="block-card block-card--new">
                <header>
                    <div>
                        <span class="block-order">+</span>
                        <strong>New article block</strong>
                    </div>
                </header>
                <div class="block-editor">
                    <div class="form-grid">
                        <label class="form-field">
                            <span>Type</span>
                            <select @bind="_newBlockType" disabled="@_isSavingBlock">
                                @foreach (var blockType in ArticleBlockTypes)
                                {
                                    <option value="@blockType">@blockType</option>
                                }
                            </select>
                        </label>
                        <label class="form-field">
                            <span>Position</span>
                            <input type="number" min="1" max="@(_article.Blocks.Count + 1)" @bind="_newBlockSortOrder" disabled="@_isSavingBlock" />
                        </label>
                        <div class="form-field form-field--full">
                            <TypedArticleBlockEditor @key="_newBlockType"
                                                     Type="@_newBlockType"
                                                     @bind-Value="_newBlockContentJson" />
                        </div>
                    </div>
                    @if (_blockErrorMessage is not null)
                    {
                        <div class="inline-error" role="alert">@_blockErrorMessage</div>
                    }
                    <div class="button-row block-editor-actions">
                        <button class="secondary-button" type="button" @onclick="CancelBlockCreate" disabled="@_isSavingBlock">Cancel</button>
                        <button class="primary-button" type="button" @onclick="CreateBlockAsync" disabled="@_isSavingBlock">
                            @(_isSavingBlock ? "Adding…" : "Add block")
                        </button>
                    </div>
                </div>
            </article>
        }

        @if (_article.Blocks.Count == 0 && !_isCreatingBlock)
        {
            <div class="state-card">
                <strong>No content blocks</strong>
                <p>This article does not contain any LearnKit blocks yet.</p>
            </div>
        }
        else
        {
            <div class="blocks-list">
                @foreach (var block in _article.Blocks.OrderBy(x => x.SortOrder))
                {
                    var isEditing = _editingBlockId == block.Id;

                    <article class="block-card">
                        <header>
                            <div>
                                <span class="block-order">@block.SortOrder</span>
                                <strong>@block.Type</strong>
                            </div>
                            <div class="block-header-actions">
                                <code>@block.Id</code>
                                @if (!isEditing)
                                {
                                    var orderedBlocks = _article.Blocks.OrderBy(x => x.SortOrder).ToArray();
                                    var blockIndex = Array.FindIndex(orderedBlocks, x => x.Id == block.Id);
                                    <button class="icon-button" title="Move block up" type="button" @onclick="() => MoveBlockAsync(block.Id, -1)" disabled="@(IsBusy || blockIndex <= 0)">↑</button>
                                    <button class="icon-button" title="Move block down" type="button" @onclick="() => MoveBlockAsync(block.Id, 1)" disabled="@(IsBusy || blockIndex >= orderedBlocks.Length - 1)">↓</button>
                                    <button class="secondary-button secondary-button--compact" type="button" @onclick="() => BeginBlockEdit(block)" disabled="@IsBusy">Edit</button>
                                    <button class="danger-button danger-button--compact" type="button" @onclick="() => DeleteBlockAsync(block)" disabled="@IsBusy">Delete</button>
                                }
                            </div>
                        </header>

                        @if (isEditing)
                        {
                            <div class="block-editor">
                                <div class="form-grid">
                                    <label class="form-field">
                                        <span>Type</span>
                                        <select @bind="_editingBlockType" disabled="@_isSavingBlock">
                                            @foreach (var blockType in ArticleBlockTypes)
                                            {
                                                <option value="@blockType">@blockType</option>
                                            }
                                        </select>
                                    </label>

                                    <div class="form-field form-field--full">
                                        <TypedArticleBlockEditor @key="_editingBlockType"
                                                                 Type="@_editingBlockType"
                                                                 @bind-Value="_editingBlockContentJson" />
                                    </div>
                                </div>

                                @if (_blockErrorMessage is not null)
                                {
                                    <div class="inline-error" role="alert">@_blockErrorMessage</div>
                                }

                                <div class="button-row block-editor-actions">
                                    <button class="secondary-button"
                                            type="button"
                                            @onclick="CancelBlockEdit"
                                            disabled="@_isSavingBlock">
                                        Cancel
                                    </button>
                                    <button class="primary-button"
                                            type="button"
                                            @onclick="SaveBlockAsync"
                                            disabled="@_isSavingBlock">
                                        @(_isSavingBlock ? "Saving…" : "Save block")
                                    </button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <pre><code>@FormatJson(block.ContentJson)</code></pre>
                        }
                    </article>
                }
            </div>
        }
    </section>
    </div>

    <aside class="article-workspace__preview">
        <ArticlePreviewWorkspace Slug="@_slug"
                                 Title="@_title"
                                 Summary="@_summary"
                                 BodyContent="@BuildPreviewBodyContent()" />
    </aside>
    </div>
}

@code {
    [Parameter]
    public Guid ArticleId { get; set; }

    private ArticleManagementDetails? _article;
    private IReadOnlyCollection<LearningStepManagementDetails> _learningSteps = [];
    private string _learningStepTitle = string.Empty;
    private Guid _learningStepId;
    private string _slug = string.Empty;
    private string _title = string.Empty;
    private string _summary = string.Empty;
    private int _sortOrder;
    private static readonly string[] WorkspaceModes = ["Editor", "Split", "Preview"];

    private static readonly string[] ArticleBlockTypes =
    [
        "Markdown",
        "Code",
        "Diagram",
        "Table",
        "Callout",
        "Summary"
    ];

    private bool _isLoading = true;
    private bool _isSaving;
    private bool _isSavingBlock;
    private bool _isDeletingArticle;
    private bool _isCreatingBlock;
    private string _newBlockType = ArticleBlockTypes[0];
    private int _newBlockSortOrder = 1;
    private string _newBlockContentJson = CreateDefaultBlockJson(ArticleBlockTypes[0]);
    private string _workspaceMode = "Split";
    private Guid? _editingBlockId;
    private string _editingBlockType = string.Empty;
    private string _editingBlockContentJson = string.Empty;
    private string? _blockErrorMessage;
    private string? _errorMessage;
    private string? _operationMessage;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _operationMessage = null;

        try
        {
            var articleTask = ManagementClient.GetArticleAsync(ArticleId);
            var learningPathTask = ManagementClient.GetLearningPathAsync(ManagementOptions.Value.DefaultLearningPathKey);

            await Task.WhenAll(articleTask, learningPathTask);

            _article = await articleTask;
            var learningPath = await learningPathTask;
            _learningSteps = learningPath?.Zones
                .OrderBy(zone => zone.SortOrder)
                .SelectMany(zone => zone.Steps.OrderBy(step => step.SortOrder))
                .ToArray()
                ?? [];

            ApplyArticleToEditor();
        }
        catch (HttpRequestException exception)
        {
            _errorMessage = exception.Message;
        }
        catch (Exception exception)
        {
            _errorMessage = $"Unexpected error: {exception.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        if (_article is null || _isSaving)
        {
            return;
        }

        _errorMessage = ValidateEditor();
        _operationMessage = null;

        if (_errorMessage is not null)
        {
            return;
        }

        _isSaving = true;

        try
        {
            var request = new UpdateArticleManagementRequest(
                _learningStepId,
                _slug.Trim(),
                _title.Trim(),
                string.IsNullOrWhiteSpace(_summary) ? null : _summary.Trim(),
                _sortOrder);

            await ManagementClient.UpdateArticleAsync(ArticleId, request);
            await ReloadArticleAsync();
            _operationMessage = "Article details were saved.";
        }
        catch (HttpRequestException exception)
        {
            _errorMessage = exception.Message;
        }
        catch (Exception exception)
        {
            _errorMessage = $"Unexpected error: {exception.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private bool IsBusy => _isSaving || _isSavingBlock || _isDeletingArticle;

    private void BeginBlockCreate()
    {
        if (IsBusy || _article is null)
        {
            return;
        }

        ClearBlockEditor();
        _isCreatingBlock = true;
        _newBlockType = ArticleBlockTypes[0];
        _newBlockSortOrder = _article.Blocks.Count + 1;
        _newBlockContentJson = CreateDefaultBlockJson(_newBlockType);
        _blockErrorMessage = null;
        _errorMessage = null;
        _operationMessage = null;
    }

    private void CancelBlockCreate()
    {
        if (!_isSavingBlock)
        {
            _isCreatingBlock = false;
            _blockErrorMessage = null;
        }
    }

    private async Task CreateBlockAsync()
    {
        if (_article is null || !_isCreatingBlock || _isSavingBlock)
        {
            return;
        }

        _blockErrorMessage = ValidateBlock(_newBlockType, _newBlockContentJson, _newBlockSortOrder);
        if (_blockErrorMessage is not null)
        {
            return;
        }

        _isSavingBlock = true;
        try
        {
            await ManagementClient.CreateArticleBlockAsync(
                ArticleId,
                new CreateArticleBlockManagementRequest(
                    _newBlockType,
                    _newBlockSortOrder,
                    _newBlockContentJson.Trim()));

            await ReloadArticleAsync();
            _isCreatingBlock = false;
            _operationMessage = "Article block was added.";
        }
        catch (Exception exception)
        {
            _blockErrorMessage = exception is HttpRequestException
                ? exception.Message
                : $"Unexpected error: {exception.Message}";
        }
        finally
        {
            _isSavingBlock = false;
        }
    }

    private void BeginBlockEdit(ArticleBlockDetails block)
    {
        if (_isSavingBlock)
        {
            return;
        }

        _isCreatingBlock = false;
        _editingBlockId = block.Id;
        _editingBlockType = block.Type;
        _editingBlockContentJson = FormatJson(block.ContentJson);
        _blockErrorMessage = null;
        _errorMessage = null;
        _operationMessage = null;
    }

    private void CancelBlockEdit()
    {
        if (_isSavingBlock)
        {
            return;
        }

        ClearBlockEditor();
    }

    private async Task SaveBlockAsync()
    {
        if (_article is null || _editingBlockId is null || _isSavingBlock)
        {
            return;
        }

        _blockErrorMessage = ValidateBlockEditor();
        _errorMessage = null;
        _operationMessage = null;

        if (_blockErrorMessage is not null)
        {
            return;
        }

        _isSavingBlock = true;

        try
        {
            var blockId = _editingBlockId.Value;
            var request = new UpdateArticleBlockManagementRequest(
                _editingBlockType,
                _editingBlockContentJson.Trim());

            await ManagementClient.UpdateArticleBlockAsync(
                ArticleId,
                blockId,
                request);

            await ReloadArticleAsync();
            ClearBlockEditor();
            _operationMessage = "Article block was saved.";
        }
        catch (HttpRequestException exception)
        {
            _blockErrorMessage = exception.Message;
        }
        catch (Exception exception)
        {
            _blockErrorMessage = $"Unexpected error: {exception.Message}";
        }
        finally
        {
            _isSavingBlock = false;
        }
    }

    private string? ValidateBlockEditor() =>
        ValidateBlock(_editingBlockType, _editingBlockContentJson, 1);

    private static string? ValidateBlock(string type, string contentJson, int sortOrder)
    {
        if (!ArticleBlockTypes.Contains(type, StringComparer.Ordinal))
        {
            return "Block type is invalid.";
        }

        if (sortOrder < 1)
        {
            return "Block position must be greater than zero.";
        }

        if (string.IsNullOrWhiteSpace(contentJson))
        {
            return "Content JSON is required.";
        }

        try
        {
            using var document = JsonDocument.Parse(contentJson);
        }
        catch (JsonException exception)
        {
            return $"Content JSON is invalid: {exception.Message}";
        }

        return null;
    }

    private void ClearBlockEditor()
    {
        _editingBlockId = null;
        _editingBlockType = string.Empty;
        _editingBlockContentJson = string.Empty;
        _blockErrorMessage = null;
    }


    private async Task DeleteBlockAsync(ArticleBlockDetails block)
    {
        if (_article is null || IsBusy)
        {
            return;
        }

        var confirmed = await JavaScript.InvokeAsync<bool>(
            "confirm",
            $"Delete the {block.Type} block at position {block.SortOrder}? This cannot be undone.");

        if (!confirmed)
        {
            return;
        }

        _isSavingBlock = true;
        _errorMessage = null;
        _operationMessage = null;

        try
        {
            await ManagementClient.DeleteArticleBlockAsync(ArticleId, block.Id);
            await ReloadArticleAsync();
            _operationMessage = "Article block was deleted.";
        }
        catch (Exception exception)
        {
            _errorMessage = exception is HttpRequestException
                ? exception.Message
                : $"Unexpected error: {exception.Message}";
        }
        finally
        {
            _isSavingBlock = false;
        }
    }

    private async Task MoveBlockAsync(Guid blockId, int direction)
    {
        if (_article is null || IsBusy)
        {
            return;
        }

        var orderedIds = _article.Blocks.OrderBy(block => block.SortOrder).Select(block => block.Id).ToList();
        var currentIndex = orderedIds.IndexOf(blockId);
        var targetIndex = currentIndex + direction;

        if (currentIndex < 0 || targetIndex < 0 || targetIndex >= orderedIds.Count)
        {
            return;
        }

        (orderedIds[currentIndex], orderedIds[targetIndex]) = (orderedIds[targetIndex], orderedIds[currentIndex]);
        _isSavingBlock = true;
        _errorMessage = null;
        _operationMessage = null;

        try
        {
            await ManagementClient.ReorderArticleBlocksAsync(
                ArticleId,
                new ReorderArticleBlocksManagementRequest(orderedIds));
            await ReloadArticleAsync();
            _operationMessage = "Article block order was updated.";
        }
        catch (Exception exception)
        {
            _errorMessage = exception is HttpRequestException
                ? exception.Message
                : $"Unexpected error: {exception.Message}";
        }
        finally
        {
            _isSavingBlock = false;
        }
    }

    private async Task DeleteArticleAsync()
    {
        if (_article is null || IsBusy)
        {
            return;
        }

        var confirmed = await JavaScript.InvokeAsync<bool>(
            "confirm",
            $"Delete '{_article.Title}' and all of its blocks? This cannot be undone.");

        if (!confirmed)
        {
            return;
        }

        _isDeletingArticle = true;
        _errorMessage = null;

        try
        {
            await ManagementClient.DeleteArticleAsync(ArticleId);
            Navigation.NavigateTo("/");
        }
        catch (Exception exception)
        {
            _errorMessage = exception is HttpRequestException
                ? exception.Message
                : $"Unexpected error: {exception.Message}";
            _isDeletingArticle = false;
        }
    }

    private async Task PublishAsync()
    {
        await ChangePublicationStatusAsync(
            () => ManagementClient.PublishArticleAsync(ArticleId),
            "Article was published.");
    }

    private async Task UnpublishAsync()
    {
        await ChangePublicationStatusAsync(
            () => ManagementClient.UnpublishArticleAsync(ArticleId),
            "Article was moved to draft.");
    }

    private async Task ChangePublicationStatusAsync(Func<Task> operation, string successMessage)
    {
        if (_article is null || _isSaving)
        {
            return;
        }

        _isSaving = true;
        _errorMessage = null;
        _operationMessage = null;

        try
        {
            await operation();
            await ReloadArticleAsync();
            _operationMessage = successMessage;
        }
        catch (HttpRequestException exception)
        {
            _errorMessage = exception.Message;
        }
        catch (Exception exception)
        {
            _errorMessage = $"Unexpected error: {exception.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task ReloadArticleAsync()
    {
        _article = await ManagementClient.GetArticleAsync(ArticleId)
            ?? throw new HttpRequestException("The article could not be reloaded after the operation.");

        ApplyArticleToEditor();
    }

    private void ApplyArticleToEditor()
    {
        if (_article is null)
        {
            _learningStepTitle = string.Empty;
            return;
        }

        _learningStepId = _article.LearningStepId;
        _slug = _article.Slug;
        _title = _article.Title;
        _summary = _article.Summary;
        _sortOrder = _article.SortOrder;
        _learningStepTitle = _learningSteps
            .FirstOrDefault(step => step.Id == _article.LearningStepId)
            ?.Title
            ?? _article.LearningStepId.ToString();
    }

    private string? ValidateEditor()
    {
        if (string.IsNullOrWhiteSpace(_title))
        {
            return "Title is required.";
        }

        if (string.IsNullOrWhiteSpace(_slug))
        {
            return "Slug is required.";
        }

        if (_learningStepId == Guid.Empty)
        {
            return "Learning step is required.";
        }

        if (_sortOrder < 1)
        {
            return "Sort order must be greater than zero.";
        }

        return null;
    }

    private static string FormatJson(string contentJson)
    {
        if (string.IsNullOrWhiteSpace(contentJson))
        {
            return string.Empty;
        }

        try
        {
            using var document = JsonDocument.Parse(contentJson);
            return JsonSerializer.Serialize(
                document.RootElement,
                new JsonSerializerOptions { WriteIndented = true });
        }
        catch (JsonException)
        {
            return contentJson;
        }
    }

    private void SetWorkspaceMode(string mode)
    {
        if (WorkspaceModes.Contains(mode, StringComparer.Ordinal))
        {
            _workspaceMode = mode;
        }
    }

    private string BuildPreviewBodyContent()
    {
        if (_article is null)
        {
            return "[]";
        }

        var blocks = _article.Blocks
            .OrderBy(block => block.SortOrder)
            .Select(block => new PreviewBlock(block.Type, block.ContentJson, block.SortOrder))
            .ToList();

        if (_editingBlockId is not null)
        {
            var existing = _article.Blocks.FirstOrDefault(block => block.Id == _editingBlockId.Value);
            if (existing is not null)
            {
                var index = blocks.FindIndex(block => block.SortOrder == existing.SortOrder);
                if (index >= 0)
                {
                    blocks[index] = new PreviewBlock(_editingBlockType, _editingBlockContentJson, existing.SortOrder);
                }
            }
        }

        if (_isCreatingBlock)
        {
            blocks.Add(new PreviewBlock(_newBlockType, _newBlockContentJson, _newBlockSortOrder));
        }

        var content = new List<JsonElement>();
        foreach (var block in blocks.OrderBy(block => block.SortOrder))
        {
            try
            {
                using var document = JsonDocument.Parse(block.ContentJson);
                var values = new Dictionary<string, object?>
                {
                    ["type"] = block.Type,
                    ["sortOrder"] = block.SortOrder
                };

                foreach (var property in document.RootElement.EnumerateObject())
                {
                    values[property.Name] = property.Value.Clone();
                }

                content.Add(JsonSerializer.SerializeToElement(values));
            }
            catch (JsonException)
            {
                // Invalid draft JSON is ignored until the editor becomes valid.
            }
        }

        return JsonSerializer.Serialize(content);
    }

    private static string CreateDefaultBlockJson(string type) => type switch
    {
        "Code" => """
        {
          "code": "",
          "language": "csharp",
          "showCodeTitleBar": true
        }
        """,
        "Diagram" => """
        {
